    {
      "id": "bridge-surface-demo-instructions",
      "type": "markdown",
      "label": "Instructions",
      "position": {
        "x": -260,
        "y": 40
      },
      "width": 520,
      "height": 360,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "## Try it\n\n1) Click the **Import Bridge** node.\n2) Use its primary action to create an instance of the bridged class in this graph.\n3) Edit the bridge node and change `bridge.ref` to a different node-class ref.\n\nNotes:\n- Import bridges usually need `create` grant.\n- Export bridges define outward exposure (views/node classes/edges/scripts)."
      }
    },
    {
      "id": "bridge-surface-demo-import-bridge",
      "type": "bridge",
      "label": "Import Bridge",
      "position": {
        "x": 140,
        "y": 90
      },
      "width": 360,
      "height": 180,
      "visible": true,
      "showLabel": true,
      "data": {
        "memo": "Import bridge: create summary-view nodes in this graph.",
        "authority": "bridge",
        "bridge": {
          "ref": "/library/classes/nodes/ui-interaction/summary-view.node-class.node",
          "role": "import",
          "scope": "focused-graph",
          "grants": [
            "create"
          ],
          "exposure": {
            "nodeClasses": {
              "mode": "deny"
            },
            "edgeClasses": {
              "mode": "deny"
            },
            "views": {
              "mode": "deny"
            },
            "scripts": {
              "mode": "deny"
            },
            "declarations": {
              "mode": "deny"
            }
          }
        },
        "target": {
          "endpoint": "/library/classes/nodes/ui-interaction/summary-view.node-class.node:root",
          "mode": "bridge",
          "kind": "node-class",
          "resourceKind": "node-class",
          "scope": "focused-graph",
          "role": "import",
          "grants": [
            "create"
          ],
          "label": "Summary View",
          "key": "summary-view"
        }
      }
    },
    {
      "id": "bridge-surface-demo-export-bridge",
      "type": "bridge",
      "label": "Export Bridge",
      "position": {
        "x": 520,
        "y": 90
      },
      "width": 360,
      "height": 180,
      "visible": true,
      "showLabel": true,
      "data": {
        "memo": "Export bridge: expose views outward (example allowlist).",
        "authority": "bridge",
        "bridge": {
          "ref": "/tutorial/views-surface-demo.document.node",
          "role": "export",
          "scope": "focused-graph",
          "grants": [
            "create"
          ],
          "exposure": {
            "nodeClasses": {
              "mode": "deny"
            },
            "edgeClasses": {
              "mode": "deny"
            },
            "views": {
              "mode": "allowlist",
              "allowKeys": [
                "node.web.summary",
                "node.web.detail",
                "node.web.icon"
              ]
            },
            "scripts": {
              "mode": "deny"
            },
            "declarations": {
              "mode": "allow"
            }
          }
        },
        "target": {
          "endpoint": "/tutorial/views-surface-demo.document.node:root",
          "mode": "bridge",
          "kind": "graph",
          "resourceKind": "graph",
          "scope": "focused-graph",
          "role": "export",
          "grants": [
            "create"
          ],
          "label": "Views Surface Demo"
        }
      }
