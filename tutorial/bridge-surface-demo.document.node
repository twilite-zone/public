        "payload": "node.web.summary",
        "title": "Bridge Surface Demo",
        "purpose": "This graph contains two bridge nodes:\n- Import bridge: creates nodes from an external node-class.\n- Export bridge: configures outward exposure (allowlists) for other graphs.\n\nUse the edit drawer on each bridge to inspect the contract.",
        "status": "active",
        "viewRole": "summary",
        "viewKind": "display",
        "exposedAuthority": "consume-view",
        "svg": "<svg viewBox=\"0 0 220 160\" xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\"><rect x=\"18\" y=\"18\" width=\"184\" height=\"124\" rx=\"18\" fill=\"#fff7ed\" stroke=\"#ea580c\" stroke-width=\"5\"/><path d=\"M54 58h58\" stroke=\"#111827\" stroke-width=\"10\" stroke-linecap=\"round\"/><path d=\"M54 102h58\" stroke=\"#111827\" stroke-width=\"10\" stroke-linecap=\"round\" opacity=\"0.6\"/><path d=\"M128 80h34\" stroke=\"#ea580c\" stroke-width=\"10\" stroke-linecap=\"round\"/><path d=\"M154 62v36\" stroke=\"#ea580c\" stroke-width=\"10\" stroke-linecap=\"round\"/></svg>",
