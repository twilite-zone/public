      "data": {
        "title": "Nodes Hold Meaning",
        "body": "A node is a discrete unit. It can represent an idea, decision, example, step, person, file, view, or contract. Because the unit is discrete, you can move it, inspect it, reference it, and change it without rewriting everything around it.",
        "_classBinding": {
          "key": "tutorial-concept",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node",
          "ref": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
