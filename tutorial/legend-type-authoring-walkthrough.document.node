      "data": {
        "payload": "node.web.summary",
        "title": "Legend + Type Walkthrough",
        "purpose": "The Legend tab is a derived surface. This walkthrough shows the minimal structure required for Legend entries to appear deterministically and for node classes to be spawnable from the Legend.\n\nThe key move: import a catalog graph that contains bridge/port targets to node classes (and optionally edge classes).",
        "status": "active",
        "viewRole": "summary",
        "viewKind": "display",
        "exposedAuthority": "consume-view",
        "svg": "<svg viewBox=\"0 0 220 160\" xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\"><rect x=\"18\" y=\"18\" width=\"184\" height=\"124\" rx=\"18\" fill=\"#fdf2f8\" stroke=\"#db2777\" stroke-width=\"5\"/><path d=\"M54 62h112\" stroke=\"#111827\" stroke-width=\"10\" stroke-linecap=\"round\"/><path d=\"M54 98h76\" stroke=\"#111827\" stroke-width=\"10\" stroke-linecap=\"round\" opacity=\"0.6\"/><circle cx=\"162\" cy=\"98\" r=\"14\" fill=\"#db2777\"/></svg>",
