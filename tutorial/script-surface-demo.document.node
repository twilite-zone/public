        "source": "const nodes = await api.getNodes();\nconst edges = await api.getEdges();\n\nreturn {\n  ok: true,\n  nodeCount: Array.isArray(nodes) ? nodes.length : 0,\n  edgeCount: Array.isArray(edges) ? edges.length : 0,\n  at: new Date().toISOString()\n};"
