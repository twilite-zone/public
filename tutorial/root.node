        },
        "intent": {
          "kind": "tutorial",
          "scope": "local"
        },
        "declaration": {
          "targetMode": "artifact",
          "defaultSurfaceId": "tutorial-view",
          "surfaces": [
            {
              "id": "tutorial-view",
              "kind": "view",
              "label": "Tutorial Reader",
              "memo": "Primary declared reader surface for the tutorial shelf.",
