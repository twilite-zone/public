      "data": {
        "payload": "node.web.summary",
        "title": "Walkthrough Readiness",
        "purpose": "This graph is a checklist and index of walkthroughs for the primitives we expect authors to use. Each walkthrough should close the loop: author → render → edit → consume/discover → (if applicable) export/import.",
        "status": "active",
        "viewRole": "summary",
        "viewKind": "display",
        "exposedAuthority": "consume-view",
        "svg": "<svg viewBox=\"0 0 220 160\" xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\"><rect x=\"18\" y=\"18\" width=\"184\" height=\"124\" rx=\"18\" fill=\"#f8fafc\" stroke=\"#0f172a\" stroke-width=\"5\"/><path d=\"M54 52h112\" stroke=\"#0f172a\" stroke-width=\"10\" stroke-linecap=\"round\"/><path d=\"M54 80h78\" stroke=\"#0f172a\" stroke-width=\"10\" stroke-linecap=\"round\" opacity=\"0.7\"/><path d=\"M54 108h94\" stroke=\"#0f172a\" stroke-width=\"10\" stroke-linecap=\"round\" opacity=\"0.45\"/><circle cx=\"166\" cy=\"108\" r=\"14\" fill=\"#22c55e\"/></svg>",
