      "label": "Checkpoint",
      "root": false,
      "position": {
        "x": 1580,
        "y": -120
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Checkpoint",
        "body": "You are done when you can say:\n- legend and elements help me discover and create\n- properties help me inspect and edit the selected thing\n- menus, theme, and account controls act at a broader app level\n- I can usually tell which surface to open based on the kind of question I am asking",
        "status": "verify",
        "_classBinding": {
          "key": "tutorial-checkpoint",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-checkpoint.node-class.node",
