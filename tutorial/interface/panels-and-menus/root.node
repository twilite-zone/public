    {
      "id": "panels-menus-discovery-note",
      "type": "tutorial-concept",
      "label": "Legend And Elements",
      "root": false,
      "position": {
        "x": -760,
        "y": -520
      },
      "width": 360,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Legend And Elements Are Discovery Surfaces",
        "body": "Use the legend and elements surfaces when you are asking what kinds of things exist and how to create or select them. They help you discover the available vocabulary of the graph.",
        "tag": "Concept",
        "_classBinding": {
          "key": "tutorial-concept",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node",
          "ref": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
        },
        "_bridge": {
          "classKey": "tutorial-concept",
          "classRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
        },
        "definitionKey": "tutorial-concept",
        "identity": {
          "graphId": "tutorial-interface-panels-and-menus"
        }
      }
    },
    {
      "id": "panels-menus-properties-note",
      "type": "tutorial-concept",
      "label": "Properties Panel",
      "root": false,
      "position": {
        "x": -300,
        "y": -520
      },
      "width": 360,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Properties Are For Inspection And Change",
        "body": "The properties panel is where you inspect and edit the currently selected thing. Once you know what node or edge you care about, this is where detailed authorship usually happens.",
        "tag": "Concept",
        "_classBinding": {
          "key": "tutorial-concept",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node",
          "ref": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
        },
        "_bridge": {
          "classKey": "tutorial-concept",
          "classRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
        },
        "definitionKey": "tutorial-concept",
        "identity": {
          "graphId": "tutorial-interface-panels-and-menus"
        }
      }
    },
    {
      "id": "panels-menus-global-note",
      "type": "tutorial-concept",
      "label": "Menus, Theme, Account",
      "root": false,
      "position": {
        "x": 160,
        "y": -520
      },
      "width": 360,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Menus, Theme, And Account Are Global Controls",
        "body": "Menus and account or theme controls answer broader app questions, not graph-local structure questions. They change context, preferences, or integration rather than editing the selected node directly.",
        "tag": "Concept",
        "_classBinding": {
          "key": "tutorial-concept",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node",
          "ref": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
        },
        "_bridge": {
          "classKey": "tutorial-concept",
          "classRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
        },
        "definitionKey": "tutorial-concept",
        "identity": {
          "graphId": "tutorial-interface-panels-and-menus"
        }
      }
    },
    {
      "id": "panels-menus-example",
      "type": "tutorial-example",
      "label": "Examples",
      "root": false,
      "position": {
        "x": 640,
        "y": -520
      },
      "width": 400,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Examples",
        "body": "Use the checklist below as a decision aid: if you know what you need to do, it should tell you which control surface is probably the right one first.",
        "cta": "Inspect the checklist",
        "_classBinding": {
          "key": "tutorial-example",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-example.node-class.node",
          "ref": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-example.node-class.node"
        },
        "_bridge": {
          "classKey": "tutorial-example",
          "classRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-example.node-class.node"
        },
        "definitionKey": "tutorial-example",
        "identity": {
          "graphId": "tutorial-interface-panels-and-menus"
        }
      }
    },
    {
      "id": "panels-menus-sample-note",
      "type": "markdown",
      "label": "Control Surface Checklist",
      "root": false,
      "position": {
        "x": 640,
        "y": -120
      },
      "width": 430,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "identity": {
          "graphId": "tutorial-interface-panels-and-menus"
        },
        "markdown": "## Which surface should I open?\n\n- Need to discover available things? Try legend or elements.\n- Need to inspect or edit the selected node or edge? Open properties.\n- Need app-wide controls, preferences, or account actions? Use menus or account surfaces.\n- Need the graph itself, not a panel? Return to the graph surface.\n\nThe goal is not to memorize every button. The goal is to know which layer answers which kind of question."
      }
    },
    {
      "id": "panels-menus-challenge",
      "type": "tutorial-challenge",
      "label": "Challenge",
      "root": false,
      "position": {
        "x": 1140,
        "y": -120
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Challenge",
        "body": "1. Pick a simple authoring task.\n2. Say which panel or menu you would open first and why.\n3. Change your selection and explain whether the answer changes.\n4. Distinguish a graph-local edit from a global app control.\n5. Return to the graph surface if you are using a panel for the wrong question.",
        "difficulty": "starter",
        "_classBinding": {
          "key": "tutorial-challenge",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-challenge.node-class.node",
          "ref": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-challenge.node-class.node"
        },
        "_bridge": {
          "classKey": "tutorial-challenge",
          "classRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-challenge.node-class.node"
        },
        "definitionKey": "tutorial-challenge",
        "identity": {
          "graphId": "tutorial-interface-panels-and-menus"
        }
      }
    },
    {
