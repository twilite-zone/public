    {
      "id": "graph-surface-reader",
      "type": "port",
      "label": "Graph Surface Reader",
      "root": false,
      "position": {
        "x": -520,
        "y": -1440
      },
      "width": 320,
      "height": 210,
      "visible": true,
      "showLabel": true,
      "data": {
        "identity": {
          "graphId": "tutorial-interface-graph-surface"
        },
        "view": {
          "intent": "node",
          "payload": "node.web.detail"
        },
        "renderShape": {
          "kind": "markdown"
        },
        "markdown": "# The Graph Surface\n---\n\nThis lesson teaches how to read the graph as space: nodes, edges, zoom, pan, minimap, and semantic zoom all work together to make large graphs navigable."
      }
    },
    {
      "id": "graph-surface-intro",
