      },
      "width": 620,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "The Graph Surface",
        "subtitle": "Learn how nodes, edges, zoom, pan, minimap, and semantic zoom behave so the canvas feels like a readable space instead of a pile of shapes.",
        "_classBinding": {
          "key": "tutorial-title",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-title.node-class.node",
          "ref": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-title.node-class.node"
        },
        "_bridge": {
          "classKey": "tutorial-title",
