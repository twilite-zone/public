      }
    },
    {
      "id": "save-refresh-checkpoint",
      "type": "tutorial-checkpoint",
      "label": "Checkpoint",
      "root": false,
      "position": {
        "x": 3870,
        "y": -1670
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Checkpoint",
        "body": "You are done when you can say:\n- I know what save target I am editing\n- I know what refresh or reopen is expected to reload\n- I can distinguish transient UI state from persisted graph state\n- I have a recovery path when the graph seems wrong\n- trust comes from checking the source of truth, not guessing",
        "status": "verify",
        "_classBinding": {
          "key": "tutorial-checkpoint",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-checkpoint.node-class.node",
