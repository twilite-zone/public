        }
      }
    },
    {
      "id": "browser-bar-checkpoint",
      "type": "tutorial-checkpoint",
      "label": "Checkpoint",
      "root": false,
      "position": {
        "x": 1580,
        "y": -120
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Checkpoint",
        "body": "You are done when you can say:\n- the address field tells me what graph I am actually in\n- browser controls are trust and recovery tools\n- bookmarks and zoom help me stay oriented\n- `github://` tells me I am looking at a GitHub-backed artifact\n- GitHub hosting is related, but it is a separate lesson from basic browser-bar literacy",
        "status": "verify",
        "_classBinding": {
          "key": "tutorial-checkpoint",
