    {
      "id": "browser-bar-section-address",
      "type": "section",
      "label": "Address Field",
      "root": false,
      "position": {
        "x": 980,
        "y": 300
      },
      "width": 440,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Read the address before you act",
        "summary": "The large field in the browser bar tells you what graph you are in. A `github://...` address means the graph is being read from a GitHub-backed repository path. A local or temporary graph will read differently, so the address is your first clue about where edits, saves, and refreshes are really happening.",
        "level": "h2",
        "anchor": "address-field",
        "status": "draft",
        "definitionKey": "section",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        }
      }
    },
    {
      "id": "browser-bar-section-controls",
      "type": "section",
      "label": "Controls + Indicator",
      "root": false,
      "position": {
        "x": 980,
        "y": 620
      },
      "width": 440,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Use the controls to stay oriented",
        "summary": "Back, forward, home, and refresh are navigation and trust tools, not decoration. Bookmarks let you pin places you revisit often. The location / position / zoom indicator tells you where you are on the graph surface and how far in or out you are, which matters when a graph is larger than one screen. Clicking the indicator resets zoom to `1x`.",
        "level": "h2",
        "anchor": "controls-and-indicator",
        "status": "draft",
        "definitionKey": "section",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        }
      }
    },
    {
      "id": "browser-bar-section-hosting",
      "type": "section",
      "label": "GitHub + Hosting",
      "root": false,
      "position": {
        "x": 1600,
        "y": 620
      },
      "width": 440,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Treat hosting as the next layer",
        "summary": "The browser bar can tell you that a graph is GitHub-backed, but it does not by itself explain how that graph is hosted or published to outside users. That is a related topic. This chapter should point to the GitHub and hosting material so the reader can connect repository addresses with public delivery without mixing too many concepts into one page.",
        "level": "h2",
        "anchor": "github-and-hosting",
        "status": "draft",
        "definitionKey": "section",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        }
      }
    },
