        "payload": "node.web.summary",
        "title": "Declaration Walkthrough",
        "purpose": "The declaration node is the graph's contract surface:\n- identity\n- dependencies\n- mutation/authority policy\n- export surfaces\n\nThis walkthrough validates that editing the declaration is stable and predictable (no phantom fields, no silent drops).",
        "status": "active",
        "viewRole": "summary",
        "viewKind": "display",
        "exposedAuthority": "consume-view",
