        "key": "node.web.detail",
        "intent": "node",
        "payload": "node.web.detail",
        "html": "<div style=\"width:100%;height:100%;display:flex;flex-direction:column;gap:14px;padding:18px;border-radius:20px;box-sizing:border-box;background:linear-gradient(180deg, rgba(255,241,242,0.98), rgba(255,228,230,0.96));border:1px solid rgba(190,24,93,0.14);overflow:hidden;\"><div style=\"display:flex;justify-content:space-between;gap:12px;align-items:center;\"><div style=\"font:800 24px/1.15 ui-sans-serif, system-ui, sans-serif;color:#0f172a;\">{{data.title}}</div><div style=\"padding:4px 8px;border-radius:999px;background:rgba(190,24,93,0.12);color:#9f1239;font:700 11px/1 ui-sans-serif, system-ui, sans-serif;\">Challenge</div></div><div style=\"font:500 14px/1.55 ui-sans-serif, system-ui, sans-serif;color:#334155;white-space:pre-wrap;overflow:auto;\">{{data.body}}</div></div>",
        "semanticLevel": "detail"
      }
    },
