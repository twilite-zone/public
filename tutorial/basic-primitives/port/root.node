      "data": {
        "title": "Model A Port",
        "body": "Create one graph entry `port` in a scratch graph.\n\nRequired:\n- `data.identity.graphId`\n- a real `data.target`\n- one real preview payload such as markdown, svg, or html\n- a clear difference between `data.viewRole` and `data.renderShape.kind`\n\nDo not use metadata-only card fields as if they render the body.",
        "difficulty": "starter",
        "_classBinding": {
