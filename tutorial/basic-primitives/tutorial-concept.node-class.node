        "html": "<div style=\"width:100%;height:100%;display:flex;flex-direction:column;justify-content:center;gap:8px;padding:16px;box-sizing:border-box;border-radius:16px;background:white;border:1px solid rgba(2,132,199,0.14);\"><div style=\"font:800 20px/1.2 ui-sans-serif, system-ui, sans-serif;color:#0f172a;\">{{data.title}}</div><div style=\"font:500 13px/1.45 ui-sans-serif, system-ui, sans-serif;color:#475569;\">{{data.body}}</div></div>",
        "semanticLevel": "summary"
      }
    },
