        "key": "node.web.detail",
        "intent": "node",
        "payload": "node.web.detail",
        "html": "<div style=\"width:100%;height:100%;display:flex;flex-direction:column;gap:14px;padding:18px;border-radius:20px;box-sizing:border-box;background:linear-gradient(180deg, rgba(239,246,255,0.98), rgba(224,242,254,0.96));border:1px solid rgba(2,132,199,0.14);overflow:hidden;\"><div style=\"display:flex;justify-content:space-between;gap:12px;align-items:center;\"><div style=\"font:800 24px/1.15 ui-sans-serif, system-ui, sans-serif;color:#0f172a;\">{{data.title}}</div><div style=\"padding:4px 8px;border-radius:999px;background:rgba(2,132,199,0.12);color:#075985;font:700 11px/1 ui-sans-serif, system-ui, sans-serif;\">{{data.tag}}</div></div><div style=\"height:4px;border-radius:999px;background:linear-gradient(90deg, #38bdf8, #0ea5e9);\"></div><div style=\"font:500 14px/1.55 ui-sans-serif, system-ui, sans-serif;color:#334155;white-space:pre-wrap;overflow:auto;\">{{data.body}}</div></div>",
        "semanticLevel": "detail"
      }
    },
