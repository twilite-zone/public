        "key": "node.web.detail",
        "intent": "node",
        "payload": "node.web.detail",
        "html": "<div style=\"width:100%;height:100%;display:flex;flex-direction:column;gap:14px;padding:18px;border-radius:20px;box-sizing:border-box;background:linear-gradient(180deg, rgba(240,253,244,0.98), rgba(220,252,231,0.96));border:1px solid rgba(22,163,74,0.14);overflow:hidden;\"><div style=\"display:flex;justify-content:space-between;gap:12px;align-items:center;\"><div style=\"font:800 24px/1.15 ui-sans-serif, system-ui, sans-serif;color:#0f172a;\">{{data.title}}</div><div style=\"padding:4px 8px;border-radius:999px;background:rgba(22,163,74,0.12);color:#166534;font:700 11px/1 ui-sans-serif, system-ui, sans-serif;\">Example</div></div><div style=\"font:500 14px/1.55 ui-sans-serif, system-ui, sans-serif;color:#334155;white-space:pre-wrap;overflow:auto;\">{{data.body}}</div><div style=\"margin-top:auto;display:inline-flex;align-self:flex-start;padding:8px 12px;border-radius:999px;background:#166534;color:white;font:700 12px/1 ui-sans-serif, system-ui, sans-serif;\">{{data.cta}}</div></div>",
