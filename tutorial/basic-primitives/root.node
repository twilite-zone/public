      "data": {
        "identity": {
          "graphId": "tutorial-basic-primitives"
        },
        "markdown": "## Port\n\nUse `port` for presentation.\n\nA port should describe:\n- how something renders\n- what payload it uses\n- what default handles a created node starts with\n\nA port does not decide graph identity.\nTo expose it to portals or consumers, add it to `declaration.surfaces` and bind the surface to the port node id.",
        "_placement": {
          "version": 1,
          "state": "manually-shaped",
          "source": "manual",
          "updatedAt": 1780528195444,
          "reason": "node-drag"
        }
      }
    },
