      "data": {
        "identity": {
          "graphId": "tutorial-basic-primitives"
        },
        "markdown": "## Markdown\n\nUse `markdown` for prose.\n\nIt is the simplest human-readable primitive.\nUse it for:\n- explanations\n- instructions\n- notes\n- tutorial steps\n\nIt should not carry graph identity.",
        "_placement": {
          "version": 1,
          "state": "manually-shaped",
          "source": "manual",
          "updatedAt": 1780528175636,
          "reason": "node-drag"
        }
      }
    },
