      "data": {
        "identity": {
          "graphId": "tutorial-basic-primitives"
        },
        "markdown": "## Portal\n\nUse `portal` for addressed behavior.\n\nA portal can:\n- navigate\n- consume a declared port surface\n- expand a branch\n\nFor now, `Behavior` remains explicit because the contract is not yet strict enough to infer everything from surface selection alone.",
        "_placement": {
          "version": 1,
          "state": "manually-shaped",
          "source": "manual",
          "updatedAt": 1780528214267,
          "reason": "node-drag"
        }
      }
    },
