      "data": {
        "identity": {
          "graphId": "tutorial-basic-primitives"
        },
        "markdown": "# Basic Primitives\n\nThis graph is the first clean tutorial hub for Twilite's basic primitives.\n\nBasic primitives here:\n- `declaration`\n- `markdown`\n- `port`\n- `portal`\n\nUse this graph to understand what each primitive owns, when to use it, and how it fits the declaration-first model.",
        "_placement": {
          "version": 1,
          "state": "manually-shaped",
          "source": "manual",
          "updatedAt": 1780590537462,
          "reason": "node-drag"
        }
      }
    },
