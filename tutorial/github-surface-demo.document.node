      "data": {
        "payload": "node.web.summary",
        "title": "GitHub Surface Demo",
        "purpose": "This graph exists so you can validate the GitHub round-trip:\n\n- Configure Document Properties → GitHub\n- Commit this graph to a repo path\n- Reload it via github://owner/repo/path\n\nThe only goal is to prove the integration is stable and repeatable.",
        "status": "active",
        "viewRole": "summary",
        "viewKind": "display",
        "exposedAuthority": "consume-view",
        "svg": "<svg viewBox=\"0 0 220 160\" xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\"><rect x=\"18\" y=\"18\" width=\"184\" height=\"124\" rx=\"18\" fill=\"#0b1220\" stroke=\"#1f2937\" stroke-width=\"5\"/><path d=\"M110 42c-14 0-26 12-26 26 0 11 7 20 17 24 1 0 2-1 2-2v-5c-7 2-9-3-9-3-1-3-3-4-3-4-2-1 0-1 0-1 2 0 4 3 4 3 2 4 6 3 8 2 0-2 1-3 2-4-6-1-12-3-12-13 0-3 1-6 3-8 0-1-1-3 0-6 0 0 2-1 7 3 2-1 5-1 7-1s5 0 7 1c5-4 7-3 7-3 1 3 0 5 0 6 2 2 3 5 3 8 0 10-6 12-12 13 1 1 2 3 2 5v8c0 1 1 2 2 2 10-4 17-13 17-24 0-14-12-26-26-26z\" fill=\"#e5e7eb\"/></svg>",
        "_classBinding": { "key": "ui-view", "sourceRef": "/library/classes/nodes/ui-interaction/ui-view.node-class.node", "ref": "/library/classes/nodes/ui-interaction/ui-view.node-class.node" },
