      "data": {
        "title": "Script",
        "body": "Use `script` for graph-visible executable behavior.\\n\\nA script remains owned by a node. The editor may be fancy, but the capability should still exist as a visible part of the graph.",
        "tag": "Concept",
        "_classBinding": {
