      },
      "width": 320,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Field",
        "body": "Use `field` for authored functional data.\\n\\nA field owns a `key`, a `fieldType`, a `value`, and the metadata needed to describe that data without smearing it into declaration or presentation.",
        "tag": "Concept",
        "_classBinding": {
