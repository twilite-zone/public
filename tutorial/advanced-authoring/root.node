          "payload": "node.web.detail"
        },
        "renderShape": {
          "kind": "markdown"
        },
        "markdown": "# Advanced Authoring\n---\n\nThis hub is about making reusable authoring artifacts, not just using advanced nodes. Think in terms of classes, templates, and formalized relationships."
      }
    },
