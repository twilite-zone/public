    {
      "id": "advanced-authoring-node-classes",
      "type": "tutorial-concept",
      "label": "Node Classes",
      "root": false,
      "position": {
        "x": -840,
        "y": -760
      },
      "width": 360,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Node Classes",
        "body": "A node class makes a kind of node reusable. It carries starter structure, meaning, and often the surfaces that make the node legible when it appears again in another graph.",
        "_classBinding": {
          "key": "tutorial-concept",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node",
          "ref": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
        },
        "_bridge": {
          "classKey": "tutorial-concept",
          "classRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
        },
        "definitionKey": "tutorial-concept",
        "identity": {
          "graphId": "tutorial-advanced-authoring"
        }
      }
    },
    {
      "id": "advanced-authoring-edge-classes",
      "type": "tutorial-concept",
      "label": "Edge Classes",
      "root": false,
      "position": {
        "x": -390,
        "y": -760
      },
      "width": 360,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Edge Classes",
        "body": "An edge class makes a relationship reusable. It lets you formalize what a link means so relationship semantics can be authored as deliberately as node structure.",
        "_classBinding": {
          "key": "tutorial-concept",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node",
          "ref": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
        },
        "_bridge": {
          "classKey": "tutorial-concept",
          "classRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
        },
        "definitionKey": "tutorial-concept",
        "identity": {
          "graphId": "tutorial-advanced-authoring"
        }
      }
    },
    {
      "id": "advanced-authoring-templates",
      "type": "tutorial-concept",
      "label": "Templates",
      "root": false,
      "position": {
        "x": 60,
        "y": -760
      },
      "width": 360,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Templates",
        "body": "A template packages repeatable graph structure. It is for the moment when the lesson, workflow, or artifact shape should be instantiated again instead of rebuilt from scratch.",
        "_classBinding": {
          "key": "tutorial-concept",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node",
          "ref": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
        },
        "_bridge": {
          "classKey": "tutorial-concept",
          "classRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
        },
        "definitionKey": "tutorial-concept",
        "identity": {
          "graphId": "tutorial-advanced-authoring"
        }
      }
    },
    {
      "id": "advanced-authoring-distribution",
      "type": "tutorial-concept",
      "label": "Distribution",
      "root": false,
      "position": {
        "x": 510,
        "y": -760
      },
      "width": 360,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Distribution And Authority",
        "body": "Reusable authoring artifacts still need a delivery story. Bridges, catalogs, and explicit authority boundaries matter here because reusable structure has to move between graphs without becoming mysterious.",
        "_classBinding": {
          "key": "tutorial-concept",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node",
          "ref": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
        },
        "_bridge": {
          "classKey": "tutorial-concept",
          "classRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-concept.node-class.node"
        },
        "definitionKey": "tutorial-concept",
        "identity": {
          "graphId": "tutorial-advanced-authoring"
        }
      }
    },
    {
      "id": "advanced-authoring-example",
      "type": "tutorial-example",
      "label": "Choosing The Artifact",
      "root": false,
      "position": {
        "x": -280,
        "y": -300
      },
      "width": 700,
      "height": 280,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Choosing The Artifact",
        "body": "Use this rule of thumb:\n\n- if you need a reusable kind of node, make a node class\n- if you need a reusable kind of relationship, make an edge class\n- if you need a reusable graph arrangement, make a template\n\nBridges help distribute those things. They are support machinery, not the headline artifact.",
        "_classBinding": {
          "key": "tutorial-example",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-example.node-class.node",
          "ref": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-example.node-class.node"
        },
        "_bridge": {
          "classKey": "tutorial-example",
          "classRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-example.node-class.node"
        },
        "definitionKey": "tutorial-example",
        "identity": {
          "graphId": "tutorial-advanced-authoring"
        }
      }
    },
    {
      "id": "advanced-authoring-challenge",
      "type": "tutorial-challenge",
      "label": "Challenge",
      "root": false,
      "position": {
        "x": 500,
        "y": -300
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Challenge",
        "body": "Pick one thing you want to reuse in Twilite.\n\nName whether it is best expressed as a node class, an edge class, or a template, and explain why the other two are worse fits.",
        "_classBinding": {
          "key": "tutorial-challenge",
          "sourceRef": "github://twilite-zone/public/tutorial/basic-primitives/tutorial-challenge.node-class.node",
