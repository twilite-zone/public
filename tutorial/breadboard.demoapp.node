    {
      "id": "board-surface",
      "type": "svg",
      "label": "Breadboard Surface",
      "position": {
        "x": -220,
        "y": -160
      },
      "width": 880,
      "height": 360,
      "state": {
        "locked": true
      },
      "visible": true,
      "showLabel": true,
      "data": {
        "svg": "<svg viewBox=\"0 0 880 360\" xmlns=\"http://www.w3.org/2000/svg\">\n  <defs>\n    <pattern id=\"holes\" width=\"40\" height=\"40\" patternUnits=\"userSpaceOnUse\">\n      <circle cx=\"20\" cy=\"20\" r=\"4\" fill=\"#19c0b1\"/>\n    </pattern>\n  </defs>\n  <rect width=\"880\" height=\"360\" rx=\"20\" fill=\"#0d2f3c\"/>\n  <rect x=\"30\" y=\"20\" width=\"820\" height=\"320\" rx=\"12\" fill=\"#0e5868\"/>\n  <rect x=\"40\" y=\"84\" width=\"800\" height=\"200\" fill=\"url(#holes)\" opacity=\"0.35\"/>\n  <rect x=\"40\" y=\"40\" width=\"800\" height=\"24\" fill=\"#1da3ba\"/>\n  <rect x=\"40\" y=\"296\" width=\"800\" height=\"24\" fill=\"#1da3ba\"/>\n  <g stroke=\"#0b1b24\" stroke-width=\"2\">\n    <line x1=\"40\" y1=\"84\" x2=\"840\" y2=\"84\"/>\n    <line x1=\"40\" y1=\"120\" x2=\"840\" y2=\"120\"/>\n    <line x1=\"40\" y1=\"156\" x2=\"840\" y2=\"156\"/>\n    <line x1=\"40\" y1=\"192\" x2=\"840\" y2=\"192\"/>\n    <line x1=\"40\" y1=\"228\" x2=\"840\" y2=\"228\"/>\n    <line x1=\"40\" y1=\"264\" x2=\"840\" y2=\"264\"/>\n    <line x1=\"40\" y1=\"300\" x2=\"840\" y2=\"300\"/>\n  </g>\n  <g stroke=\"#0b1b24\" stroke-width=\"2\">\n    <line x1=\"120\" y1=\"24\" x2=\"120\" y2=\"336\"/>\n    <line x1=\"200\" y1=\"24\" x2=\"200\" y2=\"336\"/>\n    <line x1=\"280\" y1=\"24\" x2=\"280\" y2=\"336\"/>\n    <line x1=\"360\" y1=\"24\" x2=\"360\" y2=\"336\"/>\n    <line x1=\"440\" y1=\"24\" x2=\"440\" y2=\"336\"/>\n    <line x1=\"520\" y1=\"24\" x2=\"520\" y2=\"336\"/>\n    <line x1=\"600\" y1=\"24\" x2=\"600\" y2=\"336\"/>\n    <line x1=\"680\" y1=\"24\" x2=\"680\" y2=\"336\"/>\n    <line x1=\"760\" y1=\"24\" x2=\"760\" y2=\"336\"/>\n  </g>\n  <text x=\"60\" y=\"58\" fill=\"#ffffff\" font-size=\"24\" font-family=\"monospace\">Twilite SVG Breadboard</text>\n  <text x=\"720\" y=\"50\" fill=\"#ffffff\" font-size=\"16\" font-family=\"monospace\">+5V Rail</text>\n  <text x=\"720\" y=\"334\" fill=\"#ffffff\" font-size=\"16\" font-family=\"monospace\">GND Rail</text>\n</svg>",
        "breadboard": {
          "rows": [
            "A",
            "B",
            "C",
            "D",
            "E",
            "F"
          ],
          "columns": 12,
          "rowPitch": 40,
          "columnPitch": 80
        },
        "memo": "SVG backdrop that defines the grid the demo components understand."
      }
