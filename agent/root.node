      "data": {
        "title": "Twilite Orientation Contract",
        "allowedActions": "Read declarations, surfaces, tutorial graphs, contract graphs, task graphs, and runtime codepaths. Follow bridges, inspect class bindings, compare authored graph content with rendered behavior, and make scoped graph or code edits when the task clearly calls for them.",
        "safetyLimits": "Do not invent missing capability. Do not widen authority. Do not patch runtime code to excuse bad authored content. Do not treat mirrored repos as interchangeable sources of truth. Do not treat undocumented behavior as settled law.",
        "requiredOutputs": "A working bounded result, the observations that supported it, the doctrine or source graph used, the files or graphs changed, and a clear explanation of what changed and how it was verified.",
        "escalationRule": "Escalate when the work crosses runtime/content boundaries, touches auth, billing, publishing, destructive actions, or when doctrine is still unresolved.",
        "approvalRequirement": "Human confirmation before destructive or publishing actions.",
        "terminationCondition": "The agent can operate independently on one bounded Twilite task or is blocked on missing authority, unresolved doctrine, or a cross-boundary decision.",
