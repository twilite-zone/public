      "data": {
        "title": "Get Fully Operational In Twilite",
        "instructionBody": "Read Twilite as a graph system, not as a flattened page. Start from the public root, then use the linked tutorial, bootstrap, primitives, task, GitHub, and contract graphs until you can explain declaration truth, exposed surfaces, portals, bridges, class bindings, and bounded changes in your own words. Prefer the live-served public graph set when debugging content. When behavior is wrong, decide whether the bug lives in authored graph content or runtime code before editing. When asked to change something, keep the change bounded, attributable, and verified.",
        "scope": "full Twilite orientation and bounded execution readiness",
        "inputs": [
          "public root",
          "tutorial root",
          "bootstrap tutorial",
          "basic primitives tutorial",
          "tasks root",
          "GitHub root",
          "port contract",
          "bridge contract",
          "edge contract",
          "current graph",
          "runtime codepaths"
        ],
        "version": "v1",
        "provenance": "agent root",
        "expectedOutput": "A highly functional Twilite operator who knows where doctrine lives, how authored graphs map to rendered behavior, and how to carry one bounded change through with verification.",
        "status": "ready",
        "definitionKey": "prompt",
