      "data": {
        "title": "Get up to speed on Twilite",
        "body": "Become highly functional in Twilite. Learn the declaration -> surface -> portal model, bridge authority, class-backed authoring, task flow, and the difference between graph-content problems and runtime problems well enough to make bounded, attributable changes without treating the graph as a black box.",
        "priority": "high",
        "status": "todo",
        "owner": "Agent",
        "acceptanceCriteria": [
          "Can explain declaration, exposed surface, port, portal, and consumer in Twilite terms",
          "Knows where the tutorial root, bootstrap tutorial, primitives shelf, tasks root, GitHub root, and core contracts live",
          "Can distinguish graph-content mistakes from runtime or app-code mistakes",
          "Can follow a bridge and explain what authority it grants",
          "Can make one bounded change in the live-served graph set and explain how it was verified"
        ],
        "definitionKey": "task",
