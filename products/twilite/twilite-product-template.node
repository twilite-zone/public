    },
    {
      "id": "twilite-product-template-proof-live",
      "type": "twilite-product-proof",
      "label": "What Already Works Today",
      "position": {
        "x": 60,
        "y": 980
      },
      "width": 540,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "eyebrow": "Proof",
        "title": "What Already Works Today",
        "claims": "- Twilite runs in the browser.\n- Graphs have durable addresses.\n- Tutorials, classes, and product content already ship as graphs.\n- Humans and AI can work against the same artifact.",
        "footnote": "Use these cards to state concrete present-tense truths.",
        "status": "Working Today",
        "_classBinding": {
          "key": "twilite-product-proof",
          "ref": "https://twilite.zone/products/twilite/twilite-product-proof.node-class.node"
        },
        "_bridge": {
