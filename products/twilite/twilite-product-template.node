    },
    {
      "id": "twilite-product-template-proof-persistence",
      "type": "twilite-product-proof",
      "label": "Why Persistence Matters",
      "position": {
        "x": 760,
        "y": 980
      },
      "width": 540,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "eyebrow": "Why It Matters",
        "title": "Why Persistence Matters",
        "claims": "- Context survives beyond a session.\n- Meaning stays attached to structure.\n- Future work can begin from the artifact instead of from memory.\n- AI can collaborate without re-deriving the whole world every time.",
        "footnote": "Persistence is the reason the graph matters more than a temporary conversation.",
        "status": "Core Thesis",
        "_classBinding": {
          "key": "twilite-product-proof",
          "ref": "https://twilite.zone/products/twilite/twilite-product-proof.node-class.node"
        },
        "_bridge": {
