      "type": "twilite-product-hero",
      "label": "Hero",
      "position": {
        "x": 370,
        "y": 120
      },
      "width": 640,
      "height": 340,
      "visible": true,
      "showLabel": true,
      "data": {
        "eyebrow": "Flagship Product",
        "title": "Twilite",
        "body": "Twilite turns thought into durable graph structure. Instead of losing context across chats, notes, and tabs, the work becomes a living artifact that can be opened, linked, revised, and extended over time.",
