    {
      "id": "twilite-product-template-what",
      "type": "twilite-product-section",
      "label": "What Twilite Is",
      "position": {
        "x": -230,
        "y": 560
      },
      "width": 520,
      "height": 300,
      "visible": true,
      "showLabel": true,
      "data": {
        "tag": "What",
        "title": "What Twilite Is",
        "body": "Twilite is a graph-native workspace. The graph is not a sidecar representation of the work. The graph is the work: navigable, addressable, editable, and publishable for both humans and AI.",
        "_classBinding": {
          "key": "twilite-product-section",
          "ref": "https://twilite.zone/products/twilite/twilite-product-section.node-class.node"
        },
