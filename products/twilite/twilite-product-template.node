          "targetKind": "node-class",
          "classKey": "twilite-product-section",
          "classRef": "https://twilite.zone/products/twilite/twilite-product-section.node-class.node"
        },
        "definitionKey": "twilite-product-section"
      }
    },
    {
      "id": "twilite-product-template-how",
      "type": "twilite-product-section",
      "label": "How It Works",
      "position": {
        "x": 950,
        "y": 560
      },
      "width": 520,
      "height": 300,
      "visible": true,
      "showLabel": true,
      "data": {
        "tag": "How",
        "title": "How It Works",
        "body": "Author or evolve a graph. Give it a durable address. Expose the surfaces that matter. Let humans and AI return to the same structure later and keep growing it instead of restarting from fragments.",
        "_classBinding": {
          "key": "twilite-product-section",
          "ref": "https://twilite.zone/products/twilite/twilite-product-section.node-class.node"
        },
        "_bridge": {
          "sourceBridgeNodeId": "twilite-product-template-bridge-section",
          "sourceBridgeLabel": "Section Card",
          "targetKind": "node-class",
          "classKey": "twilite-product-section",
          "classRef": "https://twilite.zone/products/twilite/twilite-product-section.node-class.node"
