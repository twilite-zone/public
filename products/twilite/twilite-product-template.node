    {
      "id": "twilite-product-template-why",
      "type": "twilite-product-section",
      "label": "Why Twilite Exists",
      "position": {
        "x": 360,
        "y": 560
      },
      "width": 520,
      "height": 300,
      "visible": true,
      "showLabel": true,
      "data": {
        "tag": "Why",
        "title": "Why Twilite Exists",
        "body": "Most tools split meaning across disconnected surfaces. Twilite keeps structure, navigation, and revision inside one durable artifact so understanding does not evaporate when the conversation ends.",
        "_classBinding": {
          "key": "twilite-product-section",
          "ref": "https://twilite.zone/products/twilite/twilite-product-section.node-class.node"
        },
        "_bridge": {
          "sourceBridgeNodeId": "twilite-product-template-bridge-section",
