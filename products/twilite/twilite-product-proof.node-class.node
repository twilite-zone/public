        },
        "html": "<div style=\"width:100%;height:100%;display:flex;flex-direction:column;gap:14px;padding:20px;border-radius:24px;box-sizing:border-box;background:linear-gradient(180deg, rgba(250,250,250,0.99), rgba(241,245,249,0.96));border:1px solid rgba(15,23,42,0.12);box-shadow:0 16px 34px rgba(15,23,42,0.08);font-family:ui-sans-serif,system-ui,sans-serif;overflow:hidden;\"><div style=\"display:flex;justify-content:space-between;gap:12px;align-items:center;\"><div style=\"font:700 10px/1 ui-sans-serif,system-ui,sans-serif;letter-spacing:0.16em;text-transform:uppercase;color:#475569;\">{{data.eyebrow}}</div><div style=\"padding:5px 10px;border-radius:999px;background:rgba(15,23,42,0.06);color:#0f172a;font:700 10px/1 ui-sans-serif,system-ui,sans-serif;\">{{data.status}}</div></div><div style=\"font:800 24px/1.1 ui-sans-serif,system-ui,sans-serif;color:#111827;\">{{data.title}}</div><div style=\"display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;\"><div style=\"height:8px;border-radius:999px;background:#2563eb;\"></div><div style=\"height:8px;border-radius:999px;background:#1d4ed8;\"></div><div style=\"height:8px;border-radius:999px;background:#f59e0b;\"></div></div><div style=\"font:600 14px/1.65 ui-sans-serif,system-ui,sans-serif;color:#334155;white-space:pre-wrap;overflow:auto;\">{{data.claims}}</div><div style=\"padding-top:10px;border-top:1px solid rgba(15,23,42,0.10);font:500 12px/1.55 ui-sans-serif,system-ui,sans-serif;color:#64748b;white-space:pre-wrap;\">{{data.footnote}}</div></div>"
