            "version": ">=0.1.0",
            "defaults": {
              "label": "Proof",
              "size": {
                "width": 540,
                "height": 320
              },
              "showLabel": false,
              "data": {
                "eyebrow": "Proof",
                "title": "What Already Works Today",
                "claims": "- Browser-native graph editing\n- Durable graph addresses\n- Human and AI collaboration against the same artifact",
                "footnote": "Use concrete claims, not future aspirations.",
                "status": "Working Today"
              },
              "ports": [
                {
                  "id": "root",
                  "label": "root",
                  "direction": "bidirectional",
                  "dataType": "any",
                  "angle": 210
                }
