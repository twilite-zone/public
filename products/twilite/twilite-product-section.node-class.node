        "view": {
          "intent": "node",
          "payload": "node.web.detail"
        },
        "html": "<div style=\"width:100%;height:100%;display:flex;flex-direction:column;gap:14px;padding:20px;border-radius:24px;box-sizing:border-box;background:linear-gradient(180deg, rgba(255,255,255,0.99), rgba(248,250,252,0.95));border:1px solid rgba(15,23,42,0.10);box-shadow:0 14px 32px rgba(15,23,42,0.08);overflow:hidden;font-family:ui-sans-serif,system-ui,sans-serif;\"><div style=\"display:flex;justify-content:space-between;gap:12px;align-items:center;\"><div style=\"font:700 10px/1 ui-sans-serif,system-ui,sans-serif;letter-spacing:0.16em;text-transform:uppercase;color:#2563eb;\">{{data.tag}}</div><div style=\"width:36px;height:6px;border-radius:999px;background:#f59e0b;\"></div></div><div style=\"font:800 24px/1.12 ui-sans-serif,system-ui,sans-serif;color:#111827;\">{{data.title}}</div><div style=\"height:4px;border-radius:999px;background:linear-gradient(90deg, rgba(37,99,235,0.92), rgba(37,99,235,0.10));\"></div><div style=\"font:500 15px/1.7 ui-sans-serif,system-ui,sans-serif;color:#334155;white-space:pre-wrap;overflow:auto;\">{{data.body}}</div></div>"
      }
