    {
      "id": "bounded-interactive-markdown-question-scope",
      "type": "open-question",
      "label": "Should bounded interactive markdown live only in markdown/document surfaces, or anywhere a class-backed view can render text content?",
      "position": {
        "x": 3120,
        "y": -40
      },
      "width": 440,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "The safer first answer may be document-like surfaces only, but the broader architectural question is whether the same bounded interactive markdown contract should eventually be available to any class-backed text or document view.",
        "status": "open",
        "owner": "Michael",
        "prominence": "high",
        "_classBinding": {
          "key": "open-question",
          "sourceRef": "/library/classes/nodes/task-planning/open-question.node-class.node",
