    },
    {
      "id": "bounded-interactive-markdown-task-use-cases",
      "type": "task",
      "label": "Identify the first few sanctioned interactive markdown use cases",
      "position": {
        "x": 2580,
        "y": -40
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Name the narrow set of inline controls that are worth supporting first, such as theme previews, run buttons, simple field editors, or compact status widgets. The point is to keep the first rollout bounded.",
        "priority": "high",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "3",
        "acceptanceCriteria": [
          "The first approved block kinds are named explicitly",
          "Each use case has a product reason to exist",
          "The initial rollout scope stays intentionally small"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "/library/classes/nodes/task-planning/task.node-class.node"
