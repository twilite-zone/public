    {
      "id": "bounded-interactive-markdown-overview",
      "type": "section",
      "label": "Bounded Interactive Markdown",
      "position": {
        "x": 1480,
        "y": -900
      },
      "width": 520,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Bounded Interactive Markdown",
        "summary": "Evaluate a safer middle path between plain markdown and a broad hosted-editor rollout. The idea is to keep authored documents mostly markdown while allowing a small sanctioned block vocabulary that can render approved interactive controls inline.",
        "level": "h2",
        "anchor": "bounded-interactive-markdown",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "root-bridge-section",
          "sourceBridgeNodeId": "root-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "bounded-interactive-markdown-proposal",
      "type": "section",
      "label": "Proposed Model",
      "position": {
        "x": 2040,
        "y": -900
      },
      "width": 520,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Proposed Model",
        "summary": "Markdown stays document-first, but gains a bounded directive vocabulary like `:::control kind=\"theme-preview\" :::` or other sanctioned blocks. The host maps those known block kinds to approved React renderers and refuses arbitrary component execution.",
        "level": "h3",
        "anchor": "proposed-model",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "root-bridge-section",
          "sourceBridgeNodeId": "root-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "bounded-interactive-markdown-comparison",
      "type": "section",
      "label": "Comparison",
      "position": {
        "x": 2600,
        "y": -900
      },
      "width": 520,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Comparison",
        "summary": "This path may fit Twilite better than a large hosted-editor registry right now. It keeps documents authored, keeps the allowed interactive vocabulary explicit, and avoids arbitrary JSX while still allowing richer inline UI where it genuinely helps.",
        "level": "h3",
        "anchor": "comparison",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
