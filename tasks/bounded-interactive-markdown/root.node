        "definitionKey": "task"
      }
    },
    {
      "id": "bounded-interactive-markdown-task-renderer",
      "type": "task",
      "label": "Prototype markdown directive parsing and sanctioned control rendering",
      "position": {
        "x": 2050,
        "y": -40
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Test whether the existing markdown/rendering stack can support a constrained directive or shortcode model cleanly enough to render approved controls inline without dragging in full MDX-style arbitrary component semantics.",
        "priority": "high",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "6",
        "acceptanceCriteria": [
          "At least one constrained syntax shape is proven viable",
          "A control registry boundary is identified",
          "The prototype demonstrates a clean fallback path"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "/library/classes/nodes/task-planning/task.node-class.node"
