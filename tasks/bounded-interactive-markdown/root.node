          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "bounded-interactive-markdown-goal",
      "type": "goal",
      "label": "Decide whether bounded interactive markdown is the right next abstraction for richer authored UI",
      "position": {
        "x": 2040,
        "y": -420
      },
      "width": 460,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Choose whether Twilite should pursue bounded interactive markdown as a first-class authored surface for inline UI, instead of immediately generalizing a broad hosted-editor system. The target is not arbitrary React in documents, but a constrained directive vocabulary with approved controls.",
        "status": "open",
        "priority": "critical",
        "owner": "Michael",
        "definitionKey": "goal",
        "_classBinding": {
          "key": "goal",
          "sourceRef": "/library/classes/nodes/task-planning/goal.node-class.node",
          "ref": "/library/classes/nodes/task-planning/goal.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "root-bridge-goal",
          "sourceBridgeNodeId": "root-bridge-goal",
          "sourceBridgeLabel": "Goal",
          "sourceRef": "/library/classes/nodes/task-planning/goal.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "goal",
          "classRef": "/library/classes/nodes/task-planning/goal.node-class.node"
        }
      }
    },
    {
      "id": "bounded-interactive-markdown-task-contract",
      "type": "task",
      "label": "Define a bounded interactive markdown contract",
      "position": {
        "x": 1520,
        "y": -40
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Specify what directive syntax is allowed, what renderer inputs a sanctioned control receives, how fallback rendering behaves, and which security/authority boundaries are non-negotiable.",
        "priority": "critical",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "4",
        "acceptanceCriteria": [
          "Interactive markdown is declarative rather than arbitrary component execution",
          "Allowed block kinds and parameter rules are explicit",
          "Fallback behavior is defined for unknown or invalid blocks"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "/library/classes/nodes/task-planning/task.node-class.node"
        },
