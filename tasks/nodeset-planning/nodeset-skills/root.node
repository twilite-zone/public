            "offset": 0.5
          }
        }
      ],
      "data": {
        "markdown": "# Nodeset Skills\n\nUse skills as the enforcement layer for nodesets so graph generation can go slightly wrong in a bounded, repairable place instead of drifting across the whole repo.\n\nThe first skill surface should enforce contract shape, canonical-vs-archive placement, and graph repair workflows for planning graphs and future nodesets.",
        "memo": "",
        "link": "",
        "isRoot": true,
        "root": true,
        "_classBinding": {
