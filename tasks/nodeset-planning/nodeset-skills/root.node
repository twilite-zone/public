    {
      "id": "nodeset-skills-goal",
      "type": "goal",
      "label": "Make nodesets self-correcting through skills",
      "position": {
        "x": 360,
        "y": -120
      },
      "width": 360,
      "height": 270,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Nodesets should carry enough local skill logic that agents can generate, validate, and repair graphs without relying on global memory or repo-wide cleanup passes.",
        "priority": "critical",
        "status": "open",
        "owner": "Michael",
        "targetDate": "",
        "successMetrics": [
