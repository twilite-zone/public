    {
      "id": "agent-prompting-task-capabilities",
      "type": "task",
      "label": "Identify the substrate capabilities required by the v1 nodeset",
      "position": {
        "x": 610,
        "y": 1385
      },
      "width": 400,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Map Substrate Dependencies",
        "body": "Define the substrate dependency contract for the v1 agent / prompting nodeset: the platform capabilities each approved node type depends on, the minimum viable support required, and what remains blocked if that support is missing.",
        "status": "done",
        "owner": "Michael",
        "priority": "high",
        "estimateHours": "2",
        "acceptanceCriteria": [
          "Capability pressure is explicit",
          "Each capability names the v1 node types that depend on it",
          "Minimum viable substrate support is described for each capability",
          "The set does not pretend to be operational without substrate support",
          "The graph can point to related capability work"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
          "identity": {
            "graphId": "task-class",
