      "showLabel": true,
      "data": {
        "title": "Lock v1 Membership",
        "body": "The v1 node set is: `agent`, `prompt`, `tool`, `contract`, `task`, `observation`, `result`, and `handoff`. `memory` is deferred pending stronger scope and retention rules. `skill` remains real but is not yet a committed node type; it may end up as tool metadata, a template surface, or a reusable contract.",
        "status": "done",
        "owner": "Michael",
        "priority": "critical",
        "estimateHours": "2",
        "acceptanceCriteria": [
          "The v1 set is explicit",
          "Deferred and non-v1 types are named separately",
          "The set describes a visible agent loop"
        ],
