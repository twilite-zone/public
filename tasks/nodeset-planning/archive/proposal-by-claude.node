    {
      "id": "a1b2c3d4-0007-4007-8007-aabbcc000007",
      "type": "markdown",
      "label": "Acceptance Criteria — proposal",
      "position": {
        "x": 1140,
        "y": -120
      },
      "width": 400,
      "height": 320,
      "color": "#1565c0",
      "ports": [
