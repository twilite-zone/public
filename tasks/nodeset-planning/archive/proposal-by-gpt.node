    {
      "id": "3c9e7a5b-2d4f-4c8a-9b1e-5f3c7d2a9e13",
      "type": "markdown",
      "label": "Acceptance Criteria as Structured Attachment",
      "position": {
        "x": 2420,
        "y": 180
      },
      "width": 420,
      "height": 300,
      "color": "#1976d2",
      "ports": [
        {
