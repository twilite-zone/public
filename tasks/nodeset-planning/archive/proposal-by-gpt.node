    {
      "id": "2b8d6f4a-1c3e-4d9b-8a7f-4e2b6c1d8f12",
      "type": "markdown",
      "label": "Dependency as Edge-First",
      "position": {
        "x": 2420,
        "y": -200
      },
      "width": 420,
      "height": 280,
      "color": "#1976d2",
      "ports": [
        {
          "id": "in",
          "label": "In",
          "direction": "input",
          "dataType": "any",
          "position": {
            "side": "left",
