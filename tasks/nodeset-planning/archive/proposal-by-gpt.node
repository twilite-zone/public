          }
        }
      ],
      "inputs": [
        {
          "key": "in",
          "label": "In",
          "type": "any"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "any"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Dependency as Edge-First\n\nProposal:\n- model ordinary dependency as an edge semantic first\n- allow dependency nodes only when the dependency itself needs content, provenance, or attached discussion\n\nExamples for node escalation:\n- external system prerequisite\n- human/team blocker\n- package or service requirement\n- complex blocker with rationale",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "_classBinding": {
