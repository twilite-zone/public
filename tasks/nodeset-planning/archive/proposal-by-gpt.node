          "key": "out",
          "label": "Out",
          "type": "any"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Constraint Needs Typed Fields\n\nProposal:\nAvoid turning Constraint into a junk drawer.\n\nSuggested fields:\n- kind: technical | product | ux | policy | performance | scope | temporal\n- strength: hard | soft\n- scope: global | subgraph | local\n- enforcement: advisory | blocking | validation-target\n\nThis makes constraints queryable and prompt-safe.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "_classBinding": {
