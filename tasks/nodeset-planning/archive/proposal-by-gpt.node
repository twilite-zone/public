    {
      "id": "1a7c5e3d-9b2f-4d6a-8c7e-3f1a5d7c9e11",
      "type": "markdown",
      "label": "Recommended First Wave",
      "position": {
        "x": 2420,
        "y": -600
      },
      "width": 420,
      "height": 300,
