    {
      "id": "7a4c2e9f-6b8d-4d1a-9c5f-9d7a2b6c4e17",
      "type": "markdown",
      "label": "Canonical Semantics Summary",
      "position": {
        "x": 3620,
        "y": -220
      },
      "width": 460,
      "height": 360,
      "color": "#1976d2",
      "ports": [
        {
          "id": "in",
