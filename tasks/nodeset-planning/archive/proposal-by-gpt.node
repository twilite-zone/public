    {
      "id": "5e2a9c7d-4f6b-4d8a-9c3e-7b5e9f4c2a15",
      "type": "markdown",
      "label": "Decision and Question Are High Value",
      "position": {
        "x": 3020,
        "y": -180
      },
      "width": 420,
      "height": 300,
      "color": "#1976d2",
      "ports": [
        {
