          "type": "any"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Risk Should Likely Split Later\n\nProposal:\nKeep `Risk / Edge Case` combined only as an early convenience.\n\nLikely future split:\n- Risk = probability, impact, mitigation\n- Edge Case = unusual scenario, coverage condition, corner behavior\n\nThey overlap, but they are not the same semantic object.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "_classBinding": {
          "key": "markdown",
