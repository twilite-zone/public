          "type": "any"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "any"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Canonical Semantics Summary\n\n- Goal = desired outcome\n- Task = actionable work\n- Decision = committed choice\n- Open Question = unresolved issue needing answer\n- Constraint = rule or limit\n- Risk = potential failure mode\n- Acceptance Criteria = condition for success\n- Dependency = prerequisite or blocking relationship\n\nThis semantic split gives planning graphs better prompting, tracing, and execution structure.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
