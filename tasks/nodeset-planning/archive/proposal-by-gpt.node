          "type": "any"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "any"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Acceptance Criteria as Structured Attachment\n\nProposal:\n- keep acceptance criteria close to tasks and goals\n- represent them as structured items rather than pure prose\n- allow later promotion to stronger validation semantics\n\nSuggested shape:\n- summary\n- criteria[]\n- verification hints\n- optional test linkage\n\nThis keeps them execution-useful without overformalizing too early.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "_classBinding": {
