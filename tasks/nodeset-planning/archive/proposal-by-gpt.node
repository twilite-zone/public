          "type": "any"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Decision and Question Are High Value\n\nProposal:\nDecision and Open Question should be early first-class types because they carry project memory.\n\nWhy:\n- they shape downstream implementation\n- they inform prompting\n- they explain graph history\n- they preserve unresolved reasoning state\n\nThese are more than notes. They are thinking artifacts.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
