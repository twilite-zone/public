    {
      "id": "spatial-environment-task-membership",
      "type": "task",
      "label": "Propose a minimal spatial core anchored to navigation and focus",
      "position": {
        "x": 560,
        "y": -90
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Lock Minimal Spatial Core",
        "body": "Propose `region`, `anchor`, `portal`, `focus-zone`, `path`, and `viewport-state` as the initial spatial core. Treat `surface`, `camera`, `cluster`, and `landmark` as follow-on types once the simpler navigation semantics prove useful.",
        "status": "done",
        "owner": "Michael",
        "priority": "medium",
        "estimateHours": "1",
        "acceptanceCriteria": [
          "The v1 set supports navigation/focus semantics",
          "Deferred types are named explicitly",
          "The proposal avoids pretending Twilite is already a 3D engine"
        ],
