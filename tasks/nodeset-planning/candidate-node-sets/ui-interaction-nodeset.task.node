    {
      "id": "ui-interaction-task-membership",
      "type": "task",
      "label": "Propose a minimal UI interaction core with clear deferrals",
      "position": {
        "x": 560,
        "y": -90
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Lock Minimal UI Core",
        "body": "Propose `view`, `panel`, `control`, `state`, `binding`, and `route` as the v1 core. Defer `modal`, `layout-region`, `feedback`, and `theme-token` until layout and style systems are clearer.",
        "status": "done",
        "owner": "Michael",
        "priority": "high",
        "estimateHours": "1",
        "acceptanceCriteria": [
          "The v1 set supports authored UI structure",
