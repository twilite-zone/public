      "id": "ui-interaction-task-contracts",
      "type": "task",
      "label": "Define interface semantics, bindings, and view composition rules",
      "position": {
        "x": 560,
        "y": 260
      },
      "width": 420,
      "height": 280,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Define UI Contracts",
        "body": "Define the minimum fields and relationships for `view`, `panel`, `control`, `state`, `binding`, and `route`, including which links need typed semantics such as contains, binds-to, or navigates-to.",
        "status": "done",
        "owner": "Michael",
        "priority": "high",
        "estimateHours": "3",
        "acceptanceCriteria": [
          "Each v1 type has a minimal contract",
