    {
      "id": "narrative-story-task-membership",
      "type": "task",
      "label": "Propose a minimal v1 narrative set instead of implementing the whole literary ontology",
      "position": {
        "x": 560,
        "y": -90
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Lock Minimal V1",
        "body": "Propose `character`, `location`, `event`, `scene`, and `artifact` as the minimal v1 core. Treat `faction`, `motif`, `timeline-beat`, and `relationship-note` as deferred enrichments that depend on stronger composition and typed-edge support.",
        "status": "done",
        "owner": "Michael",
        "priority": "high",
        "estimateHours": "1",
        "acceptanceCriteria": [
          "The v1 set is deliberately small",
          "Deferred types are explicitly named",
          "The v1 set still supports legible story graphs"
        ],
