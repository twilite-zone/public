    {
      "id": "narrative-story-task-contracts",
      "type": "task",
      "label": "Define the semantic contracts for scenes, events, and story entities",
      "position": {
        "x": 560,
        "y": 260
      },
      "width": 420,
      "height": 280,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Define Narrative Contracts",
        "body": "Define the minimum fields for `character`, `location`, `event`, `scene`, and `artifact`, and specify which relationships need first-class edge semantics such as appears-in, occurs-at, contains-scene, or owns-artifact.",
        "status": "done",
        "owner": "Michael",
        "priority": "high",
        "estimateHours": "3",
        "acceptanceCriteria": [
          "Each proposed v1 type has a minimal contract",
          "Scene containment and event ordering are addressed",
          "Typed-edge pressure is visible"
