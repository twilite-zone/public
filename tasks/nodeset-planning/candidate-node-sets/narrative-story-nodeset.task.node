    {
      "id": "narrative-story-goal",
      "type": "goal",
      "label": "Define a minimal narrative nodeset worth implementing",
      "position": {
        "x": 0,
        "y": 10
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Decide whether the narrative family has a clear enough authored-loop and node contract to justify code implementation, and if so what the smallest viable v1 is.",
        "priority": "high",
        "status": "in-progress",
        "owner": "Michael",
        "estimateHours": "4",
        "acceptanceCriteria": [
          "The graph isolates a coherent v1 narrative set",
          "Scene and relationship modeling are addressed",
          "The graph states why this family should or should not be near-term"
