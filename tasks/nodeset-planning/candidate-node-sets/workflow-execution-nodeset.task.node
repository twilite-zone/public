    {
      "id": "workflow-execution-task-membership",
      "type": "task",
      "label": "Propose the smallest executable workflow vocabulary",
      "position": {
        "x": 560,
        "y": -90
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Lock Minimal Workflow Core",
        "body": "Propose `trigger`, `action`, `condition`, `input`, `output`, and `branch` as the v1 execution core. Treat `transform`, `delay`, `state`, and `failure-handler` as later additions once the base runtime contract is stable.",
        "status": "done",
        "owner": "Michael",
        "priority": "high",
        "estimateHours": "1",
        "acceptanceCriteria": [
