    {
      "id": "knowledge-research-goal",
      "type": "goal",
      "label": "Lock an implementation-ready knowledge and research nodeset",
      "position": {
        "x": 0,
        "y": 10
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Narrow the knowledge / research family into a minimal v1 set with explicit provenance, evidence relationships, and summary behavior that can drive future node classes without overcommitting to academic citation machinery.",
        "priority": "critical",
        "status": "in-progress",
        "owner": "Michael",
        "estimateHours": "4",
        "acceptanceCriteria": [
          "The graph names a deliberately minimal v1 membership set",
          "The graph captures provenance, evidence, and synthesis pressure",
          "At least one cross-nodeset boundary question remains explicit"
        ],
