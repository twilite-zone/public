    {
      "id": "knowledge-research-task-contracts",
      "type": "task",
      "label": "Define semantic contracts and typed-edge pressure for the v1 research nodes",
      "position": {
        "x": 560,
        "y": 260
      },
      "width": 420,
      "height": 280,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Define Semantic Contracts",
        "body": "Define the minimum fields and relationship rules for `concept`, `claim`, `evidence`, `source`, `question`, and `summary`, including where typed relationships are needed for `claim` to reference `evidence`, `evidence` to cite `source`, `summary` to synthesize a set of claims, and `question` to scope an inquiry cluster.",
        "status": "todo",
        "owner": "Michael",
        "priority": "high",
        "estimateHours": "3",
        "acceptanceCriteria": [
          "Each approved type has a minimal field contract",
          "Provenance relationships are explicit",
          "Typed-edge candidates are called out where plain references are weak"
        ],
        "_classBinding": {
