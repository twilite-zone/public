    {
      "id": "knowledge-research-task-membership",
      "type": "task",
      "label": "Resolve v1 membership for the knowledge and research family",
      "position": {
        "x": 560,
        "y": -90
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Lock V1 Membership",
        "body": "Propose the initial v1 set as `concept`, `claim`, `evidence`, `source`, `question`, and `summary`. Defer `definition`, `example`, `counterpoint`, and `citation-note` until the base provenance model is stable and there is stronger evidence that they deserve first-class node treatment.",
        "status": "done",
        "owner": "Michael",
        "priority": "critical",
        "estimateHours": "1",
        "acceptanceCriteria": [
          "The v1 set is intentionally small and coherent",
          "Deferred types are named separately",
          "The v1 set can support both note-taking and evidence-backed reasoning"
        ],
