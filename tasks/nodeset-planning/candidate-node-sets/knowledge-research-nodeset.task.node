    {
      "id": "knowledge-research-task-runtime",
      "type": "task",
      "label": "Map research-runtime capabilities and summary behavior",
      "position": {
        "x": 560,
        "y": 640
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Map Runtime Dependencies",
        "body": "Describe the substrate support the research nodeset needs: source metadata capture, locator-aware citations, claim/evidence rollups, summary surfaces, filtered inquiry views, and import/export behavior for note and reference heavy graphs.",
        "status": "todo",
        "owner": "Michael",
        "priority": "high",
        "estimateHours": "2",
        "acceptanceCriteria": [
          "The graph names the runtime behaviors required for provenance",
          "The graph covers summary and export pressure",
          "The nodeset does not pretend plain markdown is enough"
        ],
