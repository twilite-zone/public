    {
      "id": "product-project-task-membership",
      "type": "task",
      "label": "Propose the smallest v1 product-specific set",
      "position": {
        "x": 560,
        "y": -90
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Lock V1 Membership",
        "body": "Propose `problem`, `user-need`, `initiative`, `feature`, and `metric` as the v1 product-specific core. Reuse planning `decision`, `constraint`, `risk`, and `open-question` rather than re-creating them as product-only classes. Treat `release` as deferred until timeline/versioning support is stronger.",
        "status": "done",
        "owner": "Michael",
        "priority": "critical",
        "estimateHours": "1",
        "acceptanceCriteria": [
          "The product-specific core is explicit",
          "Shared planning concepts are not duplicated needlessly",
          "Deferred concepts are named"
        ],
