      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Map Integration Dependencies",
        "body": "Describe how product nodes should compose with planning graphs, task summaries, release planning, and progress tracking without creating two incompatible planning systems.",
        "status": "in-progress",
        "owner": "Michael",
        "priority": "high",
