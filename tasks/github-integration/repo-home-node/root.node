    {
      "id": "github-repo-home-node-task-5",
      "type": "task",
      "label": "Define repo-home template contract",
      "root": false,
      "position": {
        "x": 2400,
        "y": 300
      },
      "width": 430,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Define repo-home template contract",
        "summary": "Specialize the generic home-page template for a GitHub repository landing surface.",
        "status": "done",
        "owner": "Michael",
        "priority": "medium",
        "definitionKey": "task",
        "_classBinding": {
          "key": "task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node"
        },
        "_bridge": {
          "classKey": "task",
          "classRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node"
        },
        "estimateHours": "2",
        "acceptanceCriteria": [
          "Repo identity is visible immediately",
          "A featured first destination is obvious",
