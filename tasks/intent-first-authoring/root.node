    {
      "id": "intent-first-goal",
      "type": "goal",
      "label": "Shift authoring from manipulation to manifestation",
      "position": {
        "x": 560,
        "y": -140
      },
      "visible": true,
      "showLabel": true,
      "width": 400,
      "height": 220,
      "data": {
        "body": "Let users specify intent while the system shoulders more of layout, routing, spacing, and configuration scaffolding.",
        "priority": "high",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "8",
        "acceptanceCriteria": [
          "Users can create useful graph structure without manual layout work",
          "Intent verbs map cleanly to system actions",
          "Auto-layout enhances authorship instead of flattening expressiveness"
        ],
