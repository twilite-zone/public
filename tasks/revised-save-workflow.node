    {
      "id": "revised-save-workflow-task-summary-task",
      "type": "task",
      "label": "Revised save workflow (intent-first)",
      "root": false,
      "position": {
        "x": 180,
        "y": -160
      },
      "width": 380,
      "height": 220,
      "ports": [
        {
          "id": "root",
