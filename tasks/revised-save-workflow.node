      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# UX Rule\n\nDo **not** lead with implementation details.\n\nAvoid exposing these until needed:\n\n- repo\n- branch\n- visibility\n- writeback rules\n- storage authority\n- GitHub mode labels like Work / Private / Public\n\nLead with user intent:\n\n> I want this graph to live locally, in GitHub, or in Twilite Cloud.\n\nThen progressively reveal destination-specific settings.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "visibilityRole": "browser",
        "_placement": {
          "version": 1,
          "state": "auto-placed",
          "source": "layout",
          "updatedAt": 1777653957028,
          "reason": "auto-layout"
        }
      }
    },
