    {
      "id": "local-runtime-question",
      "type": "open-question",
      "label": "How do semantic graphs promote into executable graphs later?",
      "position": {
        "x": 1836.8871846729337,
        "y": 316.21610444579994
      },
      "width": 360,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "The long-term value is not just a flow runner. Twilite likely wants semantic structures that imply behavior. The open question is how planning and semantic graphs promote into explicit executable runtime graphs without blurring debugging or authority boundaries.",
        "status": "open",
        "owner": "Michael",
        "resolutionPath": "Resolve after the explicit phase 1 runtime is working locally",
        "prominence": "high",
