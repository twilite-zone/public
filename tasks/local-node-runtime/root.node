            "side": "right",
            "offset": 0.5
          }
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Local Node Runtime\n\nThe local Node server becomes the execution runtime for Twilite.\n\nPhase 1 stance:\n- local-first runtime\n- explicit execution edges\n- basic executable nodes (`http`, `transform`, `log`)\n- browser remains authoring/view shell, not the execution engine\n- hosted execution is a later layer, not the starting point",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": true,
        "root": true,
        "_classBinding": {
