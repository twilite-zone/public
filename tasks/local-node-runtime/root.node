    {
      "id": "local-runtime-goal",
      "type": "goal",
      "label": "Make the local Node server the execution runtime",
      "position": {
        "x": 380,
        "y": -100
      },
      "width": 360,
      "height": 280,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Twilite should be able to execute graph behavior through a local Node server that reads graphs, resolves execution order, runs nodes, and reports state back to the authoring shell.",
        "priority": "critical",
        "status": "open",
        "owner": "Michael",
        "targetDate": "",
        "successMetrics": [
          "A local process can load and execute a Twilite graph",
          "Basic runtime nodes produce real outputs locally",
          "Execution state and errors are visible in Twilite",
          "The browser is no longer the privileged execution engine"
        ],
