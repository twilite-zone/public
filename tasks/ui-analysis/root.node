    {
      "id": "ui-analysis-task-markdown-dynamic-baseline",
      "type": "task",
      "label": "Make markdown the baseline dynamic content node",
      "position": {
        "x": 5470,
        "y": 1630
      },
      "width": 440,
      "height": 300,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Treat `markdown` as the baseline authored node and converge it with the dynamic content path instead of keeping it as a permanently privileged special renderer. Current reality: `DynamicViewNode` already understands markdown payloads, but `MarkdownNode` still carries dedicated editor handoff, runtime edge-value ingestion, canvas interaction behavior, and markdown-specific presentation. This task should audit those gaps, decide which behaviors belong in the shared dynamic substrate, and preserve `markdown` as the user-facing primitive even if the renderer path converges underneath it.",
        "priority": "high",
        "status": "in-progress",
        "owner": "Michael",
        "estimateHours": "4",
        "acceptanceCriteria": [
          "The gap between `MarkdownNode` behavior and the dynamic content path is explicit",
          "Markdown editing and runtime-value behavior are either preserved or intentionally moved into the dynamic substrate",
          "Markdown remains the baseline user-facing primitive node even if the renderer path converges",
          "The minimum authored node model becomes clearer because markdown is treated as the default authored node"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "root-bridge-task",
          "sourceBridgeNodeId": "root-bridge-task",
          "sourceBridgeLabel": "Task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "task",
          "classRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node"
        },
        "definitionKey": "task"
      }
    }
  ],
