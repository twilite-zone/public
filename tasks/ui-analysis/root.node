    {
      "id": "ui-analysis-task-grid-action",
      "type": "task",
      "label": "Repair or remove dead grid action paths",
      "position": {
        "x": 3160,
        "y": 300
      },
      "width": 400,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "The current Grid Options menu exposed an `Align to Grid` action that was not actually wired safely. That path is now connected to the real editor behavior and has been re-homed under selection layout tools, which is a better fit for its actual scope.",
        "priority": "high",
        "status": "done",
        "owner": "Michael",
        "estimateHours": "2",
        "acceptanceCriteria": [
          "Grid-related controls all invoke real behavior",
          "No dead or misleading grid action remains in the toolbar",
          "The surviving grid controls have a coherent scope"
        ],
        "_classBinding": {
