    {
      "id": "ui-analysis-task-system-panel-label",
      "type": "task",
      "label": "Rename and reframe the Legend surface as a system panel",
      "position": {
        "x": 3600,
        "y": 300
      },
      "width": 400,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "The left-side `Legend` affordance currently opens a panel containing legend, manifest, scripts, diagnostics, and related graph-system surfaces. The first copy cleanup is in: the subtitle is clearer, the legacy dictionary mention is gone, diagnostics is named honestly, and the drawer now stops at the browser bar instead of fighting the shell. The remaining question is whether the rail label itself should stay `Legend` permanently or evolve into a broader graph-system label.",
        "priority": "critical",
        "status": "in-progress",
        "owner": "Michael",
        "estimateHours": "4",
        "acceptanceCriteria": [
          "The panel label matches its real contents",
          "Users can infer where validation and scripts live without insider knowledge",
          "The surface reads as one coherent responsibility"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node"
        },
        "_bridge": {
