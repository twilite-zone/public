    },
    {
      "id": "ui-analysis-task-control-authority",
      "type": "task",
      "label": "Choose a primary authority for editor controls",
      "position": {
        "x": 4040,
        "y": 300
      },
      "width": 400,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Toolbar, radial menu, and side tabs currently expose overlapping editor actions. The current proposal is: toolbar owns primary editing authority, side rails own persistent reference and management surfaces, and the radial menu becomes shortcut-only. Use that map to demote or remove duplicates so the editor teaches one model instead of three convenience layers.",
        "priority": "critical",
        "status": "in-progress",
        "owner": "Michael",
        "estimateHours": "6",
        "acceptanceCriteria": [
          "Each editor action category has a clear primary home",
          "Duplicate affordances are reduced or intentionally downgraded to shortcuts",
          "A new user can infer where to look for layout, inspection, and creation controls"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node"
        },
        "_bridge": {
