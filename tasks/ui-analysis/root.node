        "status": "in-progress",
        "owner": "Michael",
        "estimateHours": "6",
        "acceptanceCriteria": [
          "The product's visual language gaps are named concretely",
          "Terminology inconsistencies are captured",
          "System-level consistency work is scoped into follow-up tasks",
          "Typography authority is grounded in text-bearing primitives and document structure rather than generic node appearance controls"
        ],
