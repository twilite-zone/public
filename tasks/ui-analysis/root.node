    {
      "id": "ui-analysis-control-authority-notes",
      "type": "section",
      "label": "Editor Control Authority",
      "position": {
        "x": 4040,
        "y": -80
      },
      "width": 520,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Editor Control Authority",
        "summary": "Primary authority should live in the toolbar. Persistent reference and management surfaces should live in the side rails and drawers. The radial menu should survive only as a shortcut surface, not as the place where a user has to discover how the editor works. If an action is important enough that a new user must learn it, it needs a clear home outside the radial menu.",
        "level": "h3",
        "anchor": "editor-control-authority",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/document-publishing/section.node-class.node",
