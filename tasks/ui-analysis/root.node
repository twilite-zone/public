    {
      "id": "ui-analysis-task-panels",
      "type": "task",
      "label": "Audit panels, settings, and management flows",
      "position": {
        "x": 2640,
        "y": -60
      },
      "width": 400,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Review settings panels, diagnostics, GitHub/save flows, properties, manifests, and management surfaces to find where the product exposes real power but lacks user-readable framing or safe defaults. Initial findings show an overloaded save model, a cognitively dense GitHub save flow, and an unclear boundary between graph-level settings and selected-node properties.",
        "priority": "high",
        "status": "in-progress",
        "owner": "Michael",
        "estimateHours": "6",
        "acceptanceCriteria": [
          "Management surfaces are mapped by user job",
          "Settings and state-heavy surfaces are called out clearly",
          "Complex flows are broken into smaller remediation tasks"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
