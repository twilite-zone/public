    {
      "id": "ui-analysis-scope",
      "type": "section",
      "label": "Analysis Scope",
      "position": {
        "x": 2060,
        "y": -900
      },
      "width": 520,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Analysis Scope",
        "summary": "Treat browser chrome, graph authoring, system panels, management/settings flows, onboarding/help, and visual language as one product surface. The point is not just to make isolated controls prettier, but to find where the app's UI model is still fragmented or implicit.",
        "level": "h3",
        "anchor": "analysis-scope",
        "status": "active",
        "_classBinding": {
