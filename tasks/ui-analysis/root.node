          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "github://twilite-zone/public/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "ui-analysis-task-layout-panel",
      "type": "task",
      "label": "Reshape the layout panel into a smaller action-first surface",
      "position": {
        "x": 5360,
        "y": 300
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "The current layout panel is less chaotic than before, but it still feels creator-native and visually heavy. Recast it as a compact, decisive product surface: keep graph-arrangement actions and the few defaults a normal user should understand, move edge-appearance controls to a visual/style home, and demote algorithm tuning into an expert path instead of a big visible block.",
        "priority": "critical",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "5",
        "acceptanceCriteria": [
          "The primary layout panel contains only layout actions and core graph defaults",
