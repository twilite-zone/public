    {
      "id": "ui-analysis-task-action-labels",
      "type": "task",
      "label": "Reconcile action labels with actual behavior",
      "position": {
        "x": 4480,
        "y": 300
      },
      "width": 400,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Some actions still promise broader scope than they actually provide, such as whole-graph actions that appear to depend on selection. The first concrete mismatch is now fixed: `Copy Entire Graph` no longer requires a prior selection. Continue auditing similar mismatches so the UI does not lie.",
        "priority": "high",
        "status": "in-progress",
        "owner": "Michael",
        "estimateHours": "3",
        "acceptanceCriteria": [
          "Action names reflect their true scope",
          "Selection-scoped actions are clearly distinguished from graph-scoped actions",
          "No major toolbar action requires users to discover hidden caveats"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node"
