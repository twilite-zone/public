    {
      "id": "ui-analysis-task-browser",
      "type": "task",
      "label": "Audit browser chrome and navigation surfaces",
      "position": {
        "x": 1580,
        "y": -60
      },
      "width": 400,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Review tabs, address bar, viewport chip, browser controls, bookmarks, browser settings, account surfaces, and shell behavior to find where Twilite still feels inconsistent or surprising as a browser-shaped environment. Progress so far: browser chrome now has avatar and overflow affordances, a browser appearance drawer, an account drawer, explicit Twilite-first account creation, and returning-user GitHub sign-in recovery, but the account model still needs a native Twilite re-entry path and additional linked-provider support.",
        "priority": "high",
        "status": "in-progress",
        "owner": "Michael",
        "estimateHours": "4",
        "acceptanceCriteria": [
          "Browser-level controls are mapped clearly",
          "Navigation and account surfaces are grouped by responsibility",
          "Account creation, sign-in, and provider-linking work are captured as concrete follow-up tasks"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "root-bridge-task",
          "sourceBridgeNodeId": "root-bridge-task",
          "sourceBridgeLabel": "Task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "task",
          "classRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node"
        },
        "definitionKey": "task"
      }
    },
    {
      "id": "ui-analysis-task-editor",
      "type": "task",
      "label": "Audit graph authoring and editing surfaces",
      "position": {
        "x": 2110,
        "y": -60
      },
      "width": 400,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Review graph creation, selection, toolbar actions, radial controls, drag/drop, layout controls, semantic zoom behaviors, node editing, and panel interactions to identify where authoring still depends on builder intuition. Initial findings already show a dead grid action, an overloaded Legend surface, duplicated control authority across toolbar/radial/side tabs, and at least one major action label that does not match its actual behavior.",
        "priority": "critical",
        "status": "in-progress",
        "owner": "Michael",
        "estimateHours": "8",
        "acceptanceCriteria": [
          "Authoring surfaces are grouped into a readable mental model",
          "Major editor friction points are named explicitly",
          "Interaction rough spots are converted into follow-up work"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "root-bridge-task",
          "sourceBridgeNodeId": "root-bridge-task",
          "sourceBridgeLabel": "Task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
