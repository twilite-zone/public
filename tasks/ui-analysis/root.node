      }
    },
    {
      "id": "ui-analysis-task-settings-boundary",
      "type": "task",
      "label": "Define the boundary between graph settings and node properties",
      "position": {
        "x": 3620,
        "y": 1060
      },
      "width": 400,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Graph-level settings currently live across Document Properties, the system drawer, and manifest editing inside the Properties panel. Decide what belongs to graph/document settings versus selected-node properties so the product stops exposing the same concern through multiple mental models. Current target model: `DocumentPropertiesDialog` becomes the primary graph-settings authority, `PropertiesPanel` focuses on the current selection, and the system drawer remains a graph-native reference/health surface rather than the preferred home for deep configuration. Implementation progress: manifest editing in the properties panel has already been reduced to a summary plus `Open Graph Settings` handoff, and the document dialog now enforces the visible tab model instead of carrying hidden `system` and `collaboration` authorities.",
        "priority": "critical",
        "status": "in-progress",
        "owner": "Michael",
        "estimateHours": "6",
        "acceptanceCriteria": [
          "Graph-level settings have a clear primary home",
          "Manifest and document concerns are no longer ambiguously split across surfaces",
          "Users can tell whether they are editing the graph or the current selection",
          "Manifest selection in the properties panel clearly hands off to graph settings instead of duplicating the full graph-level editor"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "root-bridge-task",
          "sourceBridgeNodeId": "root-bridge-task",
