      "showLabel": true,
      "data": {
        "body": "Goal: Make graph placement and relayout trustworthy\nStatus: done\n\nTasks in scope:\n1. Define one placement doctrine\n2. Replace naive growth placement with incremental placement\n3. Make positionless import placement intentional\n4. Constrain global relayout and reroute behavior\n5. Audit coordinate assumptions and viewport math\n\nOpen questions:\n1. When should global relayout override local placement?",
        "status": "done",
        "owner": "Michael",
        "priority": "critical",
        "estimateHours": "10",
        "acceptanceCriteria": [
          "Expansion and growth placement behave consistently in dense graphs",
          "Positionless imports land predictably",
          "Global relayout preserves meaning instead of surprising the user"
        ],
        "title": "Make graph placement and relayout trustworthy",
        "countAsTask": false,
        "summarySource": "node-updater",
        "taskProgress": {
