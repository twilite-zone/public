      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Define the concrete operating rule for when global relayout is allowed, when reroute may act alone, and what kinds of manual placement must be protected from being overwritten. Preserve meaning over neatness. Placement provenance is live, automatic layout now respects manually shaped nodes, and explicit layout now asks before overriding manual placement.",
        "priority": "high",
        "status": "done",
        "owner": "Michael",
        "estimateHours": "8",
        "acceptanceCriteria": [
          "Auto-layout modes feel predictably different and useful",
          "Reroute behavior does not create avoidable visual churn",
          "Global relayout respects the placement doctrine"
        ],
