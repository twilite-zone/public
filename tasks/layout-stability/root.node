    {
      "id": "layout-stability-question-global",
      "type": "open-question",
      "label": "When should global relayout override local placement?",
      "position": {
        "x": 2890,
        "y": 280
      },
      "width": 380,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Global relayout should override local placement only when the graph is effectively unplaced or when the user explicitly grants layout authority. Ordinary local growth should remain local, reroute should stay edge-only, and manual placement should be sticky by default.",
        "status": "answered",
        "owner": "Michael",
        "prominence": "high",
        "resolutionPath": "/library/documentation/contracts/layout/graph-layout-authority-contract.node",
