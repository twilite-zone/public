      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Relayout And Reroute Behavior",
        "summary": "Local growth owns normal editing. Repeated creation, expansion, and positionless imports should adapt near their source or active area instead of invoking whole-graph cleanup. Manual placement is sticky: once a user has shaped a region, later ordinary growth should work around that meaning. Global relayout is explicit and exceptional, reserved for user-requested layout operations or graphs that have no meaningful placement yet. Reroute is lighter than relayout: edges may adapt as nodes move, but edge cleanup alone should not relocate nodes. Preserve meaning over neatness.",
        "level": "h3",
        "anchor": "relayout-reroute-behavior",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
