    {
      "id": "layout-stability-overview",
      "type": "section",
      "label": "Layout Stability",
      "position": {
        "x": 1520,
        "y": -900
      },
      "width": 500,
      "height": 300,
      "color": "#1976d2",
      "ports": [
        {
          "id": "in",
          "label": "In",
          "direction": "input",
          "dataType": "flow",
          "position": {
            "side": "left",
            "offset": 0.5
          }
        },
        {
          "id": "out",
          "label": "Out",
          "direction": "output",
          "dataType": "content",
          "position": {
            "side": "right",
            "offset": 0.5
          }
        }
      ],
      "inputs": [
        {
          "key": "in",
          "label": "In",
          "type": "flow"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Layout Stability",
        "summary": "Twilite currently has several competing placement authorities: plain node creation uses a fallback grid, expansion uses hardcoded rightward attachment, bridged/class creation uses another fixed offset, missing-position imports invent temporary coordinates before relayout, and auto-layout recenters the whole graph globally.\n\nThat means graphs can feel jumpy, crowded, and locally disrespectful even when each individual placement rule is deterministic.\n\nThe main goal of this task is to replace those disconnected placement habits with one readable doctrine: local growth should be incremental and collision-aware, global layout should be explicit or reserved for positionless content, and manual placement should not be casually overwritten.",
        "level": "h2",
        "anchor": "layout-stability",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "root-bridge-section",
          "sourceBridgeNodeId": "root-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "layout-stability-doctrine",
      "type": "section",
      "label": "Placement Doctrine",
      "position": {
        "x": 1520,
        "y": -520
      },
      "width": 500,
      "height": 320,
      "color": "#1976d2",
      "ports": [
        {
          "id": "in",
          "label": "In",
          "direction": "input",
          "dataType": "flow",
          "position": {
            "side": "left",
            "offset": 0.5
          }
        },
        {
          "id": "out",
          "label": "Out",
          "direction": "output",
          "dataType": "content",
          "position": {
            "side": "right",
            "offset": 0.5
          }
        }
      ],
      "inputs": [
        {
          "key": "in",
          "label": "In",
          "type": "flow"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Placement Doctrine",
        "summary": "1. Local growth first: expansion, bridge-created nodes, and other nearby additions should use incremental placement near their source.\n\n2. Global relayout only by authority: use full relayout when the user explicitly asks for it or when incoming graph content has no meaningful placement yet.\n\n3. Manual placement is sticky: once a user has arranged a region intentionally, ordinary growth should adapt to that region instead of casually wiping it out.\n\n4. Positionless imports are intentional: importing nodes without positions is its own placement mode, not a half-random intermediate state.\n\n5. Reroute is lighter than relayout: edge cleanup can respond to node movement, but reroute alone should not relocate nodes.\n\n6. One coordinate model: rendering, bounds, fitting, and placement helpers must agree about what node position means.",
        "level": "h3",
        "anchor": "placement-doctrine",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "root-bridge-section",
          "sourceBridgeNodeId": "root-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "layout-stability-behavior-law",
      "type": "section",
