      "type": "task",
      "label": "Make diagnostics useful to users",
      "position": {
        "x": 2350,
        "y": 280
      },
      "width": 400,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Present diagnostics so users can answer three questions immediately: what broke, where, and whether it is still active. Prioritize trust over completeness in the first beta pass.",
        "priority": "high",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "6",
        "acceptanceCriteria": [
          "Diagnostics surface exposes severity and active/resolved state",
          "Users can navigate from a diagnostic to relevant graph context",
          "The first beta pass favors clarity over exhaustive instrumentation"
        ],
        "_classBinding": {
