    {
      "id": "diagnostics-task-contracts",
      "type": "task",
      "label": "Capture class, bridge, and contract violations",
      "position": {
        "x": 2620,
        "y": -140
      },
      "width": 400,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Capture missing view payloads, unresolved class refs, bad source-node ids, bridge mismatches, and contract violations like incomplete document order. These should read as attributable diagnostics, not opaque console chatter.",
        "priority": "high",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "8",
        "acceptanceCriteria": [
          "Class and contract failures are normalized into diagnostics records",
          "Entries identify node and class refs where available",
          "Contract errors read as actionable product feedback"
        ],
        "_classBinding": {
          "key": "task",
