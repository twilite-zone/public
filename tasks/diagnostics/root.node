    {
      "id": "diagnostics-overview",
      "type": "section",
      "label": "Overview",
      "position": {
        "x": 2080,
        "y": -980
      },
      "width": 520,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Diagnostics must be durable and attributable",
        "summary": "Twilite needs one diagnostics surface that users and builders can trust. Runtime failures, class and contract violations, validation errors, and integration failures should all be captured in a persistent place with clear attribution: which graph, which node, which script, which class, which operation, and whether the issue is still active.",
        "level": "h2",
        "anchor": "diagnostics-overview",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "root-bridge-section",
          "sourceBridgeNodeId": "root-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "diagnostics-goal",
      "type": "goal",
      "label": "Make diagnostics durable and attributable",
      "position": {
        "x": 2080,
        "y": -620
      },
      "width": 420,
      "height": 300,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Give Twilite one trustworthy diagnostics surface that captures failures durably, attributes them clearly, and helps users understand whether issues are still active.",
        "priority": "critical",
        "status": "open",
        "owner": "Michael",
        "targetDate": "2026-05-15",
        "successMetrics": [
          "Runtime failures persist long enough to inspect",
          "Diagnostics identify graph, node, script, class, and operation when available",
          "Users can distinguish active issues from already-resolved ones"
        ],
        "_classBinding": {
          "key": "goal",
          "sourceRef": "/library/classes/nodes/task-planning/goal.node-class.node",
          "ref": "/library/classes/nodes/task-planning/goal.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "root-bridge-goal",
          "sourceBridgeNodeId": "root-bridge-goal",
          "sourceBridgeLabel": "Goal",
          "sourceRef": "/library/classes/nodes/task-planning/goal.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "goal",
          "classRef": "/library/classes/nodes/task-planning/goal.node-class.node"
        },
        "definitionKey": "goal"
      }
    },
    {
      "id": "diagnostics-task-surface",
      "type": "task",
      "label": "Define the diagnostics record and surface",
      "position": {
        "x": 1540,
        "y": -140
      },
      "width": 400,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Define the canonical diagnostics record, severity model, active/resolved status, and the in-app surface where diagnostics will live. Decide what survives reload, what is graph-scoped, and what is session-scoped.",
        "priority": "critical",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "6",
        "acceptanceCriteria": [
          "One diagnostics record shape is defined",
          "Severity and active/resolved status are explicit",
          "One app surface is chosen for diagnostics review"
        ],
        "_classBinding": {
          "key": "task",
