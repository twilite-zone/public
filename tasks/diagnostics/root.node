      "label": "Capture runtime and integration failures",
      "position": {
        "x": 2080,
        "y": -140
      },
      "width": 400,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Route script errors, dynamic-view failures, source-fetch failures, save/export failures, and GitHub API failures into the diagnostics surface with clear operation context.",
        "priority": "critical",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "8",
        "acceptanceCriteria": [
