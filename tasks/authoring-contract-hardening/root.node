    {
      "id": "authoring-contract-hardening-overview",
      "type": "markdown",
      "label": "Authoring Contract Hardening",
      "position": {
        "x": -360,
        "y": -980
      },
      "width": 560,
      "height": 260,
      "color": "#1d4ed8",
      "visible": true,
      "showLabel": true,
      "root": true,
      "data": {
        "markdown": "# Authoring Contract Hardening\n\nTwilite is now powerful enough that hidden contract knowledge creates real friction. This task graph is for making the authoring model explicit, teachable, validated, and predictable so good graph authoring becomes the default instead of a survival skill.",
        "memo": "",
        "link": "",
        "isRoot": true,
        "root": true,
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
