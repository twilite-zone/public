    {
      "id": "authoring-contract-hardening-goal",
      "type": "goal",
      "label": "Make Twilite's authoring contract explicit and durable",
      "position": {
        "x": 320,
        "y": -940
      },
      "width": 420,
      "height": 280,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Reduce hidden knowledge in Twilite by turning the authoring contract into something executable, validated, discoverable, and consistently taught across docs, specimens, and the app itself.",
        "priority": "critical",
        "status": "open",
        "owner": "Michael",
        "targetDate": "",
        "successMetrics": [
          "The app explains contract failures precisely at the point of mistake",
          "Canonical specimens cover the common declaration, port, portal, and summary patterns",
          "Models can author valid graphs without relying on tribal knowledge"
        ],
        "_classBinding": {
          "key": "goal",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/goal.node-class.node",
