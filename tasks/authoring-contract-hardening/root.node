      "data": {
        "body": "Keep auth, installation access, saveability, and graph-structure problems distinct so GitHub/session issues do not masquerade as contract failures and contract failures do not read like generic save errors.",
        "priority": "high",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "6",
        "acceptanceCriteria": [
          "Saveability diagnostics separate auth/connectivity from structure",
          "Provider-session failures are explicit everywhere they matter",
          "Users can tell whether a problem is about graph shape or write authority"
        ],
