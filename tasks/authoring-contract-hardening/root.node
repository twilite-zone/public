    {
      "id": "authoring-contract-hardening-task-contract",
      "type": "task",
      "label": "Make the contract executable",
      "position": {
        "x": -280,
        "y": -520
      },
      "width": 360,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Promote the real authoring rules into validators, normalizers, creation helpers, and graph-native contract checks so declaration, port, portal, and target mistakes are caught structurally instead of through hindsight.",
        "priority": "critical",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "8",
        "acceptanceCriteria": [
          "Top contract violations have dedicated diagnostics",
          "Creation/update paths normalize or reject contradictory fields",
          "Saveability failures identify the exact violated contract"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
