      },
      "width": 380,
      "height": 220,
      "visible": false,
      "showLabel": true,
      "data": {
        "body": "Goal: Make authoring rules enforceable at runtime\nStatus: todo\n\nTasks in scope:\n1. Inventory the contract enforcement surface\n2. Define the violation matrix\n3. Implement normalization and rejection paths\n4. Tie the contract into saveability\n5. Add contract-focused smoke cases\n\nOpen questions:\n1. Which mismatches should hard-fail immediately?",
        "status": "todo",
        "owner": "Michael",
        "priority": "critical",
        "estimateHours": "12",
        "acceptanceCriteria": [
          "Top contract violations are named and validated",
          "Create/update/save paths normalize or reject contradictions consistently",
          "Authors get precise contract failures at the point of mistake"
        ],
        "title": "Make authoring rules enforceable at runtime",
