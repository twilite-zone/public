      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Promote Twilite authoring rules into explicit runtime law so malformed or contradictory graph shapes are caught by validators, normalization, and saveability checks instead of being debugged after the fact.",
        "priority": "critical",
        "status": "todo",
        "owner": "Michael",
        "targetDate": "",
        "successMetrics": [
          "Top contract violations are named and validated",
          "Create/update/save paths normalize or reject contradictions consistently",
          "Authors get precise contract failures at the point of mistake"
