    {
      "id": "content-app-separation-overview",
      "type": "markdown",
      "label": "Overview",
      "position": {
        "x": -300,
        "y": 220
      },
      "width": 520,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Separation Goal\n\nTreat the app as runtime and the graph corpus as content.\n\nDesired steady state:\n- app deploys only for runtime changes\n- graph repos publish independently\n- canonical public roots live outside the app repo\n- local bundled graphs exist only for bootstrap or safety-critical runtime assets",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "ref": "/library/classes/nodes/markdown.node-class.node"
        },
        "_bridge": {
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "markdown",
          "classRef": "/library/classes/nodes/markdown.node-class.node"
        },
        "definitionKey": "markdown"
      }
    },
    {
      "id": "content-app-separation-goal",
      "type": "goal",
      "label": "Make content independent from app publishing",
      "position": {
        "x": 420,
        "y": -120
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Separate authored graph content from the Twilite app runtime",
        "body": "A graph-only change should publish from a content repo without requiring an app rebuild, while the runtime still has a safe bootstrap path for critical local assets.",
        "status": "in-progress",
        "priority": "high",
        "owner": "Michael",
        "successMetrics": [
          "Canonical public roots live outside the app repo",
          "The app loads content from content repos by default",
          "Graph publishing no longer implies app redeploy"
        ],
        "_classBinding": {
          "key": "goal",
          "sourceRef": "/library/classes/nodes/task-planning/goal.node-class.node",
          "ref": "/library/classes/nodes/task-planning/goal.node-class.node"
        },
        "_bridge": {
          "sourceRef": "/library/classes/nodes/task-planning/goal.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "goal",
          "classRef": "/library/classes/nodes/task-planning/goal.node-class.node"
        },
        "definitionKey": "goal"
      }
    },
    {
      "id": "content-app-separation-task-canonical",
      "type": "task",
      "label": "Choose canonical graph repos",
      "position": {
        "x": 980,
        "y": -320
      },
      "width": 420,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Declare canonical ownership for public graph spaces",
        "body": "Pick the source-of-truth repos for public roots, product/company roots, and any runtime-critical bundled graph law. Freeze duplicate public graph trees in the app repo.",
        "status": "done",
        "priority": "high",
        "owner": "Michael",
        "acceptanceCriteria": [
          "twilite-zone is declared canonical for public content",
          "twilitellc is declared canonical for company/product content",
          "The app repo no longer claims local public roots are canonical"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "/library/classes/nodes/task-planning/task.node-class.node"
        },
        "_bridge": {
          "sourceRef": "/library/classes/nodes/task-planning/task.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "task",
          "classRef": "/library/classes/nodes/task-planning/task.node-class.node"
        },
        "definitionKey": "task"
      }
    },
    {
      "id": "content-app-separation-task-config",
      "type": "task",
      "label": "Centralize content entry refs",
      "position": {
        "x": 980,
        "y": -20
      },
      "width": 420,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Replace scattered hardcoded graph homes with a single content registry",
        "body": "Move default home refs and migrated section refs behind one configuration surface so the runtime has one clear model for external content roots.",
        "status": "done",
        "priority": "high",
        "owner": "Michael",
        "acceptanceCriteria": [
          "Default home graph ref is defined in one place",
          "Migration helpers and startup defaults agree",
          "README and runtime point at the same canonical homes"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "/library/classes/nodes/task-planning/task.node-class.node"
        },
        "_bridge": {
          "sourceRef": "/library/classes/nodes/task-planning/task.node-class.node",
