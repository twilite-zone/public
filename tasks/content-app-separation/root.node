          "classKey": "task",
          "classRef": "/library/classes/nodes/task-planning/task.node-class.node"
        },
        "definitionKey": "task"
      }
    },
    {
      "id": "content-app-separation-task-saveflow",
      "type": "task",
      "label": "Align save and publish flow",
      "position": {
        "x": 980,
        "y": 580
      },
      "width": 420,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Make GitHub-backed content the normal publishing path",
        "body": "Ensure that editing a graph from a content repo saves back to that repo by default, while local save remains a draft/export path rather than the main publishing model.",
        "status": "done",
        "priority": "medium",
        "owner": "Michael",
        "acceptanceCriteria": [
          "GitHub-backed graphs save back to their source repo cleanly",
          "Local untitled graphs can still be exported safely",
          "The publish model matches the new repo boundary"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "/library/classes/nodes/task-planning/task.node-class.node"
        },
