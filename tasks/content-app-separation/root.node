          "classKey": "task",
          "classRef": "/library/classes/nodes/task-planning/task.node-class.node"
        },
        "definitionKey": "task"
      }
    },
    {
      "id": "content-app-separation-task-depublish",
      "type": "task",
      "label": "Depublish app-owned public graph copies",
      "position": {
        "x": 980,
        "y": 280
      },
      "width": 420,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Remove duplicate authored public graph trees from the app repo",
        "body": "Archive, delete, or clearly downgrade local public graph trees under the app repo so they are not mistaken for publishable source content.",
        "status": "done",
        "priority": "high",
        "owner": "Michael",
        "acceptanceCriteria": [
          "The app repo retains only bootstrap-safe local graph assets",
          "No active public graph root is maintained in two repos",
          "Developer docs explain where public content now lives"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "/library/classes/nodes/task-planning/task.node-class.node"
        },
        "_bridge": {
          "sourceRef": "/library/classes/nodes/task-planning/task.node-class.node",
