        },
        "definitionKey": "task"
      }
    },
    {
      "id": "content-app-separation-question-library",
      "type": "open-question",
      "label": "Should the library split too?",
      "position": {
        "x": 1480,
        "y": 120
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Which graph assets must remain bundled with the app?",
        "body": "For now, node classes, contracts, dictionaries, templates, and related documentation stay bundled with the Twilite app. The cleanup removed duplicate public authored content, but public/library/** remains runtime-owned graph law rather than moving into an external content repo.",
        "status": "answered",
        "priority": "medium",
        "owner": "Michael",
        "_classBinding": {
          "key": "open-question",
          "sourceRef": "/library/classes/nodes/task-planning/open-question.node-class.node",
