    {
      "id": "chatgpt-app-task-summary-task",
      "type": "task",
      "label": "Ship a usable ChatGPT-style interface inside Twilite",
      "position": {
        "x": -760,
        "y": 280
      },
      "width": 380,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Goal: Ship a usable ChatGPT-style interface inside Twilite\nStatus: open\n\nTasks in scope:\n1. Define the Twilite chat mode and authority contract\n2. Build the ChatGPT-style Twilite chat surface\n3. Define graph-aware context assembly\n4. Implement the server-side chat API and streaming transport\n5. Bridge chat output into graph actions\n6. Add guardrails, evals, and observability for Twilite chat\n\nOpen questions:\n1. Where should chat history live in Twilite?\n2. What actions can chat take versus only suggest?",
        "status": "open",
        "owner": "Michael",
        "priority": "critical",
        "estimateHours": "4",
        "acceptanceCriteria": [
          "Chat mode entry points are explicit",
          "Conversation and action contract are named",
          "Deferred capabilities are written down"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/task.node-class.node",
          "identity": {
            "graphId": "task-class",
            "name": "Task Class",
            "version": "0.1.0",
            "description": "Atomic executable unit of work for planning graphs.",
            "createdAt": "2026-03-15T20:30:00.000Z",
            "updatedAt": "2026-03-24T01:10:00.000Z"
          },
          "intent": "node-class",
          "meaning": "Atomic executable unit of work for planning graphs.",
          "description": "Atomic executable unit of work for planning graphs.",
