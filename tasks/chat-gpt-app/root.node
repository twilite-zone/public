    {
      "id": "chatgpt-app-decision-web-first",
      "type": "decision",
      "label": "The chat surface lives inside Twilite's web shell first",
      "position": {
        "x": 1220,
        "y": -120
      },
      "width": 380,
      "height": 270,
      "visible": true,
      "showLabel": true,
      "data": {
        "rationale": "Twilite already has a browser and editor shell. The chat interface should arrive there first so it can reuse routing, graph context, and existing user flows instead of becoming a parallel product surface.",
        "status": "decided",
        "decidedAt": "2026-03-18",
        "owner": "Michael",
        "supersededBy": "",
        "_classBinding": {
