        "summarySource": "node-updater",
        "taskTitles": [
          "Define the Twilite chat mode and authority contract",
          "Build the ChatGPT-style Twilite chat surface",
          "Define graph-aware context assembly",
          "Implement the server-side chat API and streaming transport",
          "Bridge chat output into graph actions",
          "Add guardrails, evals, and observability for Twilite chat"
        ],
        "questionTitles": [
          "Where should chat history live in Twilite?",
          "What actions can chat take versus only suggest?"
        ],
        "taskListText": "1. Define the Twilite chat mode and authority contract\n2. Build the ChatGPT-style Twilite chat surface\n3. Define graph-aware context assembly\n4. Implement the server-side chat API and streaming transport\n5. Bridge chat output into graph actions\n6. Add guardrails, evals, and observability for Twilite chat",
        "questionListText": "1. Where should chat history live in Twilite?\n2. What actions can chat take versus only suggest?",
        "updatedAt": "2026-04-04T17:43:15.076Z",
        "priority": "critical",
        "owner": "Michael",
        "targetDate": "",
        "nextAction": "Resolve the remaining product and authority questions, then sequence implementation.",
        "blockedReason": "",
        "health": "needs-review",
        "identity": {
          "graphId": "chatgpt-app-task"
        },
        "view": {
          "intent": "node",
          "payload": "node.web",
          "label": "Summary"
        },
        "renderShape": {
          "kind": "html"
        },
        "html": "<div style='width:100%;height:100%;display:flex;flex-direction:column;box-sizing:border-box;padding:0;overflow:hidden;border-radius:18px;background:linear-gradient(180deg, rgba(255,255,255,.96), rgba(228,247,239,.94));color:#23160a;position:relative;border:1px solid rgba(0,0,0,.08);'>\n  <div style='display:flex;align-items:center;justify-content:space-between;gap:10px;padding:10px 14px;background:linear-gradient(135deg, #9be7c4, #1f9d67);color:#082618;border-bottom:1px solid rgba(0,0,0,.08);'>\n    <div style='display:flex;align-items:center;gap:10px;min-width:0;'>\n      <div style='width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:{{eq(data.status, \"done\", \"rgba(31,157,103,.20)\", \"rgba(255,255,255,.18)\")}};border:1px solid {{eq(data.status, \"done\", \"rgba(8,38,24,.24)\", \"rgba(8,38,24,.32)\")}};color:#082618;font:800 14px system-ui,sans-serif;flex:0 0 auto;'>{{eq(data.status, \"done\", \"✓\", \"\")}}</div>\n      <div style='min-width:0;'>\n        <div style='font:700 10px system-ui,sans-serif;letter-spacing:.16em;text-transform:uppercase;opacity:.68;margin-bottom:2px;'>Task Graph</div>\n        <div style='font:800 18px/1.02 Georgia, \"Times New Roman\", serif;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;'>{{data.goal}}</div>\n      </div>\n    </div>\n    <div style='display:inline-flex;align-items:center;justify-content:center;padding:5px 9px;border-radius:999px;background:rgba(255,255,255,.38);border:1px solid rgba(0,0,0,.08);font:700 10px system-ui,sans-serif;text-transform:uppercase;white-space:nowrap;'>{{data.status}}</div>\n  </div>\n  <div style='display:flex;flex-direction:column;gap:12px;padding:14px 16px;min-height:0;flex:1;color:#23160a;'>\n    <div style='display:flex;align-items:center;gap:7px;flex-wrap:wrap;font:700 10px system-ui,sans-serif;color:#5b4731;'>\n      <span>Priority {{data.priority}}</span><span>•</span><span>Health {{data.health}}</span><span>•</span><span>Owner {{data.owner}}</span><span>•</span><span>Target {{data.targetDate}}</span>\n    </div>\n    <div style='padding:9px 11px;border-radius:12px;background:rgba(31,157,103,.12);border:1px solid rgba(0,0,0,.06);font:600 11px/1.35 system-ui,sans-serif;color:#23160a;'>\n      <div><strong>Next:</strong> {{data.nextAction}}</div>\n      <div style='margin-top:4px;color:#7a3e2d;'><strong>Blocker:</strong> {{data.blockedReason}}</div>\n    </div>\n    <div style='display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;'>\n      <div style='padding:10px 12px;border-radius:12px;background:rgba(255,255,255,.72);border:1px solid rgba(0,0,0,.06);'>\n        <div style='font:700 10px system-ui,sans-serif;letter-spacing:.13em;text-transform:uppercase;opacity:.72;color:#3b5b47;'>Tasks</div>\n        <div style='margin-top:6px;font:800 24px/1 Georgia, \"Times New Roman\", serif;color:#23160a;'>{{data.taskProgress.completed}} / {{data.taskProgress.total}}</div>\n      </div>\n      <div style='padding:10px 12px;border-radius:12px;background:rgba(255,255,255,.72);border:1px solid rgba(0,0,0,.06);'>\n        <div style='font:700 10px system-ui,sans-serif;letter-spacing:.13em;text-transform:uppercase;opacity:.72;color:#3b5b47;'>Questions</div>\n        <div style='margin-top:6px;font:800 24px/1 Georgia, \"Times New Roman\", serif;color:#23160a;'>{{data.questionProgress.answered}} / {{data.questionProgress.total}}</div>\n      </div>\n    </div>\n    <div style='display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;min-height:0;flex:1;'>\n      <div style='padding:10px 12px;border-radius:12px;background:rgba(255,255,255,.72);border:1px solid rgba(0,0,0,.06);min-height:0;'>\n        <div style='font:700 10px system-ui,sans-serif;letter-spacing:.13em;text-transform:uppercase;opacity:.66;color:#6b533a;margin-bottom:6px;'>Tasks in scope</div>\n        <div style='font:600 11px/1.35 system-ui,sans-serif;color:#23160a;white-space:pre-wrap;max-height:8.4em;overflow:auto;'>{{data.taskListText}}</div>\n      </div>\n      <div style='padding:10px 12px;border-radius:12px;background:rgba(255,255,255,.72);border:1px solid rgba(0,0,0,.06);min-height:0;'>\n        <div style='font:700 10px system-ui,sans-serif;letter-spacing:.13em;text-transform:uppercase;opacity:.66;color:#6b533a;margin-bottom:6px;'>Open questions</div>\n        <div style='font:600 11px/1.35 system-ui,sans-serif;color:#23160a;white-space:pre-wrap;max-height:8.4em;overflow:auto;'>{{data.questionListText}}</div>\n      </div>\n    </div>\n  <div style='padding:0 16px 9px;font:600 9px system-ui,sans-serif;color:#6b7280;'>Updated {{data.updatedAt}}</div>\n</div>",
