      "data": {
        "body": "Turn Twilite media support into a deliberate workflow instead of a lucky collection of render paths. Images, embeds, and video should all have a clear authoring story.",
        "priority": "high",
        "status": "todo",
        "owner": "Michael",
        "successMetrics": [
          "A user can tell the difference between an asset and a presentation",
          "Image import feels intentional instead of accidental",
          "Video and embed support have a defined first-class path",
          "The onboarding tells agents how to produce correct media mutations"
        ],
