        },
        "definitionKey": "node-view",
        "isRoot": false,
        "root": false,
        "view": {
          "intent": "node",
          "payload": "node.web",
          "controlLayout": {
            "placement": "footer"
          },
          "html": {
            "chrome": true
          },
          "events": [
            {
              "id": "bootstrap-imported",
              "event": "graphDataImported",
              "when": {
                "path": "data.bootstrapState",
                "equals": "waiting"
              },
              "patch": {
                "bootstrapState": "imported",
                "stateLabel": "Handshake complete",
                "accentStart": "#b8f3d6",
                "accentEnd": "#2db784",
                "stateGlow": "rgba(45,183,132,.24)",
                "stageTitle": "Handshake complete",
                "stageBody": "The handshake has been completed. Explore any subject and make a graph about it, no matter how trivial.",
                "stageSummary": "Imported {{event.nodeCount}} nodes and {{event.edgeCount}} edges at {{now}}.",
                "bootstrapError": ""
              }
            }
          ],
          "controls": [
            {
              "id": "copy-bootstrap-prompt",
              "type": "button",
              "label": "Copy onboarding prompt",
              "variant": "contained",
              "priority": "high",
              "action": "copyToClipboard",
              "urlPath": "data.guideUrl",
              "successPatch": {
                "bootstrapState": "waiting",
                "stateLabel": "Prompt copied",
                "accentStart": "#ffe0b2",
                "accentEnd": "#ff8a50",
                "stateGlow": "rgba(255,138,80,.28)",
                "stageTitle": "Paste into the chatbot",
                "stageBody": "The onboarding prompt is on the clipboard. Paste it into the chatbot, talk for a bit, then paste the returned handshake reply here.",
                "stageSummary": "Next: paste the returned transaction into this node.",
                "bootstrapError": ""
              }
            },
            {
              "id": "paste-bootstrap-reply",
              "type": "button",
              "label": "Paste handshake reply",
              "variant": "outlined",
              "priority": "normal",
              "action": "pasteGraphData"
            }
          ]
        },
        "node": {
          "web": {
            "html": "<div style='width:100%;height:100%;display:flex;flex-direction:column;box-sizing:border-box;padding:0;overflow:hidden;border-radius:20px;background:linear-gradient(180deg, rgba(255,250,244,.98), rgba(255,241,230,.95));color:#2b180f;position:relative;'>\n  <div style='position:absolute;inset:0;background:radial-gradient(circle at top right, {{data.stateGlow}} 0%, rgba(255,255,255,0) 46%);pointer-events:none;'></div>\n  <div style='position:absolute;top:0;left:0;right:0;height:6px;background:linear-gradient(90deg, {{data.accentStart}}, {{data.accentEnd}});'></div>\n  <div style='display:flex;align-items:flex-start;justify-content:space-between;gap:12px;padding:48px 18px 14px 18px;border-bottom:1px solid rgba(60,30,12,.08);'>\n    <div style='display:flex;align-items:flex-start;gap:12px;min-width:0;'>\n      <div style='width:38px;height:38px;border-radius:14px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg, {{data.accentStart}}, {{data.accentEnd}});box-shadow:0 10px 24px rgba(0,0,0,.12);color:#2b180f;font:900 16px system-ui,sans-serif;flex:0 0 auto;'>*</div>\n      <div style='min-width:0;'>\n        <div style='font:700 10px system-ui,sans-serif;letter-spacing:.18em;text-transform:uppercase;opacity:.62;margin-bottom:4px;'>Bootstrap handshake</div>\n        <div style='font:800 22px/1.02 Georgia, \"Times New Roman\", serif;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;'>{{data.stageTitle}}</div>\n      </div>\n    </div>\n    <div style='display:inline-flex;align-items:center;justify-content:center;padding:7px 11px;border-radius:999px;background:rgba(255,255,255,.66);border:1px solid rgba(60,30,12,.10);font:700 10px system-ui,sans-serif;letter-spacing:.08em;text-transform:uppercase;white-space:nowrap;box-shadow:0 6px 18px rgba(0,0,0,.06);'>{{data.stateLabel}}</div>\n  </div>\n  <div style='display:flex;flex-direction:column;gap:14px;padding:16px 18px 18px 18px;min-height:0;flex:1;'>\n    <div style='padding:14px 15px;border-radius:16px;background:rgba(255,255,255,.72);border:1px solid rgba(60,30,12,.08);box-shadow:0 12px 24px rgba(93,54,24,.06);'>\n      <div style='font:700 10px system-ui,sans-serif;letter-spacing:.16em;text-transform:uppercase;opacity:.58;margin-bottom:8px;'>What happens now</div>\n      <div style='font:600 14px/1.5 system-ui,sans-serif;color:#2b180f;'>{{data.stageBody}}</div>\n    </div>\n    <div style='display:grid;grid-template-columns:minmax(0,1fr);gap:10px;'>\n      <div style='display:flex;align-items:center;gap:8px;flex-wrap:wrap;'>\n        <div style='padding:5px 9px;border-radius:999px;background:rgba(60,30,12,.05);border:1px solid rgba(60,30,12,.08);font:700 10px system-ui,sans-serif;'>Graph-native</div>\n        <div style='padding:5px 9px;border-radius:999px;background:rgba(60,30,12,.05);border:1px solid rgba(60,30,12,.08);font:700 10px system-ui,sans-serif;'>Clipboard handshake</div>\n        <div style='padding:5px 9px;border-radius:999px;background:rgba(60,30,12,.05);border:1px solid rgba(60,30,12,.08);font:700 10px system-ui,sans-serif;'>Additive transaction</div>\n      </div>\n      <div style='padding:12px 13px;border-radius:14px;background:linear-gradient(180deg, rgba(255,255,255,.76), rgba(255,248,242,.64));border:1px solid rgba(60,30,12,.08);'>\n        <div style='font:700 10px system-ui,sans-serif;letter-spacing:.14em;text-transform:uppercase;opacity:.58;margin-bottom:6px;'>Status</div>\n        <div style='font:600 12px/1.45 system-ui,sans-serif;white-space:pre-wrap;color:#5a3828;'>{{data.stageSummary}}</div>\n      </div>\n    </div>\n  </div>\n</div>"
          }
        }
      }
    },
