                    "accentEnd": "#ff7a45",
                    "stateGlow": "rgba(255,122,69,.22)",
                    "stageTitle": "Bootstrap handshake",
                    "stageBody": "Copy the onboarding prompt to begin the graph-native handshake.",
                    "stageSummary": "Paste the returned transaction back into this node when ready.",
                    "bootstrapError": ""
                  },
                  "waiting": {
                    "stateLabel": "Prompt copied",
                    "accentStart": "#ffe0b2",
                    "accentEnd": "#ff8a50",
                    "stateGlow": "rgba(255,138,80,.28)",
                    "stageTitle": "Paste into the chatbot",
                    "stageBody": "The onboarding prompt is on the clipboard. Paste it into the chatbot, talk for a bit, then paste the returned handshake reply here.",
                    "stageSummary": "Next: paste the returned transaction into this node.",
                    "bootstrapError": ""
                  },
                  "imported": {
                    "stateLabel": "Handshake complete",
                    "accentStart": "#b8f3d6",
                    "accentEnd": "#2db784",
                    "stateGlow": "rgba(45,183,132,.24)",
                    "stageTitle": "Handshake complete",
                    "stageBody": "The handshake has been completed. Explore any subject and make a graph about it, no matter how trivial.",
                    "stageSummary": "Imported graph data has been applied to the current graph.",
                    "bootstrapError": ""
                  }
                },
                "options": [
                  {
                    "label": "Idle",
                    "value": "idle"
                  },
                  {
                    "label": "Waiting",
                    "value": "waiting"
                  },
                  {
                    "label": "Imported",
                    "value": "imported"
                  }
                ]
              }
            ]
          }
        }
