    {
      "id": "launch-content-outline-what-is-twilite",
      "type": "markdown",
      "label": "What Is Twilite Outline",
      "root": false,
      "position": {
        "x": -300,
        "y": 1040
      },
      "width": 380,
      "height": 320,
      "handles": [
