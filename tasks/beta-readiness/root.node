    {
      "id": "beta-readiness-task-persistence",
      "type": "task",
      "label": "Clarify save and export behavior",
      "position": {
        "x": 699.5,
        "y": 605
      },
      "width": 360,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Make save, export, and overwrite behavior obvious, predictable, and safe for beta users. If a user opens a graph that already exists locally, saving it back to that local file should be an obvious first-class action rather than an implied export-and-overwrite workflow.",
        "priority": "high",
        "status": "done",
        "owner": "Michael",
        "estimateHours": "6",
        "acceptanceCriteria": [
          "Save and export behavior are obvious",
          "Local file overwrite/save-back behavior is explicit for graphs opened from disk",
          "Fragment-scoped behavior is predictable",
          "Beta users can avoid accidental data loss"
        ],
        "resolutionPath": "Added an explicit Save As / Re-root path in the toolbar so save-to-current-root and choose-a-new-root are distinct, while preserving the existing GitHub/local destination flow.",
