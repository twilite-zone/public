    {
      "id": "beta-readiness-task-classes",
      "type": "task",
      "label": "Polish class-system defaults",
      "position": {
        "x": 2259.5,
        "y": 1025
      },
      "width": 380,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Improve class authoring diagnostics, shared view tokens, and a small set of exemplar libraries so class-backed content feels reliable. This has moved forward: the graph theme is now class-backed with a hosted rich editor block instead of deepening a native node path. Remaining work is broader polish across the class system, especially diagnostics, shared conventions, and exemplar libraries beyond the theme-node case.",
        "priority": "high",
        "status": "in-progress",
        "owner": "Michael",
        "estimateHours": "8",
        "acceptanceCriteria": [
          "Class authoring diagnostics improve",
          "Shared view tokens are clearer",
          "Exemplar libraries feel reliable"
        ],
        "implementationNotes": [
          "Theme node authority now uses a real class-backed node path",
          "Dynamic views can host a richer sanctioned editor block where needed",
          "The broader class-system cleanup still needs to spread that rigor across more classes and tooling"
        ],
