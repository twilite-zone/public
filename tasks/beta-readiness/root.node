    {
      "id": "beta-readiness-task-typography",
      "type": "task",
      "label": "Establish a real typography system",
      "position": {
        "x": 258.5,
        "y": 155
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Replace the current ad hoc default-font situation with a deliberate typography system. Shared type roles now exist, browser and graph theme scopes are separated, graph surfaces can inherit browser typography by fallback, and theme-node authority is now on the right path. Remaining work is rollout: apply the shared roles across more graph-authored surfaces and clean up the remaining hardcoded local typography decisions. This is no longer treated as a beta blocker; it remains planned follow-up work unless a concrete readability issue forces it back into scope.",
        "priority": "medium",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "6",
        "countAsTask": false,
        "memo": "Removed from the counted beta-critical path. Keep visible as planned follow-up work.",
        "acceptanceCriteria": [
          "Primary UI typography is chosen intentionally",
          "Base font size and type scale are easy to control",
          "Graph/editor surfaces stop relying on accidental defaults",
          "Typography feels acceptable on Windows in normal use"
        ],
        "implementationNotes": [
          "Shared typography roles now exist in the theme layer",
          "Browser and graph theme scopes are explicitly separated",
          "Theme-node-based graph theming now gives typography a real graph-owned authority path"
