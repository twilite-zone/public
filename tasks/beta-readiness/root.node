    {
      "id": "beta-readiness-summary-task",
      "type": "task",
      "label": "Ship a credible beta release",
      "position": {
        "x": 2660.5,
        "y": 25
      },
      "width": 380,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Goal: Ship a credible beta release\nStatus: in-progress\n\nTasks in scope:\n1. Complete GitHub App migration\n2. Make diagnostics durable and attributable\n3. Stabilize layout and expansion placement\n4. Fix erratic mouse cursor mode switching\n5. Make layout controls feel correct and usable\n6. Build a beta onboarding path\n7. Polish class-system defaults\n8. Clarify save and export behavior\n\nOpen questions:\n1. What is the minimum acceptable onboarding path?",
        "status": "in-progress",
        "owner": "Michael",
        "priority": "critical",
        "estimateHours": "10",
        "acceptanceCriteria": [
          "PAT-based auth is replaced by the GitHub App path",
          "Repo flows still work during rollout",
          "Failure states are clear",
          "Expired user sessions recover cleanly or fail clearly after long-tail testing"
        ],
        "title": "Ship a credible beta release",
