    {
      "id": "beta-readiness-question",
      "type": "open-question",
      "label": "What is the minimum acceptable onboarding path?",
      "position": {
        "x": 2439.5,
        "y": 135
      },
      "width": 420,
      "height": 300,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Define the shortest path from first load to a successful graph interaction for a new beta user.",
        "status": "answered",
        "owner": "Michael",
        "resolutionPath": "Use the handshake-graph onboarding flow: copy bootstrap instructions from the landing surface, paste them into the LLM, then paste the returned additive transaction/handshake graph back into Twilite so the conversation proceeds from a real graph artifact.",
