    {
      "id": "beta-readiness-task-layout-controls",
      "type": "task",
      "label": "Make layout controls feel correct and usable",
      "position": {
        "x": 1179.5,
        "y": 1025
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Refine the layout controls so users can understand what each layout mode does, apply it confidently, and get predictable results. The toolbar/radial/rail authority model is now much cleaner: selection actions were separated from view controls, dead grid actions were repaired, the radial menu was reduced toward shortcut-only status, and the side drawers now sit correctly under the browser bar. Remaining work is deciding whether the current Legend framing is sufficient and whether any final layout-control language cleanup is still needed for beta.",
        "priority": "high",
        "status": "in-progress",
        "owner": "Michael",
        "estimateHours": "6",
        "acceptanceCriteria": [
          "Layout controls are easy to understand",
          "Applying a layout produces predictable results",
          "The controls feel coherent with the rest of the editor"
        ],
        "implementationNotes": [
          "View and selection actions are now separated in the toolbar",
          "Align to Grid is live and grouped with selection layout actions",
          "The radial menu now behaves more like a shortcut surface than a second editor authority"
        ],
