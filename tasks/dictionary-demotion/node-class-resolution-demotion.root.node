    {
      "id": "node-class-resolution-demotion-summary-updater",
      "type": "script",
      "label": "Summary Updater",
      "position": {
        "x": 115,
        "y": -805
      },
      "width": 420,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "mode": "auto",
        "status": "idle",
        "scriptRef": "",
        "source": "const SUMMARY_NODE_ID = 'node-class-resolution-demotion-summary';\nconst DONE_TASK_STATUSES = new Set(['done', 'complete', 'completed', 'closed']);\nconst ANSWERED_STATUSES = new Set(['answered', 'done', 'resolved', 'closed']);\nconst normalize = (value) => String(value || '').trim().toLowerCase();\nconst toTitle = (entry, fallback) => String(entry?.label || entry?.data?.summary || entry?.data?.body || fallback || '').trim();\nconst toListText = (items, emptyLabel, maxItems = 4) => {\n  const visible = items.filter(Boolean).slice(0, maxItems);\n  if (!visible.length) return emptyLabel;\n  return visible.map((item, index) => `${index + 1}. ${item}`).join('\\n');\n};\n\nconst nodes = await api.getNodes();\nconst summaryNode = nodes.find((entry) => entry?.id === SUMMARY_NODE_ID);\nif (!summaryNode) {\n  return { success: false, error: 'Summary node missing' };\n}\n\nconst goalNode = nodes.find((entry) => entry?.type === 'goal');\nconst tasks = nodes.filter((entry) => entry?.type === 'task');\nconst questions = nodes.filter((entry) => entry?.type === 'open-question');\nconst taskTitles = tasks.map((entry) => toTitle(entry, 'Untitled task')).filter(Boolean);\nconst questionTitles = questions.map((entry) => toTitle(entry, 'Untitled question')).filter(Boolean);\n\nconst nextData = {\n  ...(summaryNode.data || {}),\n  goal: goalNode?.label || summaryNode?.data?.goal || 'Task graph',\n  status: goalNode?.data?.status || (tasks.length > 0 && tasks.every((entry) => DONE_TASK_STATUSES.has(normalize(entry?.data?.status))) ? 'done' : (summaryNode?.data?.status || 'todo')),\n  taskProgress: {\n    completed: tasks.filter((entry) => DONE_TASK_STATUSES.has(normalize(entry?.data?.status))).length,\n    total: tasks.length\n  },\n  questionProgress: {\n    answered: questions.filter((entry) => ANSWERED_STATUSES.has(normalize(entry?.data?.status))).length,\n    total: questions.length\n  },\n  taskTitles,\n  questionTitles,\n  taskListText: toListText(taskTitles, 'No tasks listed.'),\n  questionListText: toListText(questionTitles, 'No open questions.'),\n  summarySource: 'graph-updater',\n  updatedAt: new Date().toISOString()\n};\n\nawait api.updateNode(SUMMARY_NODE_ID, { data: nextData });\nreturn { success: true, summary: nextData };",
        "summaryNodeId": "node-class-resolution-demotion-summary",
        "autoRun": true,
        "autoRunOnGraphChange": true,
        "description": "Keep the Node/Class Resolution Demotion summary node in sync with the planning graph.",
        "_semanticLevel": "detail",
        "scriptId": "",
        "allowMutations": false,
        "dryRun": false,
        "lastResult": {
          "type": "scriptResult",
          "success": true,
          "result": {
            "success": true,
            "summary": {
              "goal": "Make node/class resolution graph-native without losing robustness",
              "status": "in-progress",
              "taskProgress": {
                "completed": 0,
                "total": 4
              },
              "questionProgress": {
                "answered": 0,
                "total": 1
              },
              "summarySource": "graph-updater",
              "taskTitles": [
                "Audit every dictionary-backed node/view resolution path",
                "Define the graph-native class resolution contract",
                "Replace node-class bridge registration into host dictionaries",
                "Preserve selectors, editor views, and validation during the transition"
              ],
              "questionTitles": [
                "What minimum support surface still survives for discovery?"
              ],
              "taskListText": "1. Audit every dictionary-backed node/view resolution path\n2. Define the graph-native class resolution contract\n3. Replace node-class bridge registration into host dictionaries\n4. Preserve selectors, editor views, and validation during the transition",
              "questionListText": "1. What minimum support surface still survives for discovery?",
              "updatedAt": "2026-03-23T19:11:16.237Z"
            }
