    {
      "id": "node-class-resolution-demotion-overview",
      "type": "markdown",
      "label": "Node/Class Resolution Demotion",
      "position": {
        "x": -985,
        "y": 1030
      },
      "width": 520,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Node/Class Resolution Demotion\n\nThis is the real residue in dictionary demotion.\n\nToday, node rendering, editor views, validation, selectors, and node-class bridging still lean on dictionary `nodeDefs` and `views`. This graph tracks the work to replace that with graph-native class and bridge resolution without losing reliability.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "ref": "/library/classes/nodes/markdown.node-class.node",
