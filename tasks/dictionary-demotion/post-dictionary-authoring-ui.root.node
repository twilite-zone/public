    {
      "id": "post-dictionary-authoring-ui-summary-updater",
      "type": "script",
      "label": "Summary Updater",
      "position": {
        "x": -260,
        "y": 620
      },
      "width": 420,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "mode": "auto",
        "status": "idle",
        "scriptRef": "",
        "source": "const SUMMARY_NODE_ID = 'post-dictionary-authoring-ui-summary';\nconst DONE_TASK_STATUSES = new Set(['done', 'complete', 'completed', 'closed']);\nconst ANSWERED_STATUSES = new Set(['answered', 'done', 'resolved', 'closed']);\nconst normalize = (value) => String(value || '').trim().toLowerCase();\nconst toTitle = (entry, fallback) => String(entry?.label || entry?.data?.summary || entry?.data?.body || fallback || '').trim();\nconst toListText = (items, emptyLabel, maxItems = 4) => {\n  const visible = items.filter(Boolean).slice(0, maxItems);\n  if (!visible.length) return emptyLabel;\n  return visible.map((item, index) => `${index + 1}. ${item}`).join('\\n');\n};\n\nconst nodes = await api.getNodes();\nconst summaryNode = nodes.find((entry) => entry?.id === SUMMARY_NODE_ID);\nif (!summaryNode) {\n  return { success: false, error: 'Summary node missing' };\n}\n\nconst goalNode = nodes.find((entry) => entry?.type === 'goal');\nconst tasks = nodes.filter((entry) => entry?.type === 'task');\nconst questions = nodes.filter((entry) => entry?.type === 'open-question');\nconst taskTitles = tasks.map((entry) => toTitle(entry, 'Untitled task')).filter(Boolean);\nconst questionTitles = questions.map((entry) => toTitle(entry, 'Untitled question')).filter(Boolean);\n\nconst nextData = {\n  ...(summaryNode.data || {}),\n  goal: goalNode?.label || summaryNode?.data?.goal || 'Task graph',\n  status: goalNode?.data?.status || (tasks.length > 0 && tasks.every((entry) => DONE_TASK_STATUSES.has(normalize(entry?.data?.status))) ? 'done' : (summaryNode?.data?.status || 'todo')),\n  taskProgress: {\n    completed: tasks.filter((entry) => DONE_TASK_STATUSES.has(normalize(entry?.data?.status))).length,\n    total: tasks.length\n  },\n  questionProgress: {\n    answered: questions.filter((entry) => ANSWERED_STATUSES.has(normalize(entry?.data?.status))).length,\n    total: questions.length\n  },\n  taskTitles,\n  questionTitles,\n  taskListText: toListText(taskTitles, 'No tasks listed.'),\n  questionListText: toListText(questionTitles, 'No open questions.'),\n  summarySource: 'graph-updater',\n  updatedAt: new Date().toISOString()\n};\n\nawait api.updateNode(SUMMARY_NODE_ID, { data: nextData });\nreturn { success: true, summary: nextData };",
        "summaryNodeId": "post-dictionary-authoring-ui-summary",
        "autoRun": true,
        "autoRunOnGraphChange": true,
        "description": "Keep the Post-Dictionary Authoring UI summary node in sync with the planning graph.",
        "_semanticLevel": "detail",
        "scriptId": "",
        "allowMutations": false,
        "dryRun": false,
        "lastResult": {
          "type": "scriptResult",
          "success": true,
          "result": {
            "success": true,
            "summary": {
              "goal": "Make the authoring UI match the post-dictionary model",
              "status": "todo",
              "taskProgress": {
                "completed": 0,
                "total": 4
              },
              "questionProgress": {
                "answered": 0,
                "total": 1
              },
              "summarySource": "graph-updater",
              "taskTitles": [
                "Replace add-node-first creation with class/bridge-first flows",
                "Make generic edge creation draw from legend-visible edge classes",
                "Expose class meaning, provenance, and overrides in selection UI",
                "Keep old authoring surfaces usable during the transition"
              ],
              "questionTitles": [
                "What is the smallest honest creation UI?"
              ],
              "taskListText": "1. Replace add-node-first creation with class/bridge-first flows\n2. Make generic edge creation draw from legend-visible edge classes\n3. Expose class meaning, provenance, and overrides in selection UI\n4. Keep old authoring surfaces usable during the transition",
              "questionListText": "1. What is the smallest honest creation UI?",
              "updatedAt": "2026-03-23T21:26:13.081Z"
            }
