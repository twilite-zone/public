    {
      "id": "class-bridge-first-creation-flow-recommended",
      "type": "decision",
      "label": "Recommended: Creation Tray",
      "position": {
        "x": -140,
        "y": 220
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "A small creation tray becomes the first honest bridge/class-first entry point.",
        "rationale": "Recommended first flow:\n- one Create button or hotkey opens a tray\n- tray shows graph-visible node classes and bridge sources first\n- generic nodes move to a lower fallback section\n- after drawing a generic edge, a small chooser offers legend-visible edge classes\n- selection inspector shows class source, semantic meaning, and local overrides\n\nWhy this wins:\n- concrete enough to build now\n- central enough to replace add-node-first thinking\n- small enough to coexist with older UI during transition",
        "_classBinding": {
          "key": "decision",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/decision.node-class.node",
