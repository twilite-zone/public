    {
      "id": "class-bridge-first-creation-flow-decision-bridge-cluster",
      "type": "decision",
      "label": "Bridge Cluster Is Creation Vocabulary",
      "position": {
        "x": 1260,
        "y": 560
      },
      "width": 440,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "The visible cluster of bridge nodes is the primary source for node creation vocabulary.",
        "rationale": "If a graph wants to expose creation options, it should do so structurally and visibly.\n\nThat means:\n- the create tray reads from the bridge cluster first\n- the bridge cluster teaches the local creation language\n- hidden palette authority stops being the primary answer to `what can I make here?`\n\nIf no relevant bridge cluster is present, the UI can fall back to plain node creation.",
        "_classBinding": {
