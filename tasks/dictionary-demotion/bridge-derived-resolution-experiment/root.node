    {
      "id": "bridge-derived-resolution-experiment-task-1",
      "type": "task",
      "label": "Audit where runtime still reads dictionary nodes",
      "position": {
        "x": 320,
        "y": 300
      },
      "width": 430,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Audit where runtime still reads dictionary nodes",
        "body": "Current dictionary authority paths are now audited. The live runtime still treats dictionary nodes as primary truth in four places: (1) `GraphCrud.resolveNodeClassEntry()` for non-builtin creation defaults, (2) `GraphEditorContent.resolveNodeClassContract()` as the fallback node/editor view resolver when `_classBinding` is absent, (3) the host `resolvedDictionary` loader/merger in `GraphEditorContent` that imports `nodeDefs`, `views`, and `skills` from dictionary refs, and (4) `validateGraphInvariants()` which resolves node and view entries from dictionary data during validation.",
        "status": "done",
        "owner": "Michael",
        "priority": "high",
        "estimateHours": "2",
        "_classBinding": {
          "key": "task",
          "sourceRef": "/library/classes/nodes/task-planning/task.node-class.node",
