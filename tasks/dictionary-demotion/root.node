    {
      "id": "dict-demotion-question",
      "type": "open-question",
      "label": "What minimal declaration surface still needs to survive?",
      "position": {
        "x": 1140,
        "y": 340
      },
      "width": 380,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "If the dictionary object disappears, what explicit local surface still remains for lookup, defaults, and resolvable graph vocabulary?",
        "status": "answered",
        "owner": "Michael",
        "resolutionPath": "Defaults should mostly move to class artifacts. Reference and connection already belong to ports and bridges. Semantic meaning belongs to classes. Any remaining support should be kept only if it cannot live more honestly on classes, manifests, or structure.",
