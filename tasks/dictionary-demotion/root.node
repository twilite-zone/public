    {
      "id": "dict-demotion-task-resolution",
      "type": "task",
      "label": "Separate lookup and defaults from authority",
      "position": {
        "x": 260,
        "y": 340
      },
      "width": 360,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
