    {
      "id": "dict-demotion-decision",
      "type": "decision",
      "label": "Structure and explicit class artifacts should outrank dictionary registration",
      "position": {
        "x": 320,
        "y": -20
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
