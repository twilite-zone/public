    {
      "id": "mobile-graph-overview",
      "type": "markdown",
      "label": "Mobile Graph Authoring",
      "position": {
        "x": -80,
        "y": -140
      },
      "visible": true,
      "showLabel": true,
      "width": 540,
      "height": 240,
      "data": {
        "markdown": "# Mobile Graph Authoring\n\nTreat mobile as a graph composer, not a precision graph sculptor. The user expresses intent; the system handles much more of layout, spacing, and connection management.",
        "memo": "",
        "link": ""
      }
    },
    {
      "id": "mobile-graph-goal",
      "type": "goal",
      "label": "Make Twilite feel native on mobile",
      "position": {
        "x": 540,
        "y": -140
      },
      "visible": true,
      "showLabel": true,
      "width": 380,
      "height": 220,
      "data": {
        "body": "Design a mobile interaction model where graph authorship feels natural with fingers, reduced precision, and smaller screens.",
        "priority": "high",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "8",
        "acceptanceCriteria": [
          "Mobile authoring does not rely on pixel-precise dragging",
          "Users can express structure and behavior quickly",
          "The resulting graph still feels like Twilite, not a crippled sidecar"
        ],
