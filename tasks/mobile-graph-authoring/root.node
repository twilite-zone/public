      "data": {
        "memo": "Create decision nodes in this focused graph.",
        "intent": "external",
        "authority": "bridge",
        "resourceKind": "node-class",
        "scope": "focused-graph",
        "grants": [
          "create"
        ],
        "target": {
          "mode": "bridge",
          "label": "Create",
          "kind": "node-class",
          "key": "decision",
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/decision.node-class.node",
          "resourceKind": "node-class",
          "scope": "focused-graph",
          "grants": [
            "create"
          ],
          "meaning": "Recorded, timestamped choice for planning graphs."
        },
        "bridge": {
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/decision.node-class.node",
