    {
      "id": "github-app-task-overview",
      "type": "markdown",
      "label": "GitHub App Migration",
      "position": {
        "x": -250,
        "y": -40
      },
      "width": 500,
      "height": 230,
      "visible": true,
      "showLabel": true,
      "color": "#1976d2",
