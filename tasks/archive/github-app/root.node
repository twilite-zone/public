    {
      "id": "github-app-decision",
      "type": "decision",
      "label": "GitHub App + user sign-in is the primary auth model",
      "position": {
        "x": 1180,
        "y": -80
      },
      "width": 360,
      "height": 270,
      "visible": true,
      "showLabel": true,
      "data": {
        "rationale": "The browser should not hold long-lived GitHub credentials. GitHub login identifies the user, the app installation defines repo scope, and server-side token exchange keeps privileged operations off the client.",
