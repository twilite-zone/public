          "direction": "output",
          "dataType": "content",
          "position": {
            "side": "right",
            "offset": 0.5
          }
        }
      ],
      "data": {
        "markdown": "# GitHub App Migration\n\nReplace the GitHub Personal Access Token flow with a Twilite GitHub App backed by server-side auth.\n\nImplementation policy now:\n- GitHub login identifies the user\n- GitHub App installation defines repo scope\n- public reads continue to work\n- repo picker and manual repo/path entry must both work\n- PAT is removed rather than retained as a fallback write path",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": true,
        "root": true,
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
