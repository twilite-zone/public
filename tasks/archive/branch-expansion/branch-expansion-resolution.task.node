            "offset": 0.5
          }
        },
        {
          "id": "out",
          "label": "Out",
          "direction": "output",
          "dataType": "any",
          "position": {
            "side": "right",
            "offset": 0.5
          }
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "## Key Tradeoffs\n\n1. ID collisions during fragment merge\n- Need deterministic remap/namespace strategy.\n\n2. Duplicate expansion\n- Same ref must not duplicate branch on repeated expand.\n\n3. Collapse reversibility\n- Need provenance tags (`expansionId`, `sourceRef`, `injectedBy`).\n\n4. Contract conflicts\n- Fragment manifest/dictionary can conflict with host rules.\n\n5. Performance\n- Expansion should be transaction-based and incremental, not full rerender.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "ref": "/library/classes/nodes/markdown.node-class.node",
          "identity": {
            "graphId": "markdown_class",
            "name": "markdown Node Class",
            "version": "0.1.0",
            "description": "Canonical markdown content node.",
            "createdAt": "2026-02-24T20:05:15Z",
            "updatedAt": "2026-03-24T01:20:00.000Z"
          },
          "intent": "graph",
          "meaning": "Canonical markdown content node.",
          "description": "Canonical markdown content node.",
          "defaults": {},
          "nodeDef": {
