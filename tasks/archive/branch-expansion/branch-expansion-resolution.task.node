    {
      "id": "task-expansion-scope",
      "type": "markdown",
      "label": "Expansion Scope (One Hop)",
      "position": {
        "x": 3473.166666666667,
        "y": -557.2463113334816
      },
      "width": 560,
      "height": 330,
      "ports": [
        {
