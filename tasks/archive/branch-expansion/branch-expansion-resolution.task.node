      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Branch Expansion From Port/Reference\n\nStatus: complete for this phase.\n\nBranch expansion now supports in-place projection from `port` and `graph-reference` nodes without transferring host authority. Fragments and full graph documents can expand into the current host session, and persistence is fragment-scoped.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "ref": "/library/classes/nodes/markdown.node-class.node",
