            "side": "right",
            "offset": 0.5
          }
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Expansion Contract (Current Runtime)\n\nHost capability:\n\n`graph.expandReference(payload)`\n\n```json\n{\n  \"sourceNodeId\": \"node-123\",\n  \"target\": {\n    \"kind\": \"graph\",\n    \"ref\": \"github://twilite-zone/public/tasks/archive/script-scope/root.node\",\n    \"entryPort\": \"root\",\n    \"mode\": \"expand\"\n  }\n}\n```\n\nCurrent behavior:\n- resolves the target graph or fragment\n- runs compatibility assessment\n- projects the target into the current host session\n- downgrades manifest/dictionary/execution surfaces instead of transferring authority\n- tags injected entities with expansion provenance\n- supports collapse and focused-fragment refresh",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "ref": "/library/classes/nodes/markdown.node-class.node",
          "identity": {
