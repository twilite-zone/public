          }
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "## Done Means\n\n- Expanding a target adds a branch exactly once per expansion key.\n- Collapse removes only the injected branch.\n- `navigate` replaces the host session.\n- `expand` preserves the host session for fragments and full graph documents.\n- imported execution remains blocked or downgraded unless authority later moves there.\n- behavior is deterministic across refresh/reload.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "ref": "/library/classes/nodes/markdown.node-class.node",
          "identity": {
