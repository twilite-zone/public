            "side": "right",
            "offset": 0.5
          }
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "## Phase Plan\n\n### Phase 1: Contract + Normalizer\n- Normalize target fields on `port` and `graph-reference`.\n- Enforce `kind/mode` combinations.\n\n### Phase 2: Expansion Transaction\n- Resolve fragment, validate, remap IDs, attach root edge.\n- Tag all injected entities with `expansionId`.\n\n### Phase 3: Collapse\n- Remove injected entities by `expansionId`.\n- Preserve host-authored nodes/edges.\n\n### Phase 4: UX\n- Add Expand/Collapse controls and status badges.\n- Show explicit errors for invalid target contracts.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "ref": "/library/classes/nodes/markdown.node-class.node",
          "identity": {
