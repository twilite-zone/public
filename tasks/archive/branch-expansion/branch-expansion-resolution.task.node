    {
      "id": "task-tradeoffs",
      "type": "markdown",
      "label": "Tradeoffs & Risks",
      "position": {
        "x": 2313.833333333333,
        "y": -1117.2463113334816
      },
      "width": 540,
      "height": 360,
      "ports": [
        {
          "id": "in",
