    {
      "id": "task-expansion-contract",
      "type": "markdown",
      "label": "Expansion Contract (UI + AI)",
      "position": {
        "x": 3786.166666666667,
        "y": 1082.7536886665184
      },
      "width": 760,
      "height": 540,
      "ports": [
        {
          "id": "in",
