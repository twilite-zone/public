    {
      "id": "context-compat-overview",
      "type": "markdown",
      "label": "Problem Statement",
      "position": {
        "x": 0,
        "y": -180
      },
      "width": 460,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Context Compatibility\n\nA target graph should be inspected before `expand` so Twilite can determine whether it is compatible, compatible with downgrades, or incompatible with the host context.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
