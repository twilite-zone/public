          "type": "flow"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Authority Policy\n\nCurrent runtime stance:\n- host session owns the shared structure\n- focused fragment owns execution/reload authority inside that session\n- imported manifest authority remains informational / host-primary during expansion\n- non-fragment navigation is where document/session authority should reset\n\nThis is now partly real in runtime and should be treated as the authoritative default.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false,
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
