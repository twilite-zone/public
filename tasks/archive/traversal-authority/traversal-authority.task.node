    {
      "id": "trav-authority",
      "type": "markdown",
      "label": "Authority Policy",
      "position": {
        "x": 320,
        "y": -40
      },
      "width": 360,
      "height": 210,
      "color": "#8e24aa",
      "ports": [
        {
          "id": "in",
          "label": "In",
          "direction": "input",
          "dataType": "flow",
          "position": {
