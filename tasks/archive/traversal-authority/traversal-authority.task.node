      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Traversal And Authority\n\nStatus: complete for this phase.\n\nTwilite now has explicit runtime semantics for traversal, authority, and host/session boundaries. `navigate`, `expand`, and `focus` now behave as distinct runtime operations instead of blurred UI conventions.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": true,
        "root": true,
        "_classBinding": {
