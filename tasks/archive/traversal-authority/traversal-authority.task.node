          }
        },
        {
          "id": "out",
          "label": "Out",
          "direction": "output",
          "dataType": "content",
          "position": {
            "side": "right",
            "offset": 0.5
          }
        }
      ],
      "inputs": [
        {
          "key": "in",
          "label": "In",
          "type": "flow"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Traversal Policy\n\nCurrent rule to implement explicitly:\n- `navigate` changes the document/session host\n- `expand` keeps the same host session and materializes a fragment in place\n- `focus` moves execution authority inside that session\n\nWhat is already true:\n- ring-based loading bounds growth\n- expanded fragments can coexist structurally\n- browser address display can follow focused fragment without replacing the host session",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false,
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
