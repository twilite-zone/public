          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Capability Policy\n\nCurrent rule:\n- showing a node is not the same as running a node\n- scripts are already scoped to the active fragment\n- focused-fragment reload is scoped locally\n- static rendering can remain broad while live behavior stays local\n\nRemaining capability glue should follow this rule rather than reintroducing ambient power.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false,
        "_classBinding": {
