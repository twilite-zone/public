    {
      "id": "trav-traversal",
      "type": "markdown",
      "label": "Traversal Policy",
      "position": {
        "x": -120,
        "y": -40
      },
      "width": 360,
      "height": 210,
      "color": "#5e35b1",
      "ports": [
        {
          "id": "in",
          "label": "In",
          "direction": "input",
          "dataType": "flow",
          "position": {
            "side": "left",
