          "type": "flow"
        }
      ],
      "outputs": [
        {
          "key": "out",
          "label": "Out",
          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Avoid Baking In\n\nStill avoid:\n- ambient global execution assumptions\n- silent authority merging across visible graphs\n- hooks firing everywhere because something is visible\n- letting address-bar display become destructive navigation\n- blurring `navigate`, `expand`, and `focus` back together",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false,
