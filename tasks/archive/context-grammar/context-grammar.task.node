        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Implications\n\nWith the current runtime:\n- `expand` means same host session for fragments and full graph documents\n- `navigate` means replace the host session\n- `bridge` means explicit capability within the current session\n- `boundary` means context metadata, not edge behavior\n\nThis layer is now real enough to treat `Context Grammar` as complete for this phase.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false,
