          "type": "content"
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Boundary (Context Property)\n\nBoundary is probably not an edge behavior. It is more naturally a region or fragment property:\n- it marks where one context stops and another begins\n- it lives at the perimeter of a fragment/domain\n- ports and bridges may cross it\n- but the boundary itself is not the crossing",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": false,
        "root": false,
