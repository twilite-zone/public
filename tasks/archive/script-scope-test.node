  "scripts": [
    {
      "id": "script-scope-probe-v1",
      "name": "Script Scope Probe",
      "tags": [
        "tasks",
        "test",
        "script-scope"
      ],
      "source": "const nodes = await api.getNodes();\nconst edges = await api.getEdges();\nconst groups = typeof api.getGroups === \"function\" ? await api.getGroups() : [];\n\nconst summary = {\n  success: true,\n  nodeCount: nodes.length,\n  edgeCount: edges.length,\n  groupCount: groups.length,\n  labels: nodes.map((node) => node.label || node.id)\n};\n\napi.log(\"info\", `Scope probe saw ${summary.nodeCount} node(s) and ${summary.edgeCount} edge(s).`);\n\nreturn summary;\n",
      "ref": "",
      "createdAt": "2026-03-16T13:05:00.000Z",
      "updatedAt": "2026-03-16T13:05:00.000Z"
    },
    {
      "id": "script-scope-foreign-read-v1",
      "name": "Foreign Read Rejection Test",
      "tags": [
        "tasks",
        "test",
        "script-scope"
      ],
      "source": "const foreignId = \"script-scope-test-target\";\ntry {\n  const node = await api.getNode(foreignId);\n  return { success: false, expected: \"scope-error\", got: node };\n} catch (error) {\n  return { success: true, expected: \"scope-error\", error: String(error) };\n}\n",
      "ref": "",
      "createdAt": "2026-03-16T15:20:00.000Z",
      "updatedAt": "2026-03-16T15:20:00.000Z"
    },
    {
      "id": "script-scope-foreign-mutation-v1",
      "name": "Foreign Mutation Rejection Test",
      "tags": [
        "tasks",
        "test",
        "script-scope"
      ],
      "source": "const foreignId = \"script-scope-test-target\";\ntry {\n  const result = await api.updateNode(foreignId, { data: { probe: \"should-fail\" } });\n  return { success: false, expected: \"scope-error\", got: result };\n} catch (error) {\n  return { success: true, expected: \"scope-error\", error: String(error) };\n}\n",
      "ref": "",
      "createdAt": "2026-03-16T15:20:00.000Z",
      "updatedAt": "2026-03-16T15:20:00.000Z"
    },
    {
      "id": "script-scope-create-local-v1",
      "name": "Create Local Fragment Node Test",
      "source": "const createdId = \"script-scope-created-probe\";\ntry {\n  const existing = await api.getNode(createdId).catch(() => null);\n  if (existing) {\n    return { success: true, reused: true, id: createdId, label: existing.label || createdId };\n  }\n  const created = await api.createNode({\n    id: createdId,\n    type: \"markdown\",\n    label: \"Created In Expanded Fragment\",\n    position: { x: 1880, y: 1240 },\n    width: 320,\n    height: 160,\n    data: {\n      markdown: \"# Created In Expanded Fragment\\n\\nThis node was created by the script-scope create test.\",\n      memo: \"\",\n      link: \"\",\n      html: \"\",\n      svg: \"\"\n    }\n  });\n  return { success: true, created: true, id: created.id, type: created.type };\n} catch (error) {\n  return { success: false, expected: \"create-in-focused-fragment\", error: String(error) };\n}\n"
    },
    {
      "id": "script-scope-created-read-v1",
      "name": "Read Created Node Rejection Test",
      "source": "const foreignId = \"script-scope-created-probe\";\ntry {\n  const node = await api.getNode(foreignId);\n  return { success: false, expected: \"scope-error\", got: node };\n} catch (error) {\n  return { success: true, expected: \"scope-error\", error: String(error) };\n}\n"
    }
