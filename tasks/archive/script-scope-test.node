      "data": {
        "markdown": "# Script Scope Test\n\nUse this graph to test that scripts only see and mutate the active fragment.\n\nSuggested checks:\n- run a script in the root fragment\n- expand into another fragment\n- verify out-of-scope reads and mutations fail in diagnostics",
        "memo": "",
        "link": "",
        "isRoot": true,
        "root": true,
