      "data": {
        "markdown": "# Local Fragment Reload\n\nImplemented:\n- Refresh targets the focused fragment source when focus is inside an expanded fragment.\n- Only that fragment is collapsed and rematerialized.\n- The rest of the visible graph stays intact.\n- Focus is restored to the previously focused node when possible, otherwise to the fragment entry/root.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
