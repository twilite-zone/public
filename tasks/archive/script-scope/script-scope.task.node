    {
      "id": "script-scope-why",
      "type": "markdown",
      "label": "Why This Matters",
      "position": {
        "x": -160,
        "y": -40
      },
      "width": 360,
      "height": 210,
      "color": "#8e24aa",
      "ports": [
        {
