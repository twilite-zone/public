      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Script Scope\n\nStatus: implemented and validated.\n\nScripts now see and mutate only the active fragment. The core script-scope boundary is real enough to support safer expansion and focus-scoped authority work.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
