      "data": {
        "body": "Define a stable copy/paste payload for graph elements:\n- node(s), edge(s), group(s)\n- preserve relative positions and IDs (with remap)\n- include minimal metadata for forward compatibility\n- support paste-at-cursor and paste-in-place\n",
        "priority": "high",
