      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Goal: Make edge semantics class-based\nStatus: in-progress\n\nTasks in scope:\n1. Audit current edge semantics\n2. Design edge-class contract\n3. Implement edge-class rendering path\n4. Add authoring and selection UX\n5. Handle migration and defaulting\n\nOpen questions:\n1. How much behavior belongs on an edge class?",
        "status": "in-progress",
        "owner": "Michael",
        "priority": "high",
        "estimateHours": "4",
        "acceptanceCriteria": [
          "Current edge semantic surface is documented"
        ],
