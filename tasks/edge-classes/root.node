      "id": "edge-classes-task-schema",
      "type": "task",
      "label": "Design edge-class v1 contract",
      "position": {
        "x": 420,
        "y": 330
      },
      "width": 340,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Define the narrow v1 edge-class contract so ordinary authoring has a real semantic authority. v1 should declare: key, label, meaning, usage guidance, source kinds, target kinds, default edge type, render defaults, legend role, and semantic authority. Do not include runtime execution behavior or arbitrary interaction logic in this pass.",
        "status": "in-progress",
        "owner": "Michael",
        "priority": "critical",
        "estimateHours": "6",
        "acceptanceCriteria": [
          "The v1 contract fields are explicit and bounded",
