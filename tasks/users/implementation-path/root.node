          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "landing-seriousness-conversion",
      "type": "section",
      "label": "Migration Boundary",
      "root": false,
      "position": {
        "x": -640,
        "y": -155
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Migration Boundary",
        "summary": "Do not migrate everything.\n\nMove only product-critical user state in the first pass:\n- canonical user identity\n- provider linkage\n- selected installation\n- default save slot\n- repo mappings\n- onboarding state that must survive devices\n\nLeave pan/zoom, recents, caches, and session-local editor convenience state where they are for now.",
        "level": "h2",
        "anchor": "migration-boundary",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
