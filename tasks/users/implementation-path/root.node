          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "landing-seriousness-signals",
      "type": "section",
      "label": "Workspace Resolution",
      "root": false,
      "position": {
        "x": 1380,
        "y": -535
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Workspace Bundle",
        "summary": "On sign-in, Twilite should resolve one durable workspace bundle in this order:\n1. `users` by canonical identity\n2. `user_workspaces` for that user\n3. active `repo_mappings` for `work`, `public`, and `private`\n4. `default_save_slot`, which should initially resolve to `work`\n\nThe app should stop deriving this from scattered local state once this path exists.",
        "level": "h2",
        "anchor": "workspace-resolution",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "users-implementation-bridge-section",
          "sourceBridgeNodeId": "users-implementation-bridge-section",
          "sourceBridgeLabel": "Section",
