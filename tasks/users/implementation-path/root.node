        },
        "definitionKey": "section"
      }
    },
    {
      "id": "landing-seriousness-sequence",
      "type": "section",
      "label": "Suggested Sequence",
      "root": false,
      "position": {
        "x": -160,
        "y": -155
      },
      "width": 420,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Suggested Sequence",
        "summary": "1. create `users`, `auth_identities`, `user_workspaces`, and `repo_mappings`\n2. attach GitHub sign-in and installation linkage through `auth_identities`\n3. resolve the workspace bundle on sign-in\n4. make `work` the default save slot for new files\n5. move only critical hosted user state out of browser-local storage\n6. build settings and setup flows on top of the stable schema",
        "level": "h2",
        "anchor": "suggested-sequence",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "users-implementation-bridge-section",
          "sourceBridgeNodeId": "users-implementation-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
