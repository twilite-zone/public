      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Users Implementation Path",
        "summary": "The abstract model is done.\n\nThis graph now defines the first concrete hosted slice in code terms: four persisted records, one sign-in resolution bundle, and one default-save rule.\n\nFirst slice records:\n- `users`\n- `auth_identities`\n- `user_workspaces`\n- `repo_mappings`",
        "level": "h2",
        "anchor": "users-implementation-path",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "users-implementation-bridge-section",
          "sourceBridgeNodeId": "users-implementation-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "landing-seriousness-entry",
      "type": "section",
      "label": "Execution Boundary",
      "root": false,
      "position": {
        "x": -60,
        "y": -535
      },
      "width": 360,
      "height": 210,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Execution Boundary",
        "summary": "This first implementation slice should only make hosted identity and workspace ownership real.\n\nDo not fold in every local preference, cache, or editor convenience state yet.",
        "level": "h2",
        "anchor": "execution-boundary",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
