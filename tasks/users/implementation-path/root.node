      "data": {
        "body": "Translate the hosted users model into concrete MySQL DDL for `users`, `auth_identities`, `user_workspaces`, and `repo_mappings`, including primary keys, foreign keys, unique constraints, enums/check strategy, timestamps, and indexes needed for sign-in and save-target resolution.",
        "status": "todo",
        "owner": "Michael",
        "priority": "high",
        "estimateHours": "4",
        "acceptanceCriteria": [
          "Four core tables are defined in concrete MySQL terms",
          "Foreign keys and uniqueness rules match the hosted users model",
          "The schema supports workspace resolution and default-save lookup"
        ],
        "_classBinding": {
          "key": "task",
          "sourceRef": "/library/classes/nodes/task-planning/task.node-class.node",
          "ref": "/library/classes/nodes/task-planning/task.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "users-implementation-bridge-task",
          "sourceBridgeNodeId": "users-implementation-bridge-task",
          "sourceBridgeLabel": "Task",
          "sourceRef": "/library/classes/nodes/task-planning/task.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "task",
          "classRef": "/library/classes/nodes/task-planning/task.node-class.node"
        },
        "definitionKey": "task"
      }
    }
  ],
  "edges": [
