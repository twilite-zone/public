      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Questions To Answer",
        "summary": "Key questions:\n- What should count as the canonical Twilite user identity?\n- Which user data should stay local, and which must become server-owned?\n- How should repo mappings be represented and edited?\n- How should we migrate today's browser-local state without breaking people?",
        "level": "h2",
        "anchor": "questions-to-answer",
        "status": "active",
