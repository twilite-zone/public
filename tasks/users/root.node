      }
    },
    {
      "id": "landing-seriousness-entry",
      "type": "section",
      "label": "Identity Boundary",
      "root": false,
      "position": {
        "x": 260,
        "y": -180
      },
      "width": 360,
      "height": 210,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Identity Boundary",
        "summary": "Twilite needs a canonical user identity boundary.\n\nThe system should stop relying on browser-local state for important product data and establish a hosted user record that can survive devices, sessions, and repo changes.",
        "level": "h2",
        "anchor": "identity-boundary",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
