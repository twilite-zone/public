      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Users Infrastructure",
        "summary": "Twilite now has meaningful user data in more than one place, so pretending there is no user model is no longer viable.\n\nThis task graph defines the work needed to implement hosted users, durable server-side user data, and explicit mappings between each user's `work/`, `public/`, and `private/` folders and their corresponding repos.\n\nDirection: take the most flexible route, since hosted auth and persistence come with the web deployment anyway.",
        "level": "h2",
        "anchor": "users-infrastructure",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "landing-page-seriousness-task-bridge-section",
          "sourceBridgeNodeId": "landing-page-seriousness-task-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
