    {
      "id": "landing-seriousness-identity",
      "type": "section",
      "label": "Data Ownership",
      "root": false,
      "position": {
        "x": 680,
        "y": -180
      },
      "width": 360,
      "height": 210,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Data Ownership",
        "summary": "User-critical state should move into durable hosted storage.\n\nExamples:\n- repo mappings\n- default save destination\n- selected GitHub installation\n- workspace preferences that should follow the user\n\n`localStorage` can remain a cache and convenience layer, but not the source of truth.",
        "level": "h2",
        "anchor": "data-ownership",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "landing-page-seriousness-task-bridge-section",
