    {
      "id": "landing-seriousness-sequence",
      "type": "section",
      "label": "Suggested Sequence",
      "root": false,
      "position": {
        "x": 260,
        "y": 360
      },
      "width": 420,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Implementation Sequence",
        "summary": "Start with the canonical schema, then bind auth, then resolve the workspace on sign-in, then make `work` the default save destination.\n\nDo not try to migrate every local preference in the first slice.",
        "level": "h2",
        "anchor": "implementation-sequence",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/document-publishing/section.node-class.node",
