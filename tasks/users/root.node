    {
      "id": "users-view-coordinator",
      "type": "script",
      "label": "View Coordinator",
      "root": false,
      "position": {
        "x": -816.6597293085497,
        "y": 992.6121586548043
      },
      "width": 440,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "mode": "auto",
        "status": "idle",
        "scriptRef": "",
        "autoRun": true,
        "autoRunOnGraphChange": true,
        "description": "Single write authority for hosted users summary and document surfaces.",
        "scriptName": "Users View Coordinator",
        "scriptId": "",
        "summaryNodeId": "users-document-view",
        "summarySource": "node-updater",
        "source": "const SUMMARY_NODE_ID = 'landing-page-seriousness-summary';\nconst DOCUMENT_VIEW_ID = 'users-document-view';\nconst ORDERED_IDS = [\n  'users-title',\n  'landing-page-seriousness-summary',\n  'landing-seriousness-overview',\n  'landing-seriousness-entry',\n  'landing-seriousness-identity',\n  'landing-seriousness-hierarchy',\n  'landing-seriousness-signals',\n  'landing-seriousness-conversion',\n  'landing-seriousness-sequence',\n  'landing-seriousness-questions',\n  'landing-seriousness-output',\n  'tasks-landing-page-seriousness-task-node-task',\n  'tasks-landing-page-seriousness-task-node-question'\n];\n\nconst DONE_TASK_STATUSES = new Set(['done', 'complete', 'completed', 'closed']);\nconst ANSWERED_STATUSES = new Set(['answered', 'done', 'resolved', 'closed']);\n\nconst normalize = (value) => String(value || '').trim().toLowerCase();\nconst isEqual = (a, b) => JSON.stringify(a) === JSON.stringify(b);\nconst toTitle = (entry, fallback) =>\n  String(entry?.data?.title || entry?.label || entry?.data?.summary || entry?.data?.body || fallback || '').trim();\nconst toListText = (items, emptyLabel, maxItems = 4) => {\n  const visible = items.filter(Boolean).slice(0, maxItems);\n  if (!visible.length) return emptyLabel;\n  return visible.map((item, index) => `${index + 1}. ${item}`).join('\\n');\n};\n\nconst escapeHtml = (value) =>\n  String(value ?? '')\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;')\n    .replace(/'/g, '&#39;');\n\nconst paragraphize = (value) => escapeHtml(value).replace(/\\n\\n+/g, '<br><br>').replace(/\\n/g, '<br>');\n\nconst renderErrorCard = (title, detail) =>\n  `<section style=\"padding:18px;border:1px solid rgba(220,38,38,0.22);border-radius:16px;background:linear-gradient(180deg, rgba(254,242,242,0.98), rgba(255,255,255,0.98));display:flex;flex-direction:column;gap:10px;\"><div style=\"font:700 18px/1.25 ui-sans-serif, system-ui, sans-serif;color:#991b1b;\">${escapeHtml(title)}</div><div style=\"font:500 14px/1.6 ui-sans-serif, system-ui, sans-serif;color:#7f1d1d;\">${escapeHtml(detail)}</div></section>`;\n\nconst renderCardPart = ({ title, badge, badgeStyle, ruleStyle, body, meta, anchor }) => {\n  const safeTitle = escapeHtml(title || 'Untitled');\n  const bodyHtml = body ? `<div style=\"font:500 15px/1.7 ui-sans-serif, system-ui, sans-serif;color:#1f2937;\">${body}</div>` : '';\n  const metaHtml = meta ? `<div style=\"font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#64748b;\">${meta}</div>` : '';\n  const anchorAttr = anchor ? ` id=\"${escapeHtml(anchor)}\"` : '';\n  return `<section style=\"margin:0 0 20px 0;\"><div style=\"display:flex;flex-direction:column;gap:14px;padding:20px;border-radius:20px;background:linear-gradient(180deg, rgba(255,255,255,0.99), rgba(248,250,252,0.96));border:1px solid rgba(15,23,42,0.12);box-shadow:0 12px 28px rgba(15,23,42,0.08);\"><div style=\"display:flex;align-items:center;justify-content:space-between;gap:12px;\"><div${anchorAttr} style=\"font:700 24px/1.15 ui-sans-serif, system-ui, sans-serif;color:#111827;\">${safeTitle}</div><div style=\"display:flex;gap:6px;flex-wrap:wrap;\"><span style=\"${badgeStyle}\">${escapeHtml(badge)}</span></div></div><div style=\"${ruleStyle}\"></div>${bodyHtml}${metaHtml}</div></section>`;\n};\n\nconst renderTitlePart = (data) => {\n  const safeTitle = escapeHtml(data.title || 'Untitled Title');\n  const safeSubtitle = escapeHtml(data.subtitle || 'Use this node to frame the document.');\n  return `<section style=\"margin:0 0 20px 0;\"><div style=\"display:flex;flex-direction:column;box-sizing:border-box;padding:20px;border-radius:20px;background:linear-gradient(180deg, rgba(255,252,245,0.99), rgba(255,248,235,0.96));border:1px solid rgba(146,64,14,0.16);box-shadow:0 12px 28px rgba(180,83,9,0.10);gap:14px;\"><div style=\"display:flex;align-items:flex-start;justify-content:space-between;gap:12px;\"><div style=\"display:flex;flex-direction:column;gap:6px;min-width:0;\"><div style=\"font:700 11px/1.2 ui-sans-serif, system-ui, sans-serif;letter-spacing:0.18em;text-transform:uppercase;color:#b45309;\">Title</div><div style=\"font:700 28px/1.12 ui-sans-serif, system-ui, sans-serif;color:#1f2937;word-break:break-word;\">${safeTitle}</div></div><div style=\"display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0;\"><span style=\"padding:4px 8px;border-radius:999px;background:rgba(180,83,9,0.1);color:#92400e;font-size:11px;font-weight:700;letter-spacing:0.04em;\">${escapeHtml(data.intent || 'headline')}</span><span style=\"font:600 10px/1.2 ui-sans-serif, system-ui, sans-serif;letter-spacing:0.12em;text-transform:uppercase;color:#9a3412;opacity:0.72;\">${escapeHtml(data.status || 'draft')}</span></div></div><div style=\"height:1px;background:linear-gradient(90deg, rgba(245,158,11,0.45), rgba(245,158,11,0));\"></div><div style=\"font:500 15px/1.65 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\">${safeSubtitle}</div></div></section>`;\n};\n\nconst renderTaskPart = (node, data) => {\n  const status = escapeHtml(data.status || 'todo');\n  const priority = escapeHtml(data.priority || '');\n  const owner = escapeHtml(data.owner || '');\n  const estimate = escapeHtml(data.estimateHours || '');\n  const body = paragraphize(data.body || 'Task');\n  const meta = [\n    status ? `Status: ${status}` : '',\n    priority ? `Priority: ${priority}` : '',\n    owner ? `Owner: ${owner}` : '',\n    estimate ? `Estimate: ${estimate}h` : ''\n  ].filter(Boolean).join(' • ');\n  return renderCardPart({\n    title: data.title || node.label || 'Task',\n    badge: 'Task',\n    badgeStyle: 'padding:4px 8px;border-radius:999px;background:rgba(16,185,129,0.16);color:#047857;font-size:11px;font-weight:600;',\n    ruleStyle: 'height:4px;border-radius:999px;background:linear-gradient(90deg, #10b981, #34d399);opacity:0.95;',\n    body,\n    meta\n  });\n};\n\nconst renderOpenQuestionPart = (node, data) => {\n  const status = escapeHtml(data.status || 'open');\n  const owner = escapeHtml(data.owner || '');\n  const prominence = escapeHtml(data.prominence || '');\n  const body = paragraphize(data.body || 'Open question');\n  const meta = [\n    status ? `Status: ${status}` : '',\n    owner ? `Owner: ${owner}` : '',\n    prominence ? `Prominence: ${prominence}` : ''\n  ].filter(Boolean).join(' • ');\n  return renderCardPart({\n    title: data.title || node.label || 'Open Question',\n    badge: 'Open Question',\n    badgeStyle: 'padding:4px 8px;border-radius:999px;background:rgba(168,85,247,0.14);color:#7c3aed;font-size:11px;font-weight:600;',\n    ruleStyle: 'height:4px;border-radius:999px;background:linear-gradient(90deg, #a855f7, #c084fc);opacity:0.95;',\n    body,\n    meta\n  });\n};\n\nconst renderSummaryPart = (data) => {\n  const progress = `${Number(data?.taskProgress?.completed || 0)}/${Number(data?.taskProgress?.total || 0)} tasks complete`;\n  const questions = `${Number(data?.questionProgress?.answered || 0)}/${Number(data?.questionProgress?.total || 0)} questions answered`;\n  const body = [\n    data.goal ? `<strong>Goal:</strong> ${escapeHtml(data.goal)}` : '',\n    data.taskListText ? `<strong>Tasks In Scope</strong><br>${paragraphize(data.taskListText)}` : '',\n    data.questionListText ? `<strong>Open Questions</strong><br>${paragraphize(data.questionListText)}` : ''\n  ].filter(Boolean).join('<br><br>');\n  return renderCardPart({\n    title: data.goal || 'Users Summary',\n    badge: 'Summary',\n    badgeStyle: 'padding:4px 8px;border-radius:999px;background:rgba(219,39,119,0.14);color:#9d174d;font-size:11px;font-weight:600;',\n    ruleStyle: 'height:4px;border-radius:999px;background:linear-gradient(90deg, #db2777, #f472b6);opacity:0.95;',\n    body,\n    meta: `${progress} • ${questions}`\n  });\n};\n\nconst renderSectionPart = (node, data) =>\n  renderCardPart({\n    title: data.title || node.label || 'Section',\n    badge: 'Section',\n    badgeStyle: 'padding:4px 8px;border-radius:999px;background:rgba(37,99,235,0.14);color:#1d4ed8;font-size:11px;font-weight:600;',\n    ruleStyle: 'height:4px;border-radius:999px;background:linear-gradient(90deg, #2563eb, #60a5fa);opacity:0.95;',\n    body: paragraphize(data.summary || ''),\n    anchor: data.anchor\n  });\n\nconst renderNodePart = (node) => {\n  const data = node.data || {};\n  if (node.type === 'title') return renderTitlePart(data);\n  if (node.type === 'task-summary-provider' || node.type === 'summary') return renderSummaryPart(data);\n  if (node.type === 'task') return renderTaskPart(node, data);\n  if (node.type === 'open-question') return renderOpenQuestionPart(node, data);\n  if (node.type === 'section') return renderSectionPart(node, data);\n  return '';\n};\n\nconst nodes = await api.getNodes();\nconst nodesById = new Map(nodes.map((entry) => [entry?.id, entry]));\nconst summaryNode = nodesById.get(SUMMARY_NODE_ID);\nconst documentView = nodesById.get(DOCUMENT_VIEW_ID);\nif (!summaryNode || !documentView) return { success: false, error: 'Required view nodes missing' };\n\nconst goalNode = nodes.find((entry) => entry?.type === 'goal');\nconst tasks = nodes.filter((entry) => entry?.type === 'task' && entry?.id !== SUMMARY_NODE_ID);\nconst questions = nodes.filter((entry) => entry?.type === 'open-question');\nconst taskItems = tasks.map((entry) => ({\n  title: toTitle(entry, 'Untitled task'),\n  status: normalize(entry?.data?.status)\n})).filter((entry) => entry?.title);\nconst taskTitles = taskItems.map((entry) => entry.title);\nconst questionTitles = questions.map((entry) => toTitle(entry, 'Untitled question')).filter(Boolean);\nconst completedTaskCount = taskItems.filter((entry) => DONE_TASK_STATUSES.has(entry.status)).length;\nconst allTasksDone = taskItems.length > 0 && completedTaskCount === taskItems.length;\nconst goalStatus = normalize(goalNode?.data?.status);\nconst derivedStatus = goalStatus\n  ? (goalStatus === 'done' && !allTasksDone ? 'in-progress' : goalNode?.data?.status)\n  : (allTasksDone ? 'done' : (completedTaskCount > 0 ? 'in-progress' : (summaryNode?.data?.status || 'todo')));\n\nconst nextSummaryData = {\n  ...(summaryNode.data || {}),\n  goal: goalNode?.label || summaryNode?.data?.goal || 'Task graph',\n  status: derivedStatus,\n  taskProgress: { completed: completedTaskCount, total: taskItems.length },\n  questionProgress: {\n    answered: questions.filter((entry) => ANSWERED_STATUSES.has(normalize(entry?.data?.status))).length,\n    total: questions.length\n  },\n  taskTitles,\n  questionTitles,\n  taskListText: toListText(taskTitles, 'No tasks listed.', taskTitles.length || 4),\n  questionListText: toListText(questionTitles, 'No open questions.'),\n  summarySource: 'graph-updater'\n};\n\nconst currentSummaryComparable = { ...(summaryNode.data || {}) };\ndelete currentSummaryComparable.updatedAt;\nconst nextSummaryComparable = { ...nextSummaryData };\ndelete nextSummaryComparable.updatedAt;\nconst summaryChanged = !isEqual(currentSummaryComparable, nextSummaryComparable);\n\nconst effectiveSummaryData = summaryChanged ? nextSummaryData : (summaryNode.data || {});\nconst effectiveNodesById = new Map(nodesById);\neffectiveNodesById.set(SUMMARY_NODE_ID, { ...summaryNode, data: effectiveSummaryData });\n\nconst existingIds = new Set(nodes.map((entry) => entry?.id).filter(Boolean));\nconst missingOrderedIds = ORDERED_IDS.filter((id) => !existingIds.has(id));\nconst resolvedOrder = ORDERED_IDS.filter((id) => existingIds.has(id));\nconst renderedParts = resolvedOrder.map((id) => renderNodePart(effectiveNodesById.get(id))).filter(Boolean);\nconst invalidOrdering = missingOrderedIds.length > 0 || renderedParts.length !== resolvedOrder.length;\nconst documentHtml = invalidOrdering\n  ? renderErrorCard('Document view contract error', `Document order is invalid or incomplete. Missing: ${missingOrderedIds.join(', ') || 'unknown part rendering failure'}.`)\n  : (renderedParts.join('') || renderErrorCard('Document view contract error', 'Document content is missing. Add document parts or provide documentHtml/documentBlocks.'));\n\nconst nextDocumentData = {\n  ...(documentView.data || {}),\n  partNodeIds: resolvedOrder,\n  documentOrder: resolvedOrder,\n  documentHtml,\n  summarySource: 'node-updater'\n};\n\nconst currentDocumentComparable = { ...(documentView.data || {}) };\ndelete currentDocumentComparable.updatedAt;\nconst nextDocumentComparable = { ...nextDocumentData };\ndelete nextDocumentComparable.updatedAt;\nconst documentChanged = !isEqual(currentDocumentComparable, nextDocumentComparable);\n\nif (!summaryChanged && !documentChanged) {\n  return { success: true, updated: false, summaryChanged, documentChanged, missingOrderedIds };\n}\n\nconst stamp = new Date().toISOString();\nif (summaryChanged) {\n  await api.updateNode(SUMMARY_NODE_ID, { data: { ...nextSummaryData, updatedAt: stamp } });\n}\nif (documentChanged) {\n  await api.updateNode(DOCUMENT_VIEW_ID, { data: { ...nextDocumentData, updatedAt: stamp } });\n}\n\nreturn { success: true, updated: true, summaryChanged, documentChanged, missingOrderedIds };",
