        "x": 680,
        "y": 80
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Durable Workspace State",
        "summary": "The hosted workspace should own the user's default save slot, selected provider context, onboarding state, and any repo-linked preferences that need to follow the user across devices.",
        "level": "h2",
        "anchor": "durable-workspace-state",
        "status": "active",
