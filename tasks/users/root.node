        },
        "definitionKey": "section"
      }
    },
    {
      "id": "landing-seriousness-hierarchy",
      "type": "section",
      "label": "Repo Mapping",
      "root": false,
      "position": {
        "x": 260,
        "y": 80
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Repo Mapping Model",
        "summary": "A hosted user should own explicit repo mappings for `work`, `public`, and `private`.\n\nThat mapping is the durable contract between Twilite and GitHub, and it should not be inferred from whichever browser tab happened to be open last.",
        "level": "h2",
        "anchor": "repo-mapping-model",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/document-publishing/section.node-class.node"
