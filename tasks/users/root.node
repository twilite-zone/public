    {
      "id": "landing-seriousness-conversion",
      "type": "section",
      "label": "Hosted Flexibility",
      "root": false,
      "position": {
        "x": 1100,
        "y": 80
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Auth Strategy",
        "summary": "GitHub should attach to the Twilite user through provider identities rather than becoming the user record itself.\n\nThat keeps the system flexible enough to add other providers later without redoing the core data model.",
        "level": "h2",
        "anchor": "auth-strategy",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/document-publishing/section.node-class.node",
