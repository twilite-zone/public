    {
      "id": "field-driven-class-artifacts-goal",
      "type": "goal",
      "label": "Unify class artifacts around field-driven authoring",
      "position": {
        "x": 240,
        "y": -120
      },
      "width": 420,
      "height": 250,
      "visible": true,
      "showLabel": false,
      "data": {
        "body": "Define one canonical way to author node-class and edge-class artifacts so both use field-addressed functional data, keep human-readable documentation nearby, and preserve legacy loading only as a fallback.",
        "priority": "critical",
        "status": "in-progress",
        "owner": "Michael",
        "estimateHours": "12",
        "acceptanceCriteria": [
          "Node classes and edge classes can be described through the same artifact model",
          "Field nodes become the canonical functional data surface for class contracts",
          "Legacy manifest and dictionary readers are demoted to compatibility fallbacks"
        ],
