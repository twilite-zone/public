    {
      "id": "node-primitive-goal",
      "type": "goal",
      "label": "Make the node abstraction legible",
      "position": {
        "x": 1392.1428571428573,
        "y": -1292.6666666666667
      },
      "width": 380,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Clarify what every node shares, what is optional composition, and which interaction/content/layout responsibilities belong to the primitive versus custom nodes.",
        "priority": "critical",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "10",
        "acceptanceCriteria": [
          "A clear node primitive model exists",
          "Port/content/control composition rules are explicit",
          "Interaction policy can depend on the primitive without freezing experimentation"
        ],
