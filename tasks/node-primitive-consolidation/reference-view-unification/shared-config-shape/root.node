    {
      "id": "shared-config-shape-mapping",
      "type": "markdown",
      "label": "Current Member Mapping",
      "position": {
        "x": -80,
        "y": 540
      },
      "visible": true,
      "showLabel": true,
      "width": 560,
      "height": 340,
      "data": {
        "markdown": "# Current Member Mapping\n\n## PortNode\n- target: yes\n- surface.kind: `compact` or `boundary`\n- mode: navigate / expand / bridge\n- embed.live: no\n- best read: minimal reference primitive\n\n## DynamicViewNode\n- target: sometimes none\n- surface.kind: `hosted-view`\n- mode: mostly passive\n- embed.live: only for html/iframe-style views\n- best read: minimal hosted-view primitive\n\n## GraphReferenceNode\n- target: yes\n- surface.kind: `preview` or `embed`\n- mode: preview / interactive plus traversal affordances\n- embed.live: yes\n- best read: hybrid of reference + hosted representation + embedded runtime",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
