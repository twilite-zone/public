    {
      "id": "reference-view-unification-goal",
      "type": "goal",
      "label": "Make reference-bearing view nodes feel like one family",
      "position": {
        "x": 151.16666666666652,
        "y": -755
      },
      "width": 420,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Clarify the shared base shape for nodes that display, reference, expand, navigate, or bridge into other graph material. Differences should live in views and declared behavior where possible, not in accidental species drift.",
        "priority": "critical",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "5",
        "acceptanceCriteria": [
          "Shared family shape is documented",
          "Bridge is placed cleanly in the model",
          "At least one current distinction is identified as view difference rather than species difference"
        ],
