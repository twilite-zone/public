    {
      "id": "reference-view-unification-decision",
      "type": "decision",
      "label": "Differences should prefer view or mode before species",
      "position": {
        "x": 987.8333333333333,
        "y": 415
      },
      "width": 420,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "If two nodes share the same substrate and only differ by rendered view or traversal behavior, that difference should stay in view or mode before becoming a distinct species.",
        "rationale": "This is the only way these surfaces will actually converge instead of drifting forever.",
