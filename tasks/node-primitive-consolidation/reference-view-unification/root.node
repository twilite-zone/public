    {
      "id": "reference-view-unification-decision-emergent-selection",
      "type": "decision",
      "label": "Autorun selection is emergent behavior, not species essence",
      "position": {
        "x": 2578.8333333333335,
        "y": 115
      },
      "width": 460,
      "height": 220,
      "visible": true,
