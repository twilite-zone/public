      "visible": true,
      "showLabel": true,
      "width": 360,
      "height": 220,
      "data": {
        "body": "Produce a pile-sorted contract that distinguishes true node requirements from common defaults, optional capabilities, and family-specific chrome.",
        "priority": "critical",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "2",
        "acceptanceCriteria": [
