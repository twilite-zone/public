    {
      "id": "custom-node-pattern-task-contract",
      "type": "task",
      "label": "Define the class-backed custom node contract",
      "position": {
        "x": 560,
        "y": -140
      },
      "width": 400,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Specify what a graph-native custom node may declare: views, controls, event reactions, scripts, and optional slots for interior controls.",
        "priority": "critical",
        "status": "done",
        "owner": "Michael",
        "estimateHours": "4",
        "acceptanceCriteria": [
          "Renderer-owned versus class-owned responsibilities are explicit",
          "The bootstrap node fits the contract without cheating",
          "A future custom node can be authored without writing a bespoke React component"
        ],
        "resolutionPath": "The working pattern is now explicit: host renders generic controls, class defines behavior, and bootstrap is the proof case.",
