    {
      "id": "custom-node-pattern-decision-script-actions",
      "type": "decision",
      "label": "Named script actions are the next purity move",
      "position": {
        "x": 1060,
        "y": 80
      },
      "width": 420,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
