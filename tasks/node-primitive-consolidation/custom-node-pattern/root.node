      "width": 400,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Let classes place generic controls inside the node surface through declared slots or placements such as header, body-top, or footer, without requiring arbitrary HTML-native buttons.",
        "priority": "high",
        "status": "done",
        "owner": "Michael",
        "estimateHours": "3",
        "acceptanceCriteria": [
          "Controls can render somewhere other than browser chrome",
          "The bootstrap node can use an interior action area",
          "The mechanism stays host-rendered and theme-coherent"
