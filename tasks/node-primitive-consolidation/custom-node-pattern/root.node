    {
      "id": "custom-node-pattern-decision-split",
      "type": "decision",
      "label": "Host renders controls, class defines behavior",
      "position": {
        "x": 1060,
        "y": -220
      },
      "width": 420,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Actual button rendering, placement, theming, and click dispatch remain generic host responsibilities. The node class defines labels, actions, state patches, event reactions, and any script-backed logic.",
