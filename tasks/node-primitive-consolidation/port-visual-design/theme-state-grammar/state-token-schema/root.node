    {
      "id": "state-token-schema-decision-mui",
      "type": "decision",
      "label": "Use MUI as the carrier, add Twilite state on top",
      "position": {
        "x": 940,
        "y": 500
      },
      "visible": true,
      "showLabel": true,
      "width": 420,
      "height": 220,
      "data": {
        "body": "Do not build a parallel theming engine. Keep using MUI palette, typography, shape, and shadows, then extend the theme with a `twilite.state` section for interaction semantics.",
        "rationale": "This makes the new state grammar cheap to adopt and keeps browser/editor theme workflows intact.",
