    {
      "id": "state-token-schema-tiers",
      "type": "markdown",
      "label": "Proposed Loudness Tiers",
      "position": {
        "x": 940,
        "y": 120
      },
      "visible": true,
      "showLabel": true,
      "width": 420,
      "height": 320,
      "data": {
        "markdown": "# Proposed Loudness Tiers\n\n- `calm`\n  - quiet default presence\n- `hover`\n  - local clarification only\n- `selected`\n  - stronger than calm\n- `focused`\n  - strongest ordinary state\n- `dragTarget`\n  - temporary connection / drop emphasis\n- `connected`\n  - occupied but not loud\n- `disabled`\n  - reduced clarity / unavailable\n- `warning` / `error`\n  - exceptional states that can override ordinary hierarchy locally",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "ref": "/library/classes/nodes/markdown.node-class.node",
          "identity": {
            "graphId": "markdown_class",
            "name": "markdown Node Class",
            "version": "0.1.0",
            "description": "Canonical markdown content node.",
            "createdAt": "2026-02-24T20:05:15Z",
            "updatedAt": "2026-03-24T01:20:00.000Z"
          },
          "intent": "graph",
          "meaning": "Canonical markdown content node.",
          "description": "Canonical markdown content node.",
          "defaults": {},
          "nodeDef": {
            "key": "markdown",
            "ref": "/library/classes/nodes/markdown.node-class.node",
            "source": "local",
