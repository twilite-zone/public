    {
      "id": "state-token-schema-goal",
      "type": "goal",
      "label": "Create a small usable first token layer",
      "position": {
        "x": 480,
        "y": -140
      },
      "visible": true,
      "showLabel": true,
      "width": 380,
      "height": 220,
      "data": {
        "body": "Define a token schema that is small enough to implement now but expressive enough to calm the loudest interaction surfaces.",
        "priority": "high",
        "status": "done",
        "owner": "Michael",
        "estimateHours": "3",
        "acceptanceCriteria": [
          "The schema supports calm, selected, focused, and interactive states",
          "Ports and edge labels can adopt it first",
          "It does not explode into a huge theme framework"
        ],
        "resolutionPath": "A small first token layer now exists and is being consumed by the graph surface.",
        "_classBinding": {
