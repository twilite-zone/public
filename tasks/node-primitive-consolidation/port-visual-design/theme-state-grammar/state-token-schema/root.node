    {
      "id": "state-token-schema-families",
      "type": "markdown",
      "label": "First Token Families",
      "position": {
        "x": 1420,
        "y": 220
      },
      "visible": true,
      "showLabel": true,
      "width": 420,
      "height": 320,
      "data": {
        "markdown": "# First Token Families\n\n## 1. Surface\n- `state.surface.*`\n- generic boundary/surface treatment\n\n## 2. Port\n- `state.port.*`\n- may override surface subtly for connection grammar\n\n## 3. Edge\n- `state.edge.*`\n- line emphasis, glow restraint, opacity\n\n## 4. Label\n- `state.label.*`\n- edge labels and small control labels\n\nThis is enough to calm the current offenders without solving every part of the app.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "ref": "/library/classes/nodes/markdown.node-class.node",
          "identity": {
