    {
      "id": "theme-state-grammar-decision",
      "type": "decision",
      "label": "State should drive loudness, not arbitrary component styling",
      "position": {
        "x": 940,
        "y": -160
      },
      "visible": true,
      "showLabel": true,
      "width": 420,
      "height": 220,
      "data": {
        "body": "The app should decide what is calm, what is active, and what is urgent through theme/state tokens rather than one-off styling choices.",
        "rationale": "Ports are only the first place where this became impossible to ignore.",
