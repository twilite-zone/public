    {
      "id": "theme-state-grammar-tokens",
      "type": "markdown",
      "label": "Token Pressure",
      "position": {
        "x": 1420,
        "y": -160
      },
      "visible": true,
      "showLabel": true,
      "width": 400,
      "height": 260,
      "data": {
        "markdown": "# Token Pressure\n\nLikely token families:\n- `port.*`\n- `node.border.*`\n- `node.surface.*`\n- `edge.*`\n- `selection.*`\n- `focus.*`\n\nThis should reduce hardcoded color decisions and make state meaning more consistent.",
        "_classBinding": {
