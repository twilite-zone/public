    {
      "id": "theme-state-grammar-goal",
      "type": "goal",
      "label": "Make interaction states feel deliberate across the app",
      "position": {
        "x": 480,
        "y": -140
      },
      "visible": true,
      "showLabel": true,
      "width": 380,
      "height": 220,
      "data": {
        "body": "Define a stateful visual grammar so ports, edges, nodes, and controls all share coherent calm/default/accent behavior.",
        "priority": "high",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "4",
        "acceptanceCriteria": [
          "Theme has explicit state concepts",
          "Interactive surfaces stop improvising color and emphasis",
          "Ports can inherit meaningful state tokens"
        ],
        "_classBinding": {
          "key": "goal",
