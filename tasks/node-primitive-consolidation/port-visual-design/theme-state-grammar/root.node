    {
      "id": "theme-state-grammar-open-question",
      "type": "open-question",
      "label": "What is allowed to be visually loud in Twilite?",
      "position": {
        "x": 1420,
        "y": 180
      },
      "visible": true,
      "showLabel": true,
      "width": 420,
      "height": 220,
      "data": {
        "body": "Current answer: calm is the default. Selected should be louder than calm, and focused should be the loudest broad state. Diagnostics and warnings may override that locally, but ordinary chrome should not.",
        "status": "answered",
        "resolutionPath": "Broad rule: calm < selected < focused. Selection is primary-weighted; focus is secondary-weighted and the strongest ordinary state.",
        "_classBinding": {
          "key": "open-question",
          "sourceRef": "/library/classes/nodes/task-planning/open-question.node-class.node",
