    {
      "id": "focus-layout-overview",
      "type": "markdown",
      "label": "Focus-Driven Layout",
      "position": {
        "x": -620,
        "y": -260
      },
      "width": 480,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Focus-Driven Layout\n\nSemantic zoom already made focus the source of representation truth. The next layer is to let layout respond to that same focus so framing, orbit, clustering, and abstraction reinforce the active semantic center.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
