    {
      "id": "focus-layout-semantic-gravity",
      "type": "markdown",
      "label": "Semantic Gravity",
      "position": {
        "x": 900,
        "y": -260
      },
      "width": 440,
      "height": 280,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Semantic Gravity\n\nA plausible layout rule set:\n\n- focused fragment: centered / dominant\n- level -1 fragments: orbit nearby\n- level -2 fragments: background / clustered\n- deeper fragments: collapsed / abstracted\n\nThe closer to focus, the heavier it should feel.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
