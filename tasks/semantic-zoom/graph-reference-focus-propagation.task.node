    {
      "id": "graph-ref-focus-model",
      "type": "markdown",
      "label": "Two-Level Attention Model",
      "position": {
        "x": 120,
        "y": -220
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Two-Level Attention Model\n\n- **outer focus**: the graph-reference fragment is the current subject\n- **inner selection/focus**: some node inside that fragment is the current local subject\n\nThese are not the same state, but they should be related.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "ref": "/library/classes/nodes/markdown.node-class.node",
