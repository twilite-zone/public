    {
      "id": "graph-ref-focus-manifestation",
      "type": "markdown",
      "label": "Possible Outward Manifestations",
      "position": {
        "x": -480,
        "y": 140
      },
      "width": 460,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Possible Outward Manifestations\n\n- miniature inner highlight\n- selected inner-node title/label\n- focus badge or preview marker\n- preview emphasis on the active subregion\n- different behavior by semantic level (`detail` / `summary` / `icon`)\n\nThe point is continuity, not duplication.",
        "_classBinding": {
