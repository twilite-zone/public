    {
      "id": "task-graph-summary-contract",
      "type": "markdown",
      "label": "Summary Contract",
      "position": {
        "x": 140,
        "y": -220
      },
      "width": 420,
      "height": 280,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Summary Contract\n\nA task graph outward face should expose:\n\n- `goal`\n- `status`\n- `taskProgress.completed`\n- `taskProgress.total`\n- `questionProgress.answered`\n- `questionProgress.total`\n\nThis is the summary payload for graph-reference and related reference surfaces.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
