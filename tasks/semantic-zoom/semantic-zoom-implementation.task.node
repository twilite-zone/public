    {
      "id": "task-hysteresis-rules-semantic-zoom",
      "type": "markdown",
      "label": "Hysteresis Rules",
      "position": {
        "x": 2320,
        "y": 560
      },
      "width": 460,
      "height": 360,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Hysteresis Rules\n\nPhysical zoom should not cause semantic flicker at threshold boundaries.\n\nSuggested transitions:\n\n- `detail -> summary` below `0.85`\n- `summary -> detail` above `0.95`\n- `summary -> icon` below `0.40`\n- `icon -> summary` above `0.50`\n\nThis keeps semantic level changes stable while the user scrolls near a threshold.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
          "identity": {
            "graphId": "markdown_class",
            "name": "markdown Node Class",
            "version": "0.1.0",
            "description": "Canonical markdown content node.",
