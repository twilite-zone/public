    {
      "id": "task-acceptance-semantic-zoom",
      "type": "markdown",
      "label": "Acceptance Criteria",
      "position": {
        "x": -80,
        "y": 460
      },
      "width": 420,
      "height": 360,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Acceptance Criteria\n\n- Focused fragment semantic level resolves deterministically\n- Linked fragments render at lower relative levels\n- Zoom-band transitions do not flicker\n- Editing keeps the focused fragment readable\n- Missing semantic views degrade automatically\n- Expanded fragments remain legible when zoomed out\n- Existing graphs keep working without semantic zoom definitions",
        "_classBinding": {
