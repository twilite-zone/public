    {
      "id": "task-goals-semantic-zoom",
      "type": "markdown",
      "label": "Goals",
      "position": {
        "x": -80,
        "y": -260
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Goals\n\n- Make navigation across linked graph fragments legible\n- Introduce a `focused node` separate from selection\n- Render the focused fragment in detail\n- Render linked fragments in summary\n- Render deeper linked graphs in icon form\n- Keep the behavior deterministic and composable\n\nThis should make traversal feel intentional rather than visually noisy.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
