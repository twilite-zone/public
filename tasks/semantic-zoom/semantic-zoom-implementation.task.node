    {
      "id": "task-focus-reassignment-semantic-zoom",
      "type": "markdown",
      "label": "Focus Reassignment Rules",
      "position": {
        "x": 1820,
        "y": 900
      },
      "width": 440,
      "height": 340,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Focus Reassignment Rules\n\nFocus must never dangle.\n\nRules:\n\n- on graph load: focus the root fragment\n- on expand: move fragment focus to the expanded fragment\n- on enter embed: move fragment focus to the embedded graph context\n- on collapse of a focused fragment: return focus to the parent anchor node/fragment\n- on node deletion: move node focus to the nearest valid anchor or clear it\n\nThis keeps navigation coherent as graph contexts appear and disappear.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
          "identity": {
            "graphId": "markdown_class",
            "name": "markdown Node Class",
            "version": "0.1.0",
            "description": "Canonical markdown content node.",
            "createdAt": "2026-02-24T20:05:15Z",
            "updatedAt": "2026-03-24T01:20:00.000Z"
          },
          "intent": "graph",
          "meaning": "Canonical markdown content node.",
          "description": "Canonical markdown content node.",
