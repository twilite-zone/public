    {
      "id": "core-loop-proof-goal",
      "type": "goal",
      "label": "Prove one Twilite loop that feels inevitable",
      "position": {
        "x": -335,
        "y": 542.9166666666667
      },
      "width": 380,
      "height": 280,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "A user should be able to start in a Twilite graph, trigger a meaningful action, commit or publish through GitHub, and see a visible result quickly enough that the value of the product becomes obvious.",
        "priority": "critical",
        "status": "open",
        "owner": "Michael",
        "targetDate": "",
        "successMetrics": [
          "The loop can be demoed end to end without explanation-heavy setup",
          "The visible result is obvious and externally legible",
          "The path feels like one product, not a stitched-together sequence"
        ],
