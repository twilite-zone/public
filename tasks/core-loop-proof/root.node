      "type": "decision",
      "label": "Optimize for one undeniable capability, not product breadth",
      "position": {
        "x": -425,
        "y": 1713.9166666666665
      },
      "width": 400,
      "height": 280,
      "visible": true,
      "showLabel": true,
      "data": {
        "rationale": "Right now the bottleneck is not missing surface area. It is the absence of one crisp proof that Twilite can carry a user from graph intent to real result. A narrower proof will create more leverage than more features.",
        "status": "decided",
        "decidedAt": "2026-03-18",
        "owner": "Michael",
        "supersededBy": "",
