          "direction": "output",
          "dataType": "content",
          "position": {
            "side": "right",
            "offset": 0.5
          }
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Undeniable Core Loop\n\nThe chat is directionally right about one thing: you need one crisp flow that makes Twilite feel inevitable.\n\nThe target loop is simple:\n\n`graph -> action -> GitHub -> visible result`\n\nThe job now is not to broaden the product. The job is to make that loop easy to demo, easy to trust, and hard to misinterpret.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "isRoot": true,
        "root": true,
        "_classBinding": {
