    {
      "id": "core-loop-proof-overview",
      "type": "markdown",
      "label": "Undeniable Core Loop",
      "position": {
        "x": -1155,
        "y": 147.91666666666674
      },
      "width": 540,
      "height": 260,
      "color": "#1976d2",
      "ports": [
