    {
      "id": "interaction-policy-note-authority",
      "type": "markdown",
      "label": "Authority Rules",
      "position": {
        "x": 2299,
        "y": 385
      },
      "width": 360,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Authority Rules\n\n- Browser owns native control hover and ordinary CSS hover.\n- Graph owns hit-testing and spatial hover truth.\n- Editor owns mode-dependent meaning and revealed affordances.\n- Nodes may declare zones, but they do not declare global hover truth.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "ref": "/library/classes/nodes/markdown.node-class.node",
