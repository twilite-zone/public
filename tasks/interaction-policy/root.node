    {
      "id": "interaction-policy-decision-precedence",
      "type": "decision",
      "label": "Hover ownership resolves by precedence",
      "position": {
        "x": 1670.333333333333,
        "y": 395
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "The graph should resolve competing hover candidates through a single ordered precedence model rather than letting overlapping components race for control.",
        "rationale": "This gives browser events a deterministic owner even when shells, content, handles, and overlays all exist in the same neighborhood.",
