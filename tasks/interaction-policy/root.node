      "width": 520,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Interaction Policy\n\nDefine a single interaction law for the graph surface so cursor behavior, hover behavior, drag behavior, and hidden controls stop competing with each other.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
