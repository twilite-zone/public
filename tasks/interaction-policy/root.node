    {
      "id": "interaction-policy-task-summary-task",
      "type": "task",
      "label": "Make interaction behavior explicit and stable",
      "position": {
        "x": 419,
        "y": -895
      },
      "width": 380,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Goal: Make interaction behavior explicit and stable\nStatus: todo\n\nTasks in scope:\n1. Be more thoughtful about navigation\n2. Audit cursor and hit-target ownership\n3. Define explicit interaction zones\n4. Collapse hover authority to one path\n5. Make overlays safe under hover\n6. Verify dev/prod parity\n\nOpen questions:\n1. What should own hover authority?",
        "status": "todo",
        "owner": "Michael",
        "priority": "medium",
        "estimateHours": "4",
        "acceptanceCriteria": [
          "Navigation modes feel intentionally distinct",
          "Users can predict what click/expand/open will do",
          "Cross-graph movement feels coherent"
        ],
        "title": "Make interaction behavior explicit and stable",
        "countAsTask": false,
        "summarySource": "node-updater",
