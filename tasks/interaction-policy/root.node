    {
      "id": "interaction-policy-decision-shell",
      "type": "decision",
      "label": "Node shell is neutral by default",
      "position": {
        "x": 1457,
        "y": -775
      },
      "width": 360,
      "height": 200,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Node containers should default to neutral cursor semantics. Dragging should come from explicit drag surfaces or active drag state, not ambient shell hover.",
        "rationale": "This prevents shell cursor policy from fighting text, links, buttons, and hover overlays.",
