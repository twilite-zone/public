    {
      "id": "interaction-policy-task-zones",
      "type": "task",
      "label": "Define explicit interaction zones",
      "position": {
        "x": 1397,
        "y": 5
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Standardize graph background, node shell, drag bar, content, controls, resize handles, and ports as named interaction zones with cursor and pointer-event contracts.",
        "priority": "critical",
