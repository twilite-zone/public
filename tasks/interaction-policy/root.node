    {
      "id": "interaction-policy-goal",
      "type": "goal",
      "label": "Make interaction behavior explicit and stable",
      "position": {
        "x": 1565,
        "y": -1183
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Every pixel in the graph should have one primary interaction role at a time, and the same pointer semantics should hold in local and remote builds.",
        "priority": "critical",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "8",
        "acceptanceCriteria": [
          "Cursor behavior is predictable across node shells, content, controls, and handles",
          "Stationary mouse flicker is eliminated or reduced to negligible levels",
          "Interaction rules are documented, not implicit"
        ],
        "_classBinding": {
