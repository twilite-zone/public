    {
      "id": "view-permission-model-goal",
      "type": "goal",
      "label": "Make UI view authority explicit before script permissions spread",
      "position": {
        "x": 80,
        "y": -360
      },
      "width": 440,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Define safe view kinds, explicit runtime permission, and host-consumption law before more graphs depend on implicit view behavior.",
        "priority": "high",
        "status": "todo",
        "owner": "Michael",
        "estimateHours": "5",
        "acceptanceCriteria": [
          "Cursor behavior is predictable across node shells, content, controls, and handles",
          "Stationary mouse flicker is eliminated or reduced to negligible levels",
          "Interaction rules are documented, not implicit"
