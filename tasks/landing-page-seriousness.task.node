        "scriptRef": "",
        "source": "const SUMMARY_NODE_ID = 'landing-page-seriousness-summary';\nconst DONE_TASK_STATUSES = new Set(['done', 'complete', 'completed', 'closed']);\nconst ANSWERED_STATUSES = new Set(['answered', 'done', 'resolved', 'closed', 'cancelled']);\nconst normalize = (value) => String(value || '').trim().toLowerCase();\nconst toTitle = (entry, fallback) => String(entry?.data?.title || entry?.label || fallback || '').trim();\nconst nodes = await api.getNodes();\nconst summaryNode = nodes.find((entry) => entry?.id === SUMMARY_NODE_ID);\nif (!summaryNode) return { success: false, error: 'Summary port missing' };\nconst goalNode = nodes.find((entry) => entry?.type === 'goal');\nconst tasks = nodes.filter((entry) => entry?.type === 'task' && entry?.data?.countAsTask !== false);\nconst questions = nodes.filter((entry) => entry?.type === 'open-question');\nconst taskTitles = tasks.map((entry) => toTitle(entry, 'Untitled task')).filter(Boolean);\nconst questionTitles = questions.map((entry) => toTitle(entry, 'Untitled question')).filter(Boolean);\nconst completed = tasks.filter((entry) => DONE_TASK_STATUSES.has(normalize(entry?.data?.status))).length;\nconst answered = questions.filter((entry) => ANSWERED_STATUSES.has(normalize(entry?.data?.status))).length;\nconst status = goalNode?.data?.status || summaryNode.data?.status || 'todo';\nconst nextData = { ...summaryNode.data, goal: goalNode?.label || summaryNode.data?.goal || 'Task graph', status, health: normalize(status) === 'cancelled' ? 'cancelled' : summaryNode.data?.health, taskProgress: { completed, total: tasks.length }, questionProgress: { answered, total: questions.length }, taskTitles, questionTitles, taskListText: taskTitles.length ? taskTitles.map((title, index) => (index + 1) + '. ' + title).join('\\n') : 'No tasks listed.', questionListText: questionTitles.length ? questionTitles.map((title, index) => (index + 1) + '. ' + title).join('\\n') : 'No open questions.', summarySource: 'node-updater', updatedAt: new Date().toISOString() };\nawait api.updateNode(SUMMARY_NODE_ID, { data: nextData });\nreturn { success: true, summary: nextData };",
        "summaryNodeId": "landing-page-seriousness-summary",
        "autoRun": true,
        "description": "Keep the ordinary outward summary port synchronized with this cancelled task graph.",
        "scriptName": "Task Node Updater",
        "scriptId": "",
        "autoRunOnGraphChange": true,
        "allowMutations": true,
        "dryRun": false,
        "autoRunOnLoad": true
      }
    },
