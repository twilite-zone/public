    {
      "id": "edge-class-contract-open-question",
      "type": "open-question",
      "label": "Should edge classes eventually become node-like objects in their own right?",
      "position": {
        "x": 1660,
        "y": 220
      },
      "width": 420,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "For now they may just be declarations, but the longer-term ontology question is whether they become more object-like.",
        "status": "answered",
        "resolutionPath": "No, not by default. Edge classes should remain declarations first. If they later become more object-like, that should be because a clear runtime need emerged, not because we forced ontology too early.",
