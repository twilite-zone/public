    {
      "id": "edge-class-contract-goal",
      "type": "goal",
      "label": "Define a minimal contract for optional edge classes",
      "position": {
        "x": 560,
        "y": -140
      },
      "width": 420,
      "height": 240,
      "visible": true,
      "showLabel": true,
