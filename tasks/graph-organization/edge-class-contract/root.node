    {
      "id": "edge-class-contract-decision-small",
      "type": "decision",
      "label": "Start semantic, not infrastructural",
      "position": {
        "x": 1040,
        "y": -180
      },
      "width": 400,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "body": "Edge classes should begin as semantic declarations: what an edge means, how it is named, and what defaults it carries. They do not need a giant runtime system first.",
        "rationale": "This keeps the work grounded in organization law and puts semantic authority on the class artifact itself.",
        "_classBinding": {
