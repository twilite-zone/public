        "y": -140
      },
      "visible": true,
      "showLabel": true,
      "width": 420,
      "height": 240,
      "data": {
        "body": "Produce concrete organization rules for task graphs, libraries, galleries, and implementation boards so the system can scale without becoming visually arbitrary.",
