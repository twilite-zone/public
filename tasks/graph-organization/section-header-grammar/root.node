    {
      "id": "section-header-grammar-decision-header-role",
      "type": "decision",
      "label": "A header is not just decoration",
      "position": {
        "x": 1040,
        "y": -200
      },
      "visible": true,
      "showLabel": true,
      "width": 400,
      "height": 220,
      "data": {
        "body": "Headers should name a section, orient the reader, and serve as the visible identity of that section. By default they do not carry operational behavior. They may anchor organizational edges and may point at a section summary, but they should not become overloaded mini-routers by default.",
        "rationale": "If headers are decorative only, organizational law never becomes operational. If they are fully operational by default, every section becomes noisy and ambiguous.",
        "_classBinding": {
          "key": "decision",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/decision.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/decision.node-class.node",
