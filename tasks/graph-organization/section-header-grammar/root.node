    {
      "id": "section-header-grammar-task-header",
      "type": "task",
      "label": "Define what a header may own",
      "position": {
        "x": -40,
        "y": 220
      },
      "visible": true,
      "showLabel": true,
      "width": 360,
      "height": 220,
      "data": {
        "body": "Default law: a header may own organizational/reference edges and may point to a section summary. It should not own direct section membership, and it should not expose live ports unless the graph explicitly upgrades it into a structural anchor.",
