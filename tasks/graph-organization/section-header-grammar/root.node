    {
      "id": "section-header-grammar-decision-cluster-role",
      "type": "decision",
      "label": "Clusters group; headers orient; summaries speak outward",
      "position": {
        "x": 1040,
        "y": 80
      },
      "visible": true,
      "showLabel": true,
      "width": 420,
      "height": 220,
      "data": {
        "body": "Clusters express containment, headers express section identity, and summary nodes expose outward-facing state. Default organizational sections should keep these three roles distinct, even when one graph chooses to collapse them for a local special case.",
        "rationale": "This keeps composition from collapsing into one overloaded primitive and gives graphs a stable grammar that can scale.",
        "_classBinding": {
          "key": "decision",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/decision.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/decision.node-class.node",
