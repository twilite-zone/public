    {
      "id": "section-header-grammar-task-summary",
      "type": "task",
      "label": "Define the relationship between headers and summary nodes",
      "position": {
        "x": 1260,
        "y": 220
      },
      "visible": true,
      "showLabel": true,
      "width": 420,
      "height": 220,
      "data": {
        "body": "Default law: section summaries are optional locally, but required once a section or child graph needs to speak outward with state. The header may point to the summary, but the summary remains a separate node. Summary consumers should replace plain navigation ports when the source can honestly expose state.",
