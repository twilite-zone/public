    {
      "id": "section-header-grammar-goal",
      "type": "goal",
      "label": "Define how headers and sections behave in Twilite graphs",
      "position": {
        "x": 560,
        "y": -140
      },
      "visible": true,
      "showLabel": true,
      "width": 420,
      "height": 240,
      "data": {
        "body": "Create a practical section grammar that covers task boards, libraries, galleries, and implementation graphs without making them all look identical.",
        "priority": "critical",
        "status": "done",
        "owner": "Michael",
        "estimateHours": "4",
        "acceptanceCriteria": [
          "Header role is explicit",
          "Section membership rules are explicit",
          "Cluster and summary relationships are explicit"
        ],
