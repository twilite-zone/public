    {
      "id": "section-header-grammar-open-question",
      "type": "open-question",
      "label": "Should headers ever be connectable, or should that always belong to section summaries?",
      "position": {
        "x": 1740,
        "y": 220
      },
      "visible": true,
      "showLabel": true,
      "width": 420,
      "height": 220,
      "data": {
        "body": "This is the point where structural anchor and semantic label can blur. We need to decide whether that blur is useful or just confusing.",
        "status": "answered",
        "resolutionPath": "Headers are not connectable by default. If a graph really needs a connectable section anchor, upgrade it explicitly or use a separate summary/anchor node instead.",
        "_classBinding": {
          "key": "open-question",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/task-planning/open-question.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/task-planning/open-question.node-class.node",
          "identity": {
            "graphId": "open-question-class",
            "name": "Open Question Class",
            "version": "0.1.0",
            "description": "Unresolved question node for planning graphs.",
            "createdAt": "2026-03-15T20:30:00.000Z",
            "updatedAt": "2026-03-24T01:10:00.000Z"
          },
          "intent": "node-class",
          "meaning": "Unresolved question node for planning graphs.",
          "description": "Unresolved question node for planning graphs.",
          "defaults": {
            "label": "Open Question",
            "size": {
              "width": 340,
              "height": 260
            },
            "color": "linear-gradient(135deg, #ead6ff, #8750c7)",
            "showLabel": false,
