    {
      "id": "section-header-grammar-task-section",
      "type": "task",
      "label": "Define what makes a section real",
      "position": {
        "x": 380,
        "y": 220
      },
      "visible": true,
      "showLabel": true,
      "width": 380,
      "height": 220,
      "data": {
        "body": "Default law: a real named section is `header + members`, with `header + cluster + members` as the strong/default form for larger boards. A cluster alone may group content, but it does not count as a named organizational section without a header.",
