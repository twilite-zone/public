      "data": {
        "title": "Boundary Summary",
        "summary": "Plugins are capability-bearing runtime artifacts. Views are only surfaces they may expose. The web boundary works when role, kind, target exposure, and host-owned port authority are all explicit and effective authority is enforced before any code executes.",
        "scope": "Plugin / port / view boundary",
        "audience": "Builder",
        "status": "active",
        "_classBinding": {
