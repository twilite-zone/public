        "svg": ""
      }
    },
    {
      "id": "m0000000-0000-4ccc-8ccc-000000000007",
      "type": "default",
      "label": "☁️ Hosted Services",
      "position": {
        "x": 195,
        "y": 580
      },
      "width": 280,
      "height": 160,
      "visible": true,
      "showLabel": true,
      "data": {
        "memo": "Monetize compute, previews, collaboration, background agents, secrets, simulations, reliability.",
        "link": "",
        "html": "",
        "svg": ""
      }
    },
    {
      "id": "m0000000-0000-4ddd-8ddd-000000000008",
      "type": "default",
      "label": "🧠 Trust as a Moat",
      "position": {
        "x": 935,
        "y": 900
      },
      "width": 300,
      "height": 160,
      "visible": true,
      "showLabel": true,
      "data": {
        "memo": "Trust compounds faster than features. Never violate continuity, authorship, or user ownership.",
