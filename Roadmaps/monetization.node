        "x": 995,
        "y": 580
      },
      "width": 280,
      "height": 160,
      "visible": true,
      "showLabel": true,
      "data": {
        "memo": "Paid IDE features, graph diffs, validation, simulation, debugging lenses, power-user tooling.",
