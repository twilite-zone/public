    {
      "id": "m0000000-0000-4bbb-8bbb-000000000002",
      "type": "default",
      "label": "🟢 Safe Zone: Leverage",
      "position": {
        "x": 925,
        "y": 250
      },
      "width": 280,
      "height": 160,
      "visible": true,
      "showLabel": true,
      "data": {
        "memo": "Charge for acceleration, power, scale, safety, and convenience — never for existence or access.",
        "link": "",
        "html": "",
        "svg": ""
      }
    },
    {
      "id": "m0000000-0000-4bbb-8bbb-000000000003",
      "type": "default",
      "label": "🔴 Forbidden Zone: Ownership",
      "position": {
        "x": 525,
        "y": 250
      },
      "width": 280,
      "height": 160,
      "visible": true,
      "showLabel": true,
      "data": {
        "memo": "Never paywall graphs, block forks, restrict reading, lock formats, or claim ownership over user thinking.",
        "link": "",
        "html": "",
        "svg": ""
      }
    },
    {
      "id": "m0000000-0000-4bbb-8bbb-000000000004",
      "type": "default",
      "label": "⚠️ Danger Zone: Premature Capture",
      "position": {
        "x": 125,
        "y": 250
      },
      "width": 280,
      "height": 160,
      "visible": true,
      "showLabel": true,
      "data": {
        "memo": "Avoid monetizing too early. Let the medium spread before formalizing revenue boundaries.",
        "link": "",
        "html": "",
        "svg": ""
      }
    },
    {
      "id": "m0000000-0000-4ccc-8ccc-000000000005",
      "type": "default",
      "label": "🛠 Dev Tools (Primary Wedge)",
