        "svg": ""
      }
    },
    {
      "id": "m0000000-0000-4ccc-8ccc-000000000006",
      "type": "default",
      "label": "🚀 Acceleration > Access",
      "position": {
        "x": 595,
        "y": 580
      },
      "width": 280,
      "height": 160,
      "visible": true,
      "showLabel": true,
      "data": {
        "memo": "Free to open, read, fork, and continue. Paid to go faster, safer, and further.",
