    {
      "id": "pat-04",
      "type": "markdown",
      "label": "⚖️ Why This Is Non-Obvious",
      "position": {
        "x": 500,
        "y": 385
      },
      "width": 360,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "Most systems do:\n\nrender → edit → serialize\n\nTwilite does:\n\n**structure → persist → project**\n\nThis inversion changes how AI, humans, and tools interact with state.",
        "memo": "",
        "link": "",
        "html": "",
        "svg": "",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "ref": "/library/classes/nodes/markdown.node-class.node",
          "identity": {
            "graphId": "markdown_class",
            "name": "markdown Node Class",
            "version": "0.1.0",
            "description": "Canonical markdown content node.",
            "createdAt": "2026-02-24T20:05:15Z",
            "updatedAt": "2026-03-24T01:20:00.000Z"
          },
          "intent": "graph",
          "meaning": "Canonical markdown content node.",
          "description": "Canonical markdown content node.",
