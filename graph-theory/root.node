          "sourceBridgeLabel": "Section",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "graph-theory-structure",
      "type": "section",
      "label": "Structure",
      "root": false,
      "position": {
        "x": -820,
        "y": 360
      },
      "width": 430,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Nodes, edges, and nested graphs",
        "summary": "The basic graph vocabulary shows up directly in Twilite. Nodes can be content, tools, contracts, tasks, or views. Edges describe relation. A graph can contain another graph as a navigable or consumable surface instead of collapsing everything into one page.",
        "level": "h2",
        "anchor": "structure",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node",
          "identity": {
            "key": "section",
            "label": "Section"
          },
          "meaning": "A durable document section with structured meaning beyond raw markdown.",
          "description": "Provides a structural region for authored content and ordering.",
