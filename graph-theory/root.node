    {
      "id": "graph-theory-twilite",
      "type": "section",
      "label": "Twilite Application",
      "root": false,
      "position": {
        "x": 180,
        "y": 360
      },
      "width": 430,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Why this matters in Twilite",
        "summary": "Twilite uses graph theory as operating structure. Bridges formalize cross-graph authority. Class bindings let nodes carry durable meaning. Semantic zoom can change what surface is shown without changing the underlying relation graph.",
        "level": "h2",
        "anchor": "twilite-application",
        "status": "active",
        "_classBinding": {
