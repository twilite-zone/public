    {
      "id": "graph-theory-views",
      "type": "section",
      "label": "Views",
      "root": false,
      "position": {
        "x": -320,
        "y": 360
      },
      "width": 430,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Views and point of view",
        "summary": "Graph theory matters here because the same structure can expose different surfaces. Twilite distinguishes port views, icon views, document views, and editor views instead of pretending one rendering is enough for every context.",
        "level": "h2",
        "anchor": "views",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node",
