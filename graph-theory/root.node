    {
      "id": "graph-theory-intro",
      "type": "section",
      "label": "Introduction",
      "root": false,
      "position": {
        "x": -1320,
        "y": 360
      },
      "width": 430,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Introduction",
        "summary": "Twilite is not just inspired by graphs. It is built out of graph primitives: nodes carry state, edges carry relation, views expose surfaces, and bridges make authority explicit between graphs.",
        "level": "h2",
        "anchor": "introduction",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node",
          "identity": {
            "key": "section",
            "label": "Section"
          },
          "meaning": "A durable document section with structured meaning beyond raw markdown.",
          "description": "Provides a structural region for authored content and ordering.",
          "defaults": {
            "label": "Section",
            "size": {
              "width": 420,
              "height": 320
            }
          },
          "views": [
            {
              "intent": "editor",
