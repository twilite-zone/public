      "data": {
        "payload": "node.web.summary",
        "title": "GitHub How-To",
        "purpose": "Use this guide when you need to save a graph to GitHub, understand missing repos, or interpret the toolbar's document/save/access state.",
        "status": "active",
        "viewRole": "summary",
        "viewKind": "display",
        "exposedAuthority": "consume-view",
        "svg": "<svg viewBox=\"0 0 220 160\" xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\"><rect x=\"18\" y=\"18\" width=\"184\" height=\"124\" rx=\"18\" fill=\"#111827\" stroke=\"#374151\" stroke-width=\"5\"/><path d=\"M110 46c-12 0-22 10-22 22 0 9 6 17 14 20 1 0 2-1 2-2v-4c-6 2-7-3-7-3-1-2-3-3-3-3-2-1 0-1 0-1 2 0 3 2 3 2 2 3 5 2 7 2 0-1 1-2 2-3-5-1-10-2-10-11 0-3 1-5 2-6 0-1-1-3 0-5 0 0 2-1 6 2 2-1 4-1 6-1s4 0 6 1c4-3 6-2 6-2 1 2 0 4 0 5 1 1 2 3 2 6 0 9-5 10-10 11 1 1 2 2 2 4v6c0 1 1 2 2 2 8-3 14-11 14-20 0-12-10-22-22-22z\" fill=\"#e5e7eb\"/></svg>",
