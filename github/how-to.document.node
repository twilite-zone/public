        "y": 160
      },
      "width": 420,
      "height": 300,
      "handles": [],
      "ports": [],
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "GitHub How-To",
        "localTitle": "GitHub How-To",
        "publishedTitle": "GitHub How-To",
        "purpose": "Compose the GitHub how-to into one readable document surface.",
        "titleSourceNodeId": "github-howto-title",
        "typeSourceNodeId": "github-howto-type",
        "audience": "Reader",
        "status": "active",
        "viewRole": "document",
        "viewKind": "display",
        "exposedAuthority": "consume-view",
        "runtimeExposed": false,
        "partNodeIds": [
          "github-howto-title",
          "github-howto-status-strip",
          "github-howto-save-flow",
          "github-howto-missing-repos",
