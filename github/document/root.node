    {
      "id": "github-boundaries",
      "type": "section",
      "label": "Boundaries",
      "root": false,
      "position": {
        "x": 880,
        "y": 560
      },
      "width": 430,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Current boundaries",
        "summary": "Twilite can classify GitHub destinations as `Writable`, `Accessible`, or `Blocked`, but only `Blocked` is a hard denial. `Accessible` means the installation can reach the repo even if Twilite cannot fully predict the final write outcome. Public browsing does not require the authoring toolbar, while direct commits still do not replace local checkout-aware workflows such as branching, PR preparation, or Actions investigation.",
        "level": "h2",
        "anchor": "boundaries",
        "status": "active",
        "_classBinding": {
