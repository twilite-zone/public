    {
      "id": "github-usage",
      "type": "section",
      "label": "How To Use",
      "root": false,
      "position": {
        "x": 380,
        "y": 560
      },
      "width": 430,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "How to use it",
        "summary": "Start in browser chrome, then move into authoring controls only when the task calls for a write. `Document` tells you what graph is open, `Save target` tells you where the next write goes, and `Access` tells you which installation context Twilite is using. Missing repos are usually installation-scope issues on GitHub, not local-folder issues. The practical procedure lives in the GitHub setup guide.",
        "level": "h2",
        "anchor": "usage",
        "status": "active",
