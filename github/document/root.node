    {
      "id": "github-hybrid",
      "type": "section",
      "label": "Hybrid Model",
      "root": false,
      "position": {
        "x": -620,
        "y": 560
      },
      "width": 430,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "A clearer GitHub model",
        "summary": "The integration gets easier to trust when five concerns stay separate: document identity, browse path, save target, installation access, and local checkout context. Workspace defaults still matter, but they are advisory. Actual repo visibility comes from the selected GitHub App installation, while branch-aware work still depends on local git context when the connector is not the right authority.",
        "level": "h2",
        "anchor": "hybrid-model",
        "status": "active",
