      "width": 400,
      "height": 280,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Summary",
        "summary": "The ideal Twilite setup is three folders mapped to three repos: `work/`, `public/`, and `private/`. New files should be created in `work/` by default, then moved intentionally once the user decides they belong in `public/` or `private/`. GitHub support remains hybrid: connector-backed repository and pull-request context, local git and gh for checkout-aware work, and explicit publish workflows tied to those mapped destinations.",
        "scope": "GitHub root",
        "audience": "Reader",
        "status": "active",
        "_classBinding": {
          "key": "document-summary",
          "ref": "/library/classes/nodes/document-publishing/document-summary.node-class.node",
          "identity": {
