      "data": {
        "title": "GitHub",
        "localTitle": "GitHub",
        "publishedTitle": "GitHub",
        "purpose": "Compose the dedicated GitHub document into one readable surface.",
        "titleSourceNodeId": "github-title",
        "typeSourceNodeId": "github-type",
        "audience": "Reader",
        "status": "active",
        "viewRole": "document",
        "viewKind": "display",
        "exposedAuthority": "consume-view",
        "runtimeExposed": false,
        "partNodeIds": [
