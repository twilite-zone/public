      "data": {
        "markdown": "## Common problems\n\n- **Repository missing:** grant it to the selected GitHub App installation.\n- **Save denied:** verify write permission and the exact branch/path target.\n- **Old content returns:** refresh the GitHub revision or invalidate the graph cache.\n- **Hosted copy is stale:** publish the committed source; saving and publishing are separate operations.",
        "identity": {
          "graphId": "github-guide"
        }
      }
