      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# GitHub stores graphs\n\nA `github://owner/repository/path.node` address identifies a graph stored in a Git repository. Twilite retrieves that file when you open it and uses GitHub for revision history and authorized writes.\n\nGitHub storage is not the same thing as web hosting. A hosted graph has an `https://` address and a web server responsible for delivering it.",
        "identity": {
          "graphId": "github-guide"
        }
      }
    },
