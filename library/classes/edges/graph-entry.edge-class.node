      "label": "Meaning",
      "position": {
        "x": 1840,
        "y": 330
      },
      "width": 420,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Meaning",
        "body": "The semantic meaning is directional: the source concretely implements the target. This class is for traceable implementation, not loose inspiration or generic association.",
        "strength": "required",
        "_classBinding": {
          "key": "rule",
          "sourceRef": "/library/classes/nodes/skill-contract/rule.node-class.node",
          "ref": "/library/classes/nodes/skill-contract/rule.node-class.node"
        },
        "definitionKey": "rule",
        "markdown": "## Meaning\n\nRead as: from here, enter that graph."
      }
    },
    {
      "id": "graph-entry-rule-default-type",
      "type": "rule",
      "label": "Default Edge Type",
      "position": {
        "x": 1840,
        "y": 620
      },
      "width": 420,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Default Edge Type",
        "body": "Base edge type is `reference`. The class upgrades the edge with semantic meaning and defaults, but it does not require a special runtime edge object.",
        "strength": "default",
        "_classBinding": {
          "key": "rule",
          "sourceRef": "/library/classes/nodes/skill-contract/rule.node-class.node",
          "ref": "/library/classes/nodes/skill-contract/rule.node-class.node"
        },
        "definitionKey": "rule",
        "markdown": "## Default edge type\n\nUse `reference` unless a host introduces a stronger navigation-specific type."
      }
    },
