      "data": {
        "title": "Where This Applies",
        "body": "Applies across planning graphs, contract graphs, and implementation graphs where concrete fulfillment should remain traceable back to the thing being implemented.",
        "conditions": [
          "Implementation tracking",
          "Contract fulfillment",
          "Design realization",
          "Cross-graph traceability"
        ],
        "_classBinding": {
          "key": "scope",
