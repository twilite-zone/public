      "data": {
        "title": "Implements Contract",
        "body": "Defines the reusable implementation relationship for plans, designs, contracts, and the concrete work that fulfills them. This class should be used when implementation traceability is semantically important enough to teach, reuse, or surface in the legend.",
        "category": "edge-classes",
        "authority": "normative",
        "_classBinding": {
          "key": "skill",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/skill-contract/skill.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/skill-contract/skill.node-class.node"
        },
        "definitionKey": "skill",
        "markdown": "## Relationship contract\n\nThis edge class means the source is offering the target as local context that helps the visitor understand the page."
      }
    },
