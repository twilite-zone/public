        "intent": "node",
        "payload": "node.web.detail",
        "html": "<div style=\"width:100%;height:100%;display:flex;flex-direction:column;box-sizing:border-box;align-items:stretch;justify-content:flex-start;padding:0;background:transparent;overflow:hidden;\"><div class=\"doc-body\" style=\"flex:1;min-height:0;overflow:auto;display:flex;flex-direction:column;\">{{data.documentHtml}}</div><script>(function(){var root=document.currentScript&&document.currentScript.parentElement;if(!root)return;var bodyEl=root.querySelector('.doc-body');if(!bodyEl)return;var hasBody=bodyEl.innerHTML&&bodyEl.innerHTML.trim().length>0;if(hasBody)return;bodyEl.innerHTML='<section style=\"padding:18px;border:1px solid rgba(220,38,38,0.22);border-radius:16px;background:linear-gradient(180deg, rgba(254,242,242,0.98), rgba(255,255,255,0.98));display:flex;flex-direction:column;gap:10px;\"><div style=\"font:700 18px/1.25 ui-sans-serif, system-ui, sans-serif;color:#991b1b;\">Document view contract error</div><div style=\"font:500 14px/1.6 ui-sans-serif, system-ui, sans-serif;color:#7f1d1d;\">Document content is missing. Provide documentHtml or documentBlocks.</div></section>';})();<\\/script></div>",
        "semanticLevel": "detail"
      }
