      "data": {
        "key": "editor.web",
        "intent": "editor",
        "payload": "editor.web",
        "html": "<div style=\"width:100%;height:100%;display:flex;flex-direction:column;gap:12px;padding:16px;box-sizing:border-box;background:#f8fafc;overflow:auto;\"><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>Title</span><input data-bind=\"data.title\" value=\"{{data.title}}\" placeholder=\"Enter title\" style=\"border:1px solid rgba(15,23,42,0.14);border-radius:10px;padding:10px 12px;font:500 13px/1.4 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;\" /></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>Title Source Node Id</span><input data-bind=\"data.titleSourceNodeId\" value=\"{{data.titleSourceNodeId}}\" placeholder=\"Optional source node id\" style=\"border:1px solid rgba(15,23,42,0.14);border-radius:10px;padding:10px 12px;font:500 13px/1.4 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;\" /></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>Local Title</span><input data-bind=\"data.localTitle\" value=\"{{data.localTitle}}\" placeholder=\"Optional local/dev override\" style=\"border:1px solid rgba(15,23,42,0.14);border-radius:10px;padding:10px 12px;font:500 13px/1.4 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;\" /></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>Published Title</span><input data-bind=\"data.publishedTitle\" value=\"{{data.publishedTitle}}\" placeholder=\"Optional deployed override\" style=\"border:1px solid rgba(15,23,42,0.14);border-radius:10px;padding:10px 12px;font:500 13px/1.4 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;\" /></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>Type Source Node Id</span><input data-bind=\"data.typeSourceNodeId\" value=\"{{data.typeSourceNodeId}}\" placeholder=\"Optional type node id\" style=\"border:1px solid rgba(15,23,42,0.14);border-radius:10px;padding:10px 12px;font:500 13px/1.4 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;\" /></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>Audience</span><input data-bind=\"data.audience\" value=\"{{data.audience}}\" placeholder=\"Who uses this?\" style=\"border:1px solid rgba(15,23,42,0.14);border-radius:10px;padding:10px 12px;font:500 13px/1.4 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;\" /></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>Status</span><input data-bind=\"data.status\" value=\"{{data.status}}\" placeholder=\"draft | active | archived\" style=\"border:1px solid rgba(15,23,42,0.14);border-radius:10px;padding:10px 12px;font:500 13px/1.4 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;\" /></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>SVG</span><textarea data-bind=\"data.svg\" style=\"min-height:120px;border:1px solid rgba(15,23,42,0.14);border-radius:12px;padding:12px;font:500 12px/1.45 ui-monospace, SFMono-Regular, monospace;color:#111827;background:white;resize:vertical;\">{{data.svg}}</textarea></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;flex:1;min-height:180px;\"><span>Body</span><textarea data-bind=\"data.purpose\" style=\"flex:1;min-height:180px;border:1px solid rgba(15,23,42,0.14);border-radius:12px;padding:12px;font:500 13px/1.5 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;resize:vertical;\">{{data.purpose}}</textarea></label><div style=\"display:flex;flex-direction:column;gap:10px;padding:14px;border:1px solid rgba(15,23,42,0.12);border-radius:14px;background:rgba(255,255,255,0.78);\"><div style=\"font:700 12px/1.2 ui-sans-serif, system-ui, sans-serif;color:#0f172a;letter-spacing:0.04em;text-transform:uppercase;\">Node View Live Preview</div><div style=\"display:grid;grid-template-columns:minmax(0,1.4fr) minmax(0,1fr) minmax(0,0.8fr);gap:10px;\"><div style=\"display:flex;flex-direction:column;gap:8px;padding:12px;border-radius:14px;background:linear-gradient(180deg, rgba(255,255,255,0.98), rgba(250,250,250,0.94));border:1px solid rgba(15,23,42,0.12);min-height:204px;\"><div style=\"font:700 11px/1.2 ui-sans-serif, system-ui, sans-serif;color:#64748b;text-transform:uppercase;\">Detail</div><div style=\"flex:1;min-height:64px;display:flex;align-items:center;justify-content:center;overflow:hidden;\">{{data.svg}}</div><div style=\"font:700 16px/1.2 ui-sans-serif, system-ui, sans-serif;color:#111827;text-align:center;\">{{data.title}}</div><div style=\"font:500 12px/1.45 ui-sans-serif, system-ui, sans-serif;color:#475569;text-align:center;white-space:pre-wrap;overflow:hidden;\">{{data.purpose}}</div></div><div style=\"display:flex;flex-direction:column;gap:8px;padding:12px;border-radius:14px;background:white;border:1px solid rgba(15,23,42,0.12);min-height:180px;\"><div style=\"font:700 11px/1.2 ui-sans-serif, system-ui, sans-serif;color:#64748b;text-transform:uppercase;\">Summary</div><div style=\"flex:1;min-height:64px;display:flex;align-items:center;justify-content:center;overflow:hidden;\">{{data.svg}}</div><div style=\"font:700 14px/1.2 ui-sans-serif, system-ui, sans-serif;color:#111827;text-align:center;\">{{data.title}}</div></div><div style=\"display:flex;flex-direction:column;gap:8px;padding:12px;border-radius:14px;background:white;border:1px solid rgba(15,23,42,0.12);min-height:156px;\"><div style=\"font:700 11px/1.2 ui-sans-serif, system-ui, sans-serif;color:#64748b;text-transform:uppercase;\">Icon</div><div style=\"flex:1;min-height:64px;display:flex;align-items:center;justify-content:center;overflow:hidden;\">{{data.svg}}</div><div style=\"font:700 12px/1.2 ui-sans-serif, system-ui, sans-serif;color:#111827;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;\">{{data.title}}</div></div></div></div></div>",
