      "showLabel": true,
      "data": {
        "markdown": "# Node View Node Class\n\nDedicated primitive for the ordinary on-graph surface of a node instance.\n\n- use when the node itself is the summarized artifact on a graph\n- clearer than a generic `ui-view` with `viewRole: node`\n- defaults to `viewKind: interactive`, not `runtime`\n- distinct from `port-view`, which is the host-facing destination surface",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "ref": "/library/classes/nodes/markdown.node-class.node",
          "identity": {
