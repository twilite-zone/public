      "data": {
        "title": "Bounded Work Contract",
        "allowedActions": "Read the relevant files, make the scoped change, and run validation needed to prove the result.",
        "safetyLimits": "Do not exceed the declared write scope. Do not destroy existing work. Escalate when uncertainty is material.",
        "requiredOutputs": "A visible result, traceable evidence, and a handoff package if review is needed.",
        "escalationRule": "Escalate when the change would cross the current write boundary or when requirements conflict.",
        "approvalRequirement": "Reviewer approval before merge or publish.",
