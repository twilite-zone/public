tions</div>\n      <div style='font:500 14px/1.42 system-ui,sans-serif;max-height:4.8em;overflow:hidden;white-space:pre-wrap;'>{{data.allowedActions}}</div>\n    </div>\n    <div style='padding:12px 13px 11px 13px;border-radius:14px;background:rgba(255,255,255,.76);border:1px solid rgba(0,0,0,.06);'>\n      <div style='font:700 10px system-ui,sans-serif;letter-spacing:.14em;text-transform:uppercase;opacity:.66;margin-bottom:6px;'>Safety Limits</div>\n      <div style='font:500 14px/1.42 system-ui,sans-serif;max-height:4.8em;overflow:hidden;white-space:pre-wrap;'>{{data.safetyLimits}}</div>\n    </div>\n  </div>\n</div>"
