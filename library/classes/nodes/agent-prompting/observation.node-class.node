                "type": "text",
                "path": "data.source",
                "placeholder": "tool output, review note, file read"
              },
              {
                "key": "timestamp",
                "label": "Timestamp",
                "type": "text",
                "path": "data.timestamp",
                "placeholder": "ISO timestamp or run-relative marker"
              },
              {
                "key": "toolRef",
                "label": "Tool Ref",
                "type": "text",
                "path": "data.toolRef",
                "placeholder": "tool id or name"
              },
              {
                "key": "confidence",
                "label": "Confidence",
                "type": "select",
                "path": "data.confidence",
                "options": [
                  {
                    "label": "High",
                    "value": "high"
                  },
                  {
                    "label": "Medium",
                    "value": "medium"
                  },
                  {
                    "label": "Low",
                    "value": "low"
                  }
                ]
              },
