    {
      "id": "task-graph-summary-node-view",
      "type": "view",
      "label": "Node View (node.web)",
      "position": {
        "x": -320,
        "y": 20
      },
      "width": 460,
    "height": 360,
      "visible": true,
      "showLabel": true,
      "data": {
        "view": {
          "intent": "node",
          "payload": "node.web",
          "html": {
            "chrome": true
          }
        },
        "node": {
          "web": {
        "html": "<div style='width:100%;height:100%;display:flex;flex-direction:column;box-sizing:border-box;padding:0;overflow:hidden;border-radius:18px;background:linear-gradient(180deg, rgba(255,255,255,.96), rgba(228,247,239,.94));color:#23160a;position:relative;border:1px solid rgba(0,0,0,.08);'>\n  <div style='display:flex;align-items:center;justify-content:space-between;gap:10px;padding:10px 14px;background:linear-gradient(135deg, #9be7c4, #1f9d67);color:#082618;border-bottom:1px solid rgba(0,0,0,.08);'>\n    <div style='display:flex;align-items:center;gap:10px;min-width:0;'>\n      <div style='width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:{{eq(data.status, \"done\", \"rgba(31,157,103,.20)\", \"rgba(255,255,255,.18)\")}};border:1px solid {{eq(data.status, \"done\", \"rgba(8,38,24,.24)\", \"rgba(8,38,24,.32)\")}};color:#082618;font:800 14px system-ui,sans-serif;flex:0 0 auto;'><span aria-hidden=\"true\" style=\"display:{{eq(data.status, 'in-progress', 'inline', 'none')}};color:#2563eb;\">◐</span><span aria-hidden=\"true\" style=\"display:{{eq(data.status, 'done', 'inline', 'none')}};color:#166534;\">✓</span><span aria-hidden=\"true\" style=\"display:{{eq(data.status, 'achieved', 'inline', 'none')}};color:#166534;\">✓</span><span aria-hidden=\"true\" style=\"display:{{eq(data.status, 'blocked', 'inline', 'none')}};color:#b91c1c;\">!</span><span aria-hidden=\"true\" style=\"display:{{eq(data.status, 'waiting', 'inline', 'none')}};color:#92400e;\">Ⅱ</span><span aria-hidden=\"true\" style=\"display:{{eq(data.status, 'cancelled', 'inline', 'none')}};color:#475569;\">×</span></div>\n      <div style='min-width:0;'>\n        <div style='font:700 10px system-ui,sans-serif;letter-spacing:.16em;text-transform:uppercase;opacity:.68;margin-bottom:2px;'>Task Graph</div>\n        <div style='font:800 18px/1.02 Georgia, \"Times New Roman\", serif;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;'>{{data.goal}}</div>\n      </div>\n    </div>\n    <div style='display:inline-flex;align-items:center;justify-content:center;padding:5px 9px;border-radius:999px;background:rgba(255,255,255,.38);border:1px solid rgba(0,0,0,.08);font:700 10px system-ui,sans-serif;text-transform:uppercase;white-space:nowrap;'>{{data.status}}</div>\n  </div>\n  <div style='display:flex;flex-direction:column;gap:12px;padding:14px 16px;min-height:0;flex:1;color:#23160a;'>\n    <div style='display:flex;align-items:center;gap:7px;flex-wrap:wrap;font:700 10px system-ui,sans-serif;color:#5b4731;'>\n      <span>Priority {{data.priority}}</span><span>•</span><span>Health {{data.health}}</span><span>•</span><span>Owner {{data.owner}}</span><span>•</span><span>Target {{data.targetDate}}</span>\n    </div>\n    <div style='padding:9px 11px;border-radius:12px;background:rgba(31,157,103,.12);border:1px solid rgba(0,0,0,.06);font:600 11px/1.35 system-ui,sans-serif;color:#23160a;'>\n      <div><strong>Next:</strong> {{data.nextAction}}</div>\n      <div style='margin-top:4px;color:#7a3e2d;'><strong>Blocker:</strong> {{data.blockedReason}}</div>\n    </div>\n    <div style='display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;'>\n      <div style='padding:10px 12px;border-radius:12px;background:rgba(255,255,255,.72);border:1px solid rgba(0,0,0,.06);'>\n        <div style='font:700 10px system-ui,sans-serif;letter-spacing:.13em;text-transform:uppercase;opacity:.72;color:#3b5b47;'>Tasks</div>\n        <div style='margin-top:6px;font:800 24px/1 Georgia, \"Times New Roman\", serif;color:#23160a;'>{{data.taskProgress.completed}} / {{data.taskProgress.total}}</div>\n      </div>\n      <div style='padding:10px 12px;border-radius:12px;background:rgba(255,255,255,.72);border:1px solid rgba(0,0,0,.06);'>\n        <div style='font:700 10px system-ui,sans-serif;letter-spacing:.13em;text-transform:uppercase;opacity:.72;color:#3b5b47;'>Questions</div>\n        <div style='margin-top:6px;font:800 24px/1 Georgia, \"Times New Roman\", serif;color:#23160a;'>{{data.questionProgress.answered}} / {{data.questionProgress.total}}</div>\n      </div>\n    </div>\n    <div style='display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;min-height:0;flex:1;'>\n      <div style='padding:10px 12px;border-radius:12px;background:rgba(255,255,255,.72);border:1px solid rgba(0,0,0,.06);min-height:0;'>\n        <div style='font:700 10px system-ui,sans-serif;letter-spacing:.13em;text-transform:uppercase;opacity:.66;color:#6b533a;margin-bottom:6px;'>Tasks in scope</div>\n        <div style='font:600 11px/1.35 system-ui,sans-serif;color:#23160a;white-space:pre-wrap;max-height:8.4em;overflow:auto;'>{{data.taskListText}}</div>\n      </div>\n      <div style='padding:10px 12px;border-radius:12px;background:rgba(255,255,255,.72);border:1px solid rgba(0,0,0,.06);min-height:0;'>\n        <div style='font:700 10px system-ui,sans-serif;letter-spacing:.13em;text-transform:uppercase;opacity:.66;color:#6b533a;margin-bottom:6px;'>Open questions</div>\n        <div style='font:600 11px/1.35 system-ui,sans-serif;color:#23160a;white-space:pre-wrap;max-height:8.4em;overflow:auto;'>{{data.questionListText}}</div>\n      </div>\n    </div>\n  <div style='padding:0 16px 9px;font:600 9px system-ui,sans-serif;color:#6b7280;'>Updated {{data.updatedAt}}</div>\n</div>"
          }
        }
      }
    },
