        "node": {
          "web": {
            "html": "<div style='width:100%;height:100%;display:flex;flex-direction:column;box-sizing:border-box;padding:0;overflow:hidden;border-radius:16px;background:linear-gradient(180deg, rgba(255,255,255,.96), rgba(228,247,239,.94));color:#23160a;position:relative;'>\n  <div style='padding:8px 10px 6px 10px;background:linear-gradient(135deg, #9be7c4, #1f9d67);color:#082618;border-bottom:1px solid rgba(0,0,0,.08);'>\n    <div style='display:flex;align-items:flex-start;justify-content:space-between;gap:6px;'>\n      <div style='min-width:0;flex:1 1 auto;'>\n        <div style='font:700 8px system-ui,sans-serif;letter-spacing:.15em;text-transform:uppercase;opacity:.7;margin-bottom:2px;'>Task summary provider</div>\n        <div style='font:800 15px/1.02 Georgia, \"Times New Roman\", serif;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;'>{{data.goal}}</div>\n      </div>\n      <div style='display:inline-flex;align-items:center;justify-content:center;padding:3px 7px;border-radius:999px;background:rgba(255,255,255,.38);border:1px solid rgba(0,0,0,.08);font:700 8px system-ui,sans-serif;text-transform:uppercase;white-space:nowrap;flex:0 0 auto;'>{{data.status}}</div>\n    </div>\n    <div style='display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:6px;margin-top:6px;'>\n      <div style='padding:6px 7px;border-radius:10px;background:rgba(255,255,255,.58);border:1px solid rgba(0,0,0,.06);min-width:0;'>\n        <div style='font:700 8px system-ui,sans-serif;letter-spacing:.13em;text-transform:uppercase;opacity:.72;color:#3b5b47;'>Tasks</div>\n        <div style='font:800 16px/1 Georgia, \"Times New Roman\", serif;color:#23160a;margin-top:2px;'>{{data.taskProgress.completed}}/{{data.taskProgress.total}}</div>\n      </div>\n      <div style='padding:6px 7px;border-radius:10px;background:rgba(255,255,255,.58);border:1px solid rgba(0,0,0,.06);min-width:0;'>\n        <div style='font:700 8px system-ui,sans-serif;letter-spacing:.13em;text-transform:uppercase;opacity:.72;color:#3b5b47;'>Questions</div>\n        <div style='font:800 16px/1 Georgia, \"Times New Roman\", serif;color:#23160a;margin-top:2px;'>{{data.questionProgress.answered}}/{{data.questionProgress.total}}</div>\n      </div>\n    </div>\n  </div>\n  <div style='display:flex;flex-direction:column;gap:6px;padding:8px 10px 10px 10px;min-height:0;flex:1;color:#23160a;'>\n    <div style='display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:6px;min-height:0;'>\n      <div style='padding:6px 7px;border-radius:10px;background:rgba(255,255,255,.72);border:1px solid rgba(0,0,0,.06);min-width:0;min-height:0;'>\n        <div style='font:700 8px system-ui,sans-serif;letter-spacing:.13em;text-transform:uppercase;opacity:.66;color:#3b5b47;margin-bottom:3px;'>Tasks in scope</div>\n        <div style='font:600 9px/1.22 system-ui,sans-serif;color:#23160a;white-space:pre-wrap;max-height:7.4em;overflow:auto;padding-right:2px;'>{{data.taskListText}}</div>\n      </div>\n      <div style='padding:6px 7px;border-radius:10px;background:rgba(255,255,255,.72);border:1px solid rgba(0,0,0,.06);min-width:0;min-height:0;'>\n        <div style='font:700 8px system-ui,sans-serif;letter-spacing:.13em;text-transform:uppercase;opacity:.66;color:#3b5b47;margin-bottom:3px;'>Open questions</div>\n        <div style='font:600 9px/1.22 system-ui,sans-serif;color:#23160a;white-space:pre-wrap;max-height:7.4em;overflow:auto;padding-right:2px;'>{{data.questionListText}}</div>\n      </div>\n    </div>\n    <div style='padding:7px 8px;border-radius:10px;background:rgba(255,255,255,.76);border:1px solid rgba(0,0,0,.06);margin-top:auto;'>\n      <div style='font:700 8px system-ui,sans-serif;letter-spacing:.13em;text-transform:uppercase;opacity:.66;margin-bottom:3px;color:#3b5b47;'>Current read</div>\n      <div style='font:600 10px/1.28 system-ui,sans-serif;color:#23160a;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;'>{{data.goal}}</div>\n    </div>\n  </div>\n</div>"
