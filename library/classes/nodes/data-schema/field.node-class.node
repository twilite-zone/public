    {
      "id": "field-editor-view",
      "type": "view",
      "label": "Field Editor",
      "position": {
        "x": -120,
        "y": -160
      },
      "visible": true,
      "showLabel": true,
      "width": 520,
      "height": 340,
      "data": {
        "view": {
          "intent": "editor",
          "payload": "editor.web"
        },
        "key": "editor.web",
        "intent": "editor",
        "payload": "editor.web",
        "editor": {
          "web": {
            "fields": [
              {
                "key": "title",
                "label": "Title",
                "type": "text",
                "path": "data.title",
                "placeholder": "Type"
              },
              {
                "key": "value",
                "label": "Value",
                "type": "text",
                "path": "data.value",
                "placeholder": "contract"
              },
              {
                "key": "fieldType",
                "label": "Field Type",
                "type": "select",
                "path": "data.fieldType",
                "options": [
                  {
                    "label": "String",
                    "value": "string"
                  },
                  {
                    "label": "Number",
                    "value": "number"
                  },
                  {
                    "label": "Boolean",
                    "value": "boolean"
                  },
                  {
                    "label": "Reference",
                    "value": "reference"
                  }
                ]
              },
              {
                "key": "required",
                "label": "Required",
                "type": "select",
                "path": "data.required",
                "options": [
                  {
                    "label": "True",
                    "value": "true"
                  },
                  {
                    "label": "False",
                    "value": "false"
                  }
                ]
              },
              {
                "key": "description",
                "label": "Description",
                "type": "markdown",
                "path": "data.description",
                "placeholder": "Declare the value this field carries and the shape it should use.",
                "multiline": true,
                "rows": 6
              }
            ]
          }
        },
        "html": "<div style=\"width:100%;height:100%;display:flex;flex-direction:column;gap:12px;padding:16px;box-sizing:border-box;background:#f8fafc;overflow:auto;\"><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>Title</span><input data-bind=\"data.title\" value=\"{{data.title}}\" placeholder=\"Enter title\" style=\"border:1px solid rgba(15,23,42,0.14);border-radius:10px;padding:10px 12px;font:500 13px/1.4 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;\" /></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>Value</span><input data-bind=\"data.value\" value=\"{{data.value}}\" placeholder=\"contract | template | view\" style=\"border:1px solid rgba(15,23,42,0.14);border-radius:10px;padding:10px 12px;font:500 13px/1.4 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;\" /></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>Field Type</span><input data-bind=\"data.fieldType\" value=\"{{data.fieldType}}\" placeholder=\"string | number | boolean\" style=\"border:1px solid rgba(15,23,42,0.14);border-radius:10px;padding:10px 12px;font:500 13px/1.4 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;\" /></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>Required</span><input data-bind=\"data.required\" value=\"{{data.required}}\" placeholder=\"true | false\" style=\"border:1px solid rgba(15,23,42,0.14);border-radius:10px;padding:10px 12px;font:500 13px/1.4 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;\" /></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;flex:1;min-height:180px;\"><span>Body</span><textarea data-bind=\"data.description\" style=\"flex:1;min-height:180px;border:1px solid rgba(15,23,42,0.14);border-radius:12px;padding:12px;font:500 13px/1.5 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;resize:vertical;\">{{data.description}}</textarea></label></div>",
        "semanticLevel": "detail"
      }
    },
    {
      "id": "field-detail-view",
