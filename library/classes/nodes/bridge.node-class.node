              { "key": "exposeViews", "label": "Views Exposure", "path": "data.bridge.exposure.views.mode", "type": "checkbox", "trueValue": "allow", "falseValue": "deny" },
              { "key": "viewsMode", "label": "Views Policy", "path": "data.bridge.exposure.views.mode", "type": "select", "options": ["allow", "deny", "allowlist", "denylist"] },
