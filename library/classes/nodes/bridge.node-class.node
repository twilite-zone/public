        "editor": {
          "web": {
            "host": { "kind": "bridge-editor" },
            "fields": [
              { "key": "label", "label": "Label", "path": "label", "type": "text", "placeholder": "Bridge" },
              { "key": "memo", "label": "Bridge Note", "path": "data.memo", "type": "multiline", "rows": 5, "placeholder": "Describe why this bridge exists and what it should expose." },
