              { "key": "exposeNodeClasses", "label": "Node Classes Exposure", "path": "data.bridge.exposure.nodeClasses.mode", "type": "checkbox", "trueValue": "allow", "falseValue": "deny" },
              { "key": "nodesMode", "label": "Node Classes Policy", "path": "data.bridge.exposure.nodeClasses.mode", "type": "select", "options": ["allow", "deny", "allowlist", "denylist"] },
