              { "key": "exposeEdgeClasses", "label": "Edge Classes Exposure", "path": "data.bridge.exposure.edgeClasses.mode", "type": "checkbox", "trueValue": "allow", "falseValue": "deny" },
              { "key": "edgesMode", "label": "Edge Classes Policy", "path": "data.bridge.exposure.edgeClasses.mode", "type": "select", "options": ["allow", "deny", "allowlist", "denylist"] },
              { "key": "edgesAllowKeys", "label": "Edge Class Keys", "path": "data.bridge.exposure.edgeClasses.allowKeys", "type": "multiline", "rows": 3, "placeholder": "task.depends-on\nplanning.answers" },

              { "key": "exposeScripts", "label": "Scripts Exposure", "path": "data.bridge.exposure.scripts.mode", "type": "checkbox", "trueValue": "allow", "falseValue": "deny" },
