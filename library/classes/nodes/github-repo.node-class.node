    {
      "id": "github-repo-instance-editor-view",
      "type": "view",
      "label": "Instance Editor View",
      "position": {
        "x": -420,
        "y": 380
      },
      "width": 520,
      "height": 360,
      "visible": true,
      "showLabel": true,
      "data": {
        "view": {
          "intent": "editor",
          "payload": "editor.web"
        },
        "editor": {
          "web": {
            "fields": [
              {
                "key": "title",
                "label": "Title",
                "type": "text",
                "path": "data.title",
                "placeholder": "Twilite Zone Repo"
              },
              {
                "key": "owner",
                "label": "Owner",
                "type": "text",
                "path": "data.owner",
                "placeholder": "twilitellc"
              },
              {
                "key": "repo",
                "label": "Repo",
                "type": "text",
                "path": "data.repo",
                "placeholder": "public"
              },
              {
                "key": "branch",
                "label": "Branch",
                "type": "text",
                "path": "data.branch",
                "placeholder": "main"
              },
              {
                "key": "homeRef",
                "label": "Home Ref",
                "type": "text",
                "path": "data.homeRef",
                "placeholder": "/root.node"
              },
              {
                "key": "notes",
                "label": "Notes",
                "type": "markdown",
                "path": "data.notes",
                "placeholder": "What this repo is for and why its home matters",
                "multiline": true,
                "rows": 8
              }
            ]
          }
        }
      }
    },
    {
      "id": "github-repo-instance-detail-view",
      "type": "view",
      "label": "Instance Detail View",
      "position": {
        "x": 180,
        "y": 380
      },
      "width": 520,
      "height": 340,
      "visible": true,
      "showLabel": true,
      "data": {
        "key": "node.web.detail",
        "intent": "node",
        "payload": "node.web.detail",
        "view": {
          "controls": [
            {
              "id": "open-repo-home",
              "type": "button",
              "label": "Open Repo",
              "action": "navigate",
              "url": "github://{{data.owner}}/{{data.repo}}{{data.homeRef}}",
              "variant": "contained",
              "priority": -30,
              "icon": "navigate"
            }
          ]
        },
        "html": "<div style=\"width:100%;height:100%;display:flex;flex-direction:column;gap:16px;padding:18px;box-sizing:border-box;border-radius:22px;background:linear-gradient(180deg,#ffffff,#f8fafc);border:1px solid rgba(15,23,42,0.12);overflow:hidden;\"><div style=\"display:flex;align-items:center;justify-content:space-between;gap:12px;\"><div style=\"display:flex;align-items:center;gap:12px;\"><div style=\"width:56px;height:56px;border-radius:16px;background:#0f172a;display:flex;align-items:center;justify-content:center;box-shadow:inset 0 0 0 1px rgba(255,255,255,0.08);\"><svg viewBox=\"0 0 64 64\" width=\"34\" height=\"34\" xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\"><path fill=\"#f8fafc\" d=\"M32 7C18.19 7 7 18.19 7 32c0 11.05 7.16 20.43 17.1 23.74 1.25.23 1.71-.54 1.71-1.2 0-.59-.02-2.15-.03-4.22-6.95 1.51-8.42-3.35-8.42-3.35-1.14-2.9-2.78-3.67-2.78-3.67-2.28-1.56.17-1.53.17-1.53 2.52.18 3.85 2.59 3.85 2.59 2.24 3.84 5.87 2.73 7.3 2.09.23-1.62.88-2.73 1.59-3.36-5.55-.63-11.39-2.78-11.39-12.36 0-2.73.97-4.96 2.57-6.71-.26-.63-1.11-3.16.24-6.59 0 0 2.1-.67 6.88 2.56A23.9 23.9 0 0 1 32 19.2c2.12.01 4.25.29 6.24.85 4.77-3.23 6.87-2.56 6.87-2.56 1.35 3.43.5 5.96.25 6.59 1.6 1.75 2.57 3.98 2.57 6.71 0 9.61-5.85 11.72-11.42 12.34.9.78 1.7 2.31 1.7 4.66 0 3.36-.03 6.07-.03 6.9 0 .67.45 1.44 1.72 1.2C49.84 52.42 57 43.05 57 32 57 18.19 45.81 7 32 7Z\"/></svg></div><div style=\"display:flex;flex-direction:column;gap:4px;\"><div style=\"font:700 12px/1.2 ui-sans-serif,system-ui,sans-serif;letter-spacing:0.08em;text-transform:uppercase;color:#64748b;\">GitHub Repo</div><div style=\"font:800 24px/1.15 ui-sans-serif,system-ui,sans-serif;color:#0f172a;\">{{data.title}}</div></div></div><div style=\"padding:6px 10px;border-radius:999px;background:rgba(59,130,246,0.1);color:#1d4ed8;font:700 11px/1.2 ui-sans-serif,system-ui,sans-serif;letter-spacing:0.06em;text-transform:uppercase;\">{{data.branch}}</div></div><div style=\"display:flex;flex-direction:column;gap:8px;padding:14px 16px;border-radius:18px;background:#0f172a;color:#f8fafc;\"><div style=\"font:700 11px/1.2 ui-sans-serif,system-ui,sans-serif;letter-spacing:0.08em;text-transform:uppercase;color:rgba(248,250,252,0.7);\">Repository Identity</div><div style=\"font:700 18px/1.25 ui-monospace,SFMono-Regular,monospace;color:#f8fafc;\">{{data.owner}}/{{data.repo}}</div><div style=\"font:500 12px/1.45 ui-monospace,SFMono-Regular,monospace;color:rgba(248,250,252,0.82);\">github://{{data.owner}}/{{data.repo}}</div></div><div style=\"display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;\"><div style=\"padding:14px;border-radius:18px;background:rgba(15,23,42,0.04);border:1px solid rgba(15,23,42,0.08);\"><div style=\"font:700 11px/1.2 ui-sans-serif,system-ui,sans-serif;letter-spacing:0.08em;text-transform:uppercase;color:#64748b;\">Home Ref</div><div style=\"margin-top:8px;font:700 14px/1.3 ui-monospace,SFMono-Regular,monospace;color:#0f172a;\">{{data.homeRef}}</div></div><div style=\"padding:14px;border-radius:18px;background:rgba(15,23,42,0.04);border:1px solid rgba(15,23,42,0.08);\"><div style=\"font:700 11px/1.2 ui-sans-serif,system-ui,sans-serif;letter-spacing:0.08em;text-transform:uppercase;color:#64748b;\">Resolution Rule</div><div style=\"margin-top:8px;font:600 13px/1.45 ui-sans-serif,system-ui,sans-serif;color:#334155;\">Declaration wins. <span style=\"font-family:ui-monospace,SFMono-Regular,monospace;\">/root.node</span> bootstraps.</div></div></div><div style=\"font:500 14px/1.55 ui-sans-serif,system-ui,sans-serif;color:#334155;white-space:pre-wrap;overflow:auto;\">{{data.notes}}</div></div>",
        "semanticLevel": "detail"
      }
    },
