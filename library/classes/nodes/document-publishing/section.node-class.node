      "data": {
        "key": "editor.web",
        "intent": "editor",
        "payload": "editor.web",
        "html": "<div style=\"width:100%;height:100%;display:flex;flex-direction:column;gap:12px;padding:16px;box-sizing:border-box;background:#f8fafc;overflow:auto;\"><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>Title</span><input data-bind=\"data.title\" value=\"{{data.title}}\" placeholder=\"Enter title\" style=\"border:1px solid rgba(15,23,42,0.14);border-radius:10px;padding:10px 12px;font:500 13px/1.4 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;\" /></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>Level</span><input data-bind=\"data.level\" value=\"{{data.level}}\" placeholder=\"h1 | h2 | h3\" style=\"border:1px solid rgba(15,23,42,0.14);border-radius:10px;padding:10px 12px;font:500 13px/1.4 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;\" /></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;\"><span>Anchor</span><input data-bind=\"data.anchor\" value=\"{{data.anchor}}\" placeholder=\"section-anchor\" style=\"border:1px solid rgba(15,23,42,0.14);border-radius:10px;padding:10px 12px;font:500 13px/1.4 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;\" /></label><label style=\"display:flex;flex-direction:column;gap:6px;font:600 12px/1.4 ui-sans-serif, system-ui, sans-serif;color:#4b5563;flex:1;min-height:180px;\"><span>Body</span><textarea data-bind=\"data.summary\" style=\"flex:1;min-height:180px;border:1px solid rgba(15,23,42,0.14);border-radius:12px;padding:12px;font:500 13px/1.5 ui-sans-serif, system-ui, sans-serif;color:#111827;background:white;resize:vertical;\">{{data.summary}}</textarea></label></div>",
        "semanticLevel": "detail"
      }
