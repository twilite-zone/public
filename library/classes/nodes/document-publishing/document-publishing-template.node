        "viewKind": "display",
        "exposedAuthority": "consume-view",
        "svg": "<svg viewBox=\"0 0 220 160\" xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\"><defs><linearGradient id=\"templateBg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0%\" stop-color=\"#faf5ff\"/><stop offset=\"100%\" stop-color=\"#eff6ff\"/></linearGradient><linearGradient id=\"templateFront\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\"><stop offset=\"0%\" stop-color=\"#fffdf8\"/><stop offset=\"100%\" stop-color=\"#fff7ed\"/></linearGradient></defs><rect x=\"34\" y=\"24\" width=\"118\" height=\"86\" rx=\"16\" fill=\"#ede9fe\" stroke=\"#7c3aed\" stroke-width=\"4\" opacity=\"0.95\"/><rect x=\"58\" y=\"42\" width=\"128\" height=\"92\" rx=\"18\" fill=\"url(#templateBg)\" stroke=\"#6366f1\" stroke-width=\"4\"/><rect x=\"74\" y=\"26\" width=\"112\" height=\"94\" rx=\"18\" fill=\"url(#templateFront)\" stroke=\"#c2410c\" stroke-width=\"4\"/><rect x=\"92\" y=\"40\" width=\"54\" height=\"10\" rx=\"5\" fill=\"#f59e0b\" opacity=\"0.9\"/><rect x=\"92\" y=\"60\" width=\"78\" height=\"12\" rx=\"6\" fill=\"#1d4ed8\" opacity=\"0.9\"/><rect x=\"92\" y=\"80\" width=\"66\" height=\"10\" rx=\"5\" fill=\"#60a5fa\" opacity=\"0.7\"/><rect x=\"92\" y=\"98\" width=\"74\" height=\"10\" rx=\"5\" fill=\"#cbd5e1\"/><rect x=\"146\" y=\"116\" width=\"28\" height=\"10\" rx=\"5\" fill=\"#22c55e\" opacity=\"0.9\"/><rect x=\"24\" y=\"116\" width=\"76\" height=\"18\" rx=\"9\" fill=\"#312e81\"/><text x=\"62\" y=\"128\" text-anchor=\"middle\" font-family=\"ui-sans-serif, system-ui, sans-serif\" font-size=\"9\" font-weight=\"700\" fill=\"#eef2ff\" letter-spacing=\"0.12em\">TEMPLATE</text><rect x=\"170\" y=\"22\" width=\"26\" height=\"26\" rx=\"8\" fill=\"#ffffff\" stroke=\"#0f172a\" stroke-width=\"3\"/><path d=\"M178 30h10M183 25v10\" stroke=\"#0f172a\" stroke-width=\"3\" stroke-linecap=\"round\"/></svg>",
