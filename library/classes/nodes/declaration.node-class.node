        "html": "<div style=\"width:100%;height:100%;display:flex;flex-direction:column;gap:12px;padding:18px;box-sizing:border-box;border-radius:18px;background:linear-gradient(180deg, rgba(255,255,255,0.98), rgba(243,244,255,0.96));border:1px solid rgba(109,40,217,0.14);overflow:hidden;\"><div style=\"display:flex;align-items:flex-start;justify-content:space-between;gap:12px;\"><div style=\"display:flex;flex-direction:column;gap:6px;min-width:0;\"><div style=\"font:700 11px/1.2 ui-sans-serif, system-ui, sans-serif;letter-spacing:0.18em;text-transform:uppercase;color:#7c3aed;\">Editor Surface</div><div style=\"font:700 24px/1.12 ui-sans-serif, system-ui, sans-serif;color:#312e81;\">Declaration Editor</div></div><div style=\"padding:4px 8px;border-radius:999px;background:rgba(124,58,237,0.1);color:#5b21b6;font:700 11px/1 ui-sans-serif, system-ui, sans-serif;\">form-driven</div></div><div style=\"display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;\"><div style=\"padding:10px 12px;border-radius:12px;background:white;border:1px solid rgba(109,40,217,0.12);font:600 12px/1.35 ui-sans-serif, system-ui, sans-serif;color:#4338ca;\">Identity fields</div><div style=\"padding:10px 12px;border-radius:12px;background:white;border:1px solid rgba(109,40,217,0.12);font:600 12px/1.35 ui-sans-serif, system-ui, sans-serif;color:#4338ca;\">Intent and target mode</div><div style=\"padding:10px 12px;border-radius:12px;background:white;border:1px solid rgba(109,40,217,0.12);font:600 12px/1.35 ui-sans-serif, system-ui, sans-serif;color:#4338ca;\">Surface bindings</div><div style=\"padding:10px 12px;border-radius:12px;background:white;border:1px solid rgba(109,40,217,0.12);font:600 12px/1.35 ui-sans-serif, system-ui, sans-serif;color:#4338ca;\">Purpose and description</div></div><div style=\"padding:12px 14px;border-radius:14px;background:rgba(255,255,255,0.88);border:1px solid rgba(109,40,217,0.12);font:500 13px/1.5 ui-sans-serif, system-ui, sans-serif;color:#4c1d95;\">This specimen previews the editor contract for declaration nodes. The actual editable schema still lives in <span style=\"font-weight:700;color:#312e81;\">data.editor.web.fields</span>; the card here is just the visual surface specimen.</div></div>",
