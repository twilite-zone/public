      "width": 540,
      "height": 280,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "## Story Context\n\nThis template is for product graphs that need to do three things quickly:\n\n- tell a newcomer what the product is\n- make the first click obvious\n- provide just enough proof or framing to keep the story grounded\n\nIt should stay lighter than a full document and more intentional than a loose collection of markdown nodes.",
        "definitionKey": "markdown",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
