      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Contract: Validation Rules\n\nThis graph defines **global and local invariants** that guarantee safety, interpretability, and trust.\n\nValidation is observation, not correction.\n\nThis graph is normative.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
