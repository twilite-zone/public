    {
      "id": "validation-order",
      "type": "markdown",
      "label": "Validation Order",
      "position": {
        "x": -1100,
        "y": 420
      },
      "width": 720,
      "height": 420,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "## Validation Order\n\n1. Schema validation\n2. Port compatibility\n3. Manifest validation\n4. Dependency validation\n5. Structural integrity\n6. Safety & mutation rules\n7. Intent validation\n\nOrder is mandatory.\nLater stages assume earlier truth.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
          "ref": "/library/classes/nodes/markdown.node-class.node",
          "identity": {
