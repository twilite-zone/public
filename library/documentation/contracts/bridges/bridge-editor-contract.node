        "title": "Bridge Editor Contract",
        "purpose": "Summary surface for the bridge editor model.",
        "titleSourceNodeId": "bridge-editor-contract-title",
        "typeSourceNodeId": "bridge-editor-contract-type",
        "viewRole": "node",
        "viewKind": "interactive",
        "audience": "Author",
        "status": "draft",
        "svg": "<svg viewBox=\"0 0 220 160\" xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\"><rect x=\"20\" y=\"16\" width=\"180\" height=\"128\" rx=\"18\" fill=\"#fffaf3\" stroke=\"#241a12\" stroke-width=\"5\"/><rect x=\"36\" y=\"34\" width=\"58\" height=\"18\" rx=\"9\" fill=\"#dbeafe\"/><rect x=\"104\" y=\"34\" width=\"42\" height=\"18\" rx=\"9\" fill=\"#86efac\"/><rect x=\"154\" y=\"34\" width=\"28\" height=\"18\" rx=\"9\" fill=\"#fde68a\"/><rect x=\"36\" y=\"66\" width=\"146\" height=\"14\" rx=\"7\" fill=\"#e2e8f0\"/><rect x=\"36\" y=\"92\" width=\"62\" height=\"16\" rx=\"8\" fill=\"#fca5a5\"/><rect x=\"106\" y=\"92\" width=\"76\" height=\"16\" rx=\"8\" fill=\"#c4b5fd\"/><rect x=\"36\" y=\"118\" width=\"146\" height=\"10\" rx=\"5\" fill=\"#cbd5e1\"/></svg>",
