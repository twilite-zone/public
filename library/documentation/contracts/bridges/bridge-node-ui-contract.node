        "status": "draft",
        "svg": "<svg viewBox=\"0 0 240 160\" xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\"><rect x=\"18\" y=\"16\" width=\"204\" height=\"128\" rx=\"18\" fill=\"#ffffff\" stroke=\"#083344\" stroke-width=\"4\"/><rect x=\"34\" y=\"28\" width=\"172\" height=\"16\" rx=\"8\" fill=\"#ecfeff\" stroke=\"#0e7490\" stroke-width=\"1\"/><text x=\"44\" y=\"39\" font-family=\"ui-sans-serif, system-ui\" font-size=\"10\" font-weight=\"700\" fill=\"#0e7490\">Source</text><rect x=\"34\" y=\"48\" width=\"172\" height=\"16\" rx=\"8\" fill=\"#dcfce7\" stroke=\"#166534\" stroke-width=\"1\"/><text x=\"44\" y=\"59\" font-family=\"ui-sans-serif, system-ui\" font-size=\"10\" font-weight=\"700\" fill=\"#166534\">Role</text><rect x=\"34\" y=\"68\" width=\"172\" height=\"16\" rx=\"8\" fill=\"#fef3c7\" stroke=\"#b45309\" stroke-width=\"1\"/><text x=\"44\" y=\"79\" font-family=\"ui-sans-serif, system-ui\" font-size=\"10\" font-weight=\"700\" fill=\"#b45309\">Grants</text><rect x=\"34\" y=\"88\" width=\"172\" height=\"16\" rx=\"8\" fill=\"#ede9fe\" stroke=\"#6d28d9\" stroke-width=\"1\"/><text x=\"44\" y=\"99\" font-family=\"ui-sans-serif, system-ui\" font-size=\"10\" font-weight=\"700\" fill=\"#6d28d9\">Exposure</text><rect x=\"34\" y=\"108\" width=\"172\" height=\"16\" rx=\"8\" fill=\"#dcfce7\" stroke=\"#15803d\" stroke-width=\"1\"/><text x=\"44\" y=\"119\" font-family=\"ui-sans-serif, system-ui\" font-size=\"10\" font-weight=\"700\" fill=\"#15803d\">Effective Result</text><rect x=\"34\" y=\"128\" width=\"172\" height=\"16\" rx=\"8\" fill=\"#fee2e2\" stroke=\"#b91c1c\" stroke-width=\"1\"/><text x=\"44\" y=\"139\" font-family=\"ui-sans-serif, system-ui\" font-size=\"10\" font-weight=\"700\" fill=\"#b91c1c\">Diagnostics</text></svg>",
