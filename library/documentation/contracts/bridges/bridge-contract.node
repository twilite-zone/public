    {
      "id": "bridge-contract-procedure",
      "type": "procedure",
      "label": "Procedure",
      "position": {
        "x": 620,
        "y": 300
      },
      "width": 420,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Resolve In Five Passes",
        "body": "Evaluate the port boundary in an explicit order so renderer appearance and target richness never outrun declared authority.",
        "steps": [
          "Read the host port authority; default new ports to navigate.",
          "Read the target exposure: named views, bridgeability, runtime capability, and default root behavior.",
          "Validate semantic meaning, direction, semantic type, multiplicity, and wildcard policy.",
          "Compute effective authority as the minimum of host authority, target exposure, and local policy.",
          "Filter the result to the allowed boundary behavior or refuse if no safe behavior remains."
        ],
        "_classBinding": {
          "key": "procedure",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/skill-contract/procedure.node-class.node",
