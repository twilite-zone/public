      "data": {
        "title": "Bridge Exposure Contract",
        "purpose": "Summary surface for bridge exposure policy.",
        "titleSourceNodeId": "bridge-exposure-contract-title",
        "typeSourceNodeId": "bridge-exposure-contract-type",
        "viewRole": "node",
        "viewKind": "interactive",
        "audience": "Author",
        "status": "draft",
        "svg": "<svg viewBox=\"0 0 220 160\" xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\"><rect x=\"20\" y=\"18\" width=\"180\" height=\"124\" rx=\"22\" fill=\"#fffaf3\" stroke=\"#201910\" stroke-width=\"5\"/><rect x=\"38\" y=\"36\" width=\"78\" height=\"14\" rx=\"7\" fill=\"#e2e8f0\"/><rect x=\"124\" y=\"36\" width=\"58\" height=\"14\" rx=\"7\" fill=\"#f3e2b8\"/><rect x=\"38\" y=\"64\" width=\"56\" height=\"18\" rx=\"9\" fill=\"#86efac\"/><rect x=\"102\" y=\"64\" width=\"56\" height=\"18\" rx=\"9\" fill=\"#93c5fd\"/><rect x=\"38\" y=\"92\" width=\"56\" height=\"18\" rx=\"9\" fill=\"#fca5a5\"/><rect x=\"102\" y=\"92\" width=\"56\" height=\"18\" rx=\"9\" fill=\"#c4b5fd\"/><path d=\"M170 62v48\" stroke=\"#201910\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-dasharray=\"8 8\"/><path d=\"M170 110l14 0\" stroke=\"#201910\" stroke-width=\"4\" stroke-linecap=\"round\"/><circle cx=\"170\" cy=\"62\" r=\"8\" fill=\"#fffaf3\" stroke=\"#201910\" stroke-width=\"4\"/><circle cx=\"170\" cy=\"110\" r=\"8\" fill=\"#fffaf3\" stroke=\"#201910\" stroke-width=\"4\"/></svg>",
        "_classBinding": {
