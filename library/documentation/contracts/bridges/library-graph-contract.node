        "status": "draft",
        "svg": "<svg viewBox=\"0 0 220 160\" xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\"><rect x=\"16\" y=\"16\" width=\"188\" height=\"128\" rx=\"24\" fill=\"#fffaf3\" stroke=\"#201910\" stroke-width=\"5\"/><rect x=\"34\" y=\"30\" width=\"70\" height=\"16\" rx=\"8\" fill=\"#f3e2b8\"/><rect x=\"112\" y=\"30\" width=\"74\" height=\"16\" rx=\"8\" fill=\"#dbeafe\"/><rect x=\"34\" y=\"60\" width=\"60\" height=\"52\" rx=\"12\" fill=\"#eef8e8\" stroke=\"#201910\" stroke-width=\"3\"/><rect x=\"104\" y=\"60\" width=\"34\" height=\"18\" rx=\"9\" fill=\"#86efac\"/><rect x=\"146\" y=\"60\" width=\"34\" height=\"18\" rx=\"9\" fill=\"#93c5fd\"/><rect x=\"104\" y=\"86\" width=\"34\" height=\"18\" rx=\"9\" fill=\"#fca5a5\"/><rect x=\"146\" y=\"86\" width=\"34\" height=\"18\" rx=\"9\" fill=\"#c4b5fd\"/><path d=\"M94 86h10\" stroke=\"#201910\" stroke-width=\"4\" stroke-linecap=\"round\"/><path d=\"M64 112v14\" stroke=\"#201910\" stroke-width=\"4\" stroke-linecap=\"round\"/><path d=\"M64 126h100\" stroke=\"#201910\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-dasharray=\"8 8\"/></svg>",
