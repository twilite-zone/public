        "svg": "<svg viewBox=\"0 0 220 160\" xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\"><rect x=\"16\" y=\"18\" width=\"188\" height=\"124\" rx=\"22\" fill=\"#fffaf2\" stroke=\"#2b2118\" stroke-width=\"5\"/><rect x=\"34\" y=\"36\" width=\"82\" height=\"14\" rx=\"7\" fill=\"#f2e2b8\"/><rect x=\"124\" y=\"36\" width=\"62\" height=\"14\" rx=\"7\" fill=\"#cbd5e1\"/><rect x=\"34\" y=\"66\" width=\"152\" height=\"18\" rx=\"9\" fill=\"#e2e8f0\"/><rect x=\"34\" y=\"96\" width=\"62\" height=\"10\" rx=\"5\" fill=\"#475569\" opacity=\"0.88\"/><rect x=\"102\" y=\"96\" width=\"52\" height=\"10\" rx=\"5\" fill=\"#94a3b8\" opacity=\"0.95\"/><rect x=\"160\" y=\"96\" width=\"26\" height=\"10\" rx=\"5\" fill=\"#cbd5e1\" opacity=\"0.98\"/></svg>",
