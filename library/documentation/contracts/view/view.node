      "showLabel": true,
      "data": {
        "markdown": "## Required\n\n- `type: \"view\"`\n- `data.view.intent` (string)\n- `data.view.payload` (string)\n\nIntent declares **why** the view exists; payload declares **how** it is expressed.",
        "_classBinding": {
          "key": "markdown",
