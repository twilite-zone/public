      "width": 520,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "## Rules\n\n- A node definition must include **at least one** View node.\n- A definition graph **may contain only View nodes** and still be valid.\n- View nodes are descriptive, not executable.\n- Multiple View nodes can exist for multiple intent/payload pairs.\n- Renderers choose the best compatible intent + payload.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "/library/classes/nodes/markdown.node-class.node",
