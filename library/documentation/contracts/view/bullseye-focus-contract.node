    {
      "id": "bullseye-focus-title",
      "type": "title",
      "label": "Title",
      "root": true,
      "position": {
        "x": -260,
        "y": -40
      },
      "width": 460,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Bullseye Focus Contract",
        "subtitle": "Semantic zoom uses two related bullseyes. The outer bullseye selects fragment context. The inner bullseye resolves node focus inside the selected fragment. The center of the inner bullseye is the focused node under direct user attention and is the only place full graph render is allowed. The graph root must always remain at node-view regardless of selection state. Around that center, the second ring renders an exposed child surface when one exists, otherwise the node's own node-view, and does not collapse to icon-view. The third ring renders icon-view when loaded or type badge when not yet loaded, and the fourth ring renders dots. Representation at a ring depends on both semantic distance and current load state.",
        "intent": "headline",
        "status": "active",
        "_classBinding": {
          "key": "title",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/template-structure/title.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/template-structure/title.node-class.node",
