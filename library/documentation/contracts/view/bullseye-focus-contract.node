      "showLabel": true,
      "data": {
        "title": "Outer Selection And Inner Focus Collapse Into One Another",
        "body": "Failure mode is mushy semantic zoom: fragment context selection is unclear, the focused node inside that fragment is unclear, directly connected nodes collapse to icon-view too early, directly connected local nodes over-render as opened graphs instead of reading as node view, file-backed child graphs do not read as ports when they should, third-ring nodes do not distinguish loaded icon-view from unloaded type badge, fourth-ring nodes do not collapse to dots, cached nodes stay richer than their current ring allows, or runtime-discovered children do not expose port-view first and icon-view fallback.",
        "response": "warn",
        "_classBinding": {
          "key": "failure-mode",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/skill-contract/failure-mode.node-class.node",
