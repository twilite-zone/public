    {
      "id": "bullseye-focus-procedure",
      "type": "procedure",
      "label": "Procedure",
      "root": false,
      "position": {
        "x": 1220,
        "y": 960
      },
      "width": 360,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Select Fragment First, Then Resolve Node Rings",
        "body": "First identify the selected fragment context. Then identify the focused node under direct user attention inside that fragment as the center of the inner bullseye. Then load and render outward by ring inside that fragment: directly connected children through an exposed child-facing surface when one exists, otherwise through node-view, nodes one connection farther out as third-ring icon-view when loaded or type badge when not yet loaded, and nodes one more connection out as fourth-ring dots. Only the center may render as a full graph. When fragment selection changes, recompute the outer context. When node focus changes, recompute the inner rings. Reuse cached data where possible without exceeding ring caps.",
        "steps": [
          "Select the active fragment context first.",
          "Treat the focused node inside that fragment as the center under direct user attention.",
          "Load the selected fragment context before farther contexts.",
          "Load the focused `.node` file first inside that fragment.",
          "Render directly connected children through an exposed child-facing surface when one exists.",
          "Otherwise render directly connected children through node-view.",
          "Keep the graph root at node-view regardless of selection state.",
          "Do not collapse the second ring to icon-view.",
          "Do not let second-ring nodes render as opened multi-node graphs.",
          "Load the second ring before loading farther rings inside the selected fragment.",
          "Render nodes one connection farther out as third-ring icon-view when loaded or type badge when not yet loaded.",
          "Load the third ring after the second ring, and the fourth ring after the third.",
          "Render nodes one more connection out as fourth-ring dots.",
          "If `root.node` is absent, generate a runtime root and expose sibling `.node` files as second-ring discoveries using port-view first and icon-view fallback.",
          "Let fragment selection determine the outer bullseye while node distance determines the inner bullseye.",
          "Let semantic distance determine the ring while load state determines whether third-ring nodes can realize icon-view or must remain type badges.",
          "When fragment selection or node focus changes, recompute ring membership and downgrade or upgrade representations to the new ring caps.",
          "Allow cache to satisfy a ring immediately, but never let cached data exceed the cap of the current ring.",
          "If a required surface for the current representation is missing, show an explicit error instead of guessing."
        ],
        "_classBinding": {
