    {
      "id": "bullseye-focus-skill",
      "type": "skill",
      "label": "Skill",
      "root": false,
      "position": {
        "x": -40,
        "y": 320
      },
      "width": 420,
      "height": 260,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Select fragment outside, focus node inside",
        "body": "The bullseye does not choose behavior. It describes semantic distance from direct user attention across two layers. The outer bullseye selects the active fragment context. The inner bullseye resolves node focus inside that selected fragment. The center of the inner bullseye is the focused node under direct attention and is the only place full graph render is allowed. The graph root must always remain rendered at node-view regardless of selection state. The second ring contains nodes directly connected to that center. If a directly connected child exposes a distinct child-facing surface, such as port-view, that exposed surface may be used. Otherwise the second ring must render the node's own node-view. It must not collapse to icon-view at that ring. The third ring contains nodes one connection farther out and renders as icon-view when already loaded or as a type badge when not yet loaded. The fourth ring contains nodes one more connection out and renders as dots. When fragment selection changes, the outer bullseye changes. When node focus changes inside the selected fragment, the inner bullseye changes. Cached data may satisfy a ring immediately, but only up to that ring's allowed cap. If `root.node` is absent, a runtime-generated root may still browse sibling `.node` files as second-ring discoveries using port-view first and icon-view fallback.",
        "category": "view-contract",
        "authority": "normative",
        "_classBinding": {
          "key": "skill",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/skill-contract/skill.node-class.node",
