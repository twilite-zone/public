    {
      "id": "bullseye-focus-guardrail",
      "type": "guardrail",
      "label": "Guardrail",
      "root": false,
      "position": {
        "x": 1620,
        "y": 640
      },
      "width": 360,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Do Not Blur Fragment Selection, Node Distance, and Loadedness",
        "body": "Do not jump directly from far-distance dots to full graph render. Do not let fragment selection stand in for node focus, and do not let node focus rewrite fragment context. Do not let second-ring nodes collapse to icon-view. Do not let second-ring local elemental nodes render as opened multi-node graphs, and do not force file-backed child graphs through the same node-surface path when they should read as ports. Do not let load state overwrite semantic distance, and do not let semantic distance pretend data is loaded when it is not. Do not let cached richness exceed the cap of the current ring. Do not treat every editor-facing node as zoom-exempt. Only explicitly declared plumbing should stay invariant to zoom.",
        "hardStop": true,
        "_classBinding": {
          "key": "guardrail",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/skill-contract/guardrail.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/skill-contract/guardrail.node-class.node",
          "identity": {
            "graphId": "guardrail-class",
