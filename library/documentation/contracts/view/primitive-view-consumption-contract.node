    {
      "id": "primitive-view-consumption-contract-procedure",
      "type": "procedure",
      "label": "Procedure",
      "position": {
        "x": -1654.3601010653929,
        "y": 2247.1666666666665
      },
      "width": 420,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Procedure",
        "body": "Resolve the target ref first, stamp the canonical bridge object second, then mirror or derive any legacy fallback fields only as compatibility shims. New bridge authoring should write the canonical shape directly.",
        "steps": [
          "Read the host port authority; default new ports to navigate.",
          "Read the target exposure: named views, bridgeability, runtime capability, and default root behavior.",
          "Validate semantic meaning, direction, semantic type, multiplicity, and wildcard policy.",
          "Compute effective authority as the minimum of host authority, target exposure, and local policy.",
          "Filter the result to the allowed boundary behavior or refuse if no safe behavior remains."
        ],
        "_classBinding": {
