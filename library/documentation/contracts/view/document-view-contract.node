    {
      "id": "document-view-contract-errors",
      "type": "markdown",
      "label": "Errors",
      "root": false,
      "position": {
        "x": -970,
        "y": 765
      },
      "width": 520,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "## Errors & Fallbacks\n\n- If document content is missing: show an error card.\n- If part ordering is invalid: show an error card.\n- If only SVG/title are present: treat as invalid for document view.\n\nDocument view must never silently downgrade to a port or icon view.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
