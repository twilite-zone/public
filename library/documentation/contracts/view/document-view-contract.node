    {
      "id": "document-view-contract-scope",
      "type": "markdown",
      "label": "Scope",
      "root": false,
      "position": {
        "x": 550,
        "y": -15
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "## Scope\n\n- Applies to **document-view** primitives.\n- Used by planning, status, and document templates.\n- Must render composed content, not a port card.",
