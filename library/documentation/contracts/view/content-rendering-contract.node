    {
      "id": "content-rendering-contract-skill",
      "type": "skill",
      "label": "Skill",
      "root": false,
      "position": {
        "x": -220,
        "y": -200
      },
      "width": 380,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Make Rendering Explicit",
        "body": "A renderer must not infer product behavior solely from field names like `markdown`, `html`, or `text`. Content rendering should be declared so authored surfaces behave predictably across native and dynamic paths.",
        "_classBinding": {
          "key": "skill",
          "sourceRef": "/library/classes/nodes/skill-contract/skill.node-class.node",
          "ref": "/library/classes/nodes/skill-contract/skill.node-class.node"
        },
        "definitionKey": "skill"
      }
    },
    {
      "id": "content-rendering-contract-scope",
      "type": "scope",
      "label": "Scope",
      "root": false,
      "position": {
        "x": 220,
        "y": -200
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Where It Applies",
        "body": "Applies to `MarkdownNode`, `DynamicViewNode`, node/editor/web views, document-like surfaces, summary/icon surfaces, and any future content renderer that claims to render authored text-bearing payloads.",
        "_classBinding": {
          "key": "scope",
          "sourceRef": "/library/classes/nodes/skill-contract/scope.node-class.node",
          "ref": "/library/classes/nodes/skill-contract/scope.node-class.node"
        },
        "definitionKey": "scope"
      }
    },
    {
      "id": "content-rendering-contract-input",
      "type": "input",
      "label": "Input",
      "root": false,
      "position": {
        "x": -220,
        "y": 80
      },
      "width": 380,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Required Inputs",
        "body": "Every renderable surface should declare at least: content kind, source path, render role, and presentation profile. These inputs are the minimum needed to distinguish transport from presentation.",
        "_classBinding": {
          "key": "input",
          "sourceRef": "/library/classes/nodes/skill-contract/input.node-class.node",
          "ref": "/library/classes/nodes/skill-contract/input.node-class.node"
        },
        "definitionKey": "input"
      }
    },
    {
      "id": "content-rendering-contract-output",
      "type": "output",
      "label": "Output",
      "root": false,
      "position": {
        "x": 220,
        "y": 80
      },
      "width": 380,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Expected Output",
        "body": "A rendered surface with explicit behavior: content looks intentional, title/body policy is predictable, editor fallback is consistent, and typography/container rules are known instead of accidental.",
        "_classBinding": {
          "key": "output",
          "sourceRef": "/library/classes/nodes/skill-contract/output.node-class.node",
          "ref": "/library/classes/nodes/skill-contract/output.node-class.node"
        },
        "definitionKey": "output"
      }
    },
    {
      "id": "content-rendering-contract-rule-kind",
      "type": "rule",
      "label": "Rule",
      "root": false,
      "position": {
        "x": -220,
        "y": 360
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Declare Content Kind",
        "body": "Content kind must be explicit: markdown, html, text, svg, image, canvas, json, or another declared kind. A renderer should not determine product meaning purely by checking which field happens to be present.",
        "_classBinding": {
          "key": "rule",
          "sourceRef": "/library/classes/nodes/skill-contract/rule.node-class.node",
          "ref": "/library/classes/nodes/skill-contract/rule.node-class.node"
        },
        "definitionKey": "rule"
      }
    },
    {
      "id": "content-rendering-contract-rule-role",
      "type": "rule",
      "label": "Rule",
      "root": false,
      "position": {
        "x": 180,
        "y": 360
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Declare Render Role",
        "body": "The same content kind may render differently by role. Detail, summary, icon, editor, and document-like surfaces must be treated as declared roles with different presentation expectations.",
        "_classBinding": {
          "key": "rule",
          "sourceRef": "/library/classes/nodes/skill-contract/rule.node-class.node",
          "ref": "/library/classes/nodes/skill-contract/rule.node-class.node"
        },
        "definitionKey": "rule"
      }
    },
    {
      "id": "content-rendering-contract-rule-presentation",
      "type": "rule",
      "label": "Rule",
      "root": false,
      "position": {
        "x": 580,
        "y": 360
      },
      "width": 360,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Declare Presentation Profile",
        "body": "Markdown rendering must carry presentation rules such as container padding, title/body separation, typography rhythm, list and code treatment, and overflow policy. Rendering quality cannot remain implicit in component code alone.",
        "_classBinding": {
          "key": "rule",
          "sourceRef": "/library/classes/nodes/skill-contract/rule.node-class.node",
          "ref": "/library/classes/nodes/skill-contract/rule.node-class.node"
        },
        "definitionKey": "rule"
      }
    },
    {
      "id": "content-rendering-contract-guardrail",
      "type": "guardrail",
      "label": "Guardrail",
      "root": false,
      "position": {
        "x": -20,
        "y": 640
      },
      "width": 420,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Do Not Infer Product Semantics From Field Names",
        "body": "A field named `markdown` or `html` may describe payload transport, but it is not enough to define how the product should render, edit, or size that content. Content contract and render contract must stay explicit.",
        "_classBinding": {
          "key": "guardrail",
          "sourceRef": "/library/classes/nodes/skill-contract/guardrail.node-class.node",
          "ref": "/library/classes/nodes/skill-contract/guardrail.node-class.node"
        },
        "definitionKey": "guardrail"
      }
    },
    {
      "id": "content-rendering-contract-failure",
      "type": "failure-mode",
      "label": "Failure Mode",
      "root": false,
      "position": {
        "x": 460,
        "y": 640
      },
      "width": 420,
      "height": 220,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Renderer Can Render But Does Not Render Well",
        "body": "This is the markdown smoke-test failure. The generic dynamic path technically supports markdown, but because presentation rules are missing, the result is materially worse than the native markdown node and not fit as a replacement.",
        "_classBinding": {
          "key": "failure-mode",
          "sourceRef": "/library/classes/nodes/skill-contract/failure-mode.node-class.node",
          "ref": "/library/classes/nodes/skill-contract/failure-mode.node-class.node"
        },
        "definitionKey": "failure-mode"
      }
    },
    {
      "id": "content-rendering-contract-procedure",
      "type": "procedure",
      "label": "Procedure",
      "root": false,
      "position": {
        "x": 220,
        "y": 920
      },
      "width": 420,
      "height": 240,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Apply The Contract",
        "body": "1. Declare content kind and source path.\n2. Declare render role.\n3. Attach a presentation profile.\n4. Make editor behavior resolve to the same declared contract.\n5. Only then consider converging native and dynamic render paths.",
        "_classBinding": {
          "key": "procedure",
          "sourceRef": "/library/classes/nodes/skill-contract/procedure.node-class.node",
          "ref": "/library/classes/nodes/skill-contract/procedure.node-class.node"
        },
        "definitionKey": "procedure"
      }
    },
