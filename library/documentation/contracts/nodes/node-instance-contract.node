      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Node Instance Contract",
        "subtitle": "Defines what makes a class-backed node instance real: not just a type and prose fields, but a full binding contract carrying class identity, bridge provenance, definition key, `root.node` plus connected fragments, explicit fragment declaration by type, runtime-root discovery behavior, whether the node is single-file or multi-file, and root-only port exposure.",
        "intent": "headline",
        "status": "active",
