    {
      "id": "node-instance-contract-procedure",
      "type": "procedure",
      "label": "Procedure",
      "position": {
        "x": 5204.279797869214,
        "y": 430
      },
      "width": 420,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Procedure",
        "body": "Stamp full binding data at creation time. For class-backed nodes, write semantic node data first, then `_classBinding`, then `_bridge`, then `definitionKey`. Validate those fields after cloning or migration.",
        "steps": [
          "Read the declared node schema and refuse unknown types before creating or mutating anything.",
          "Confirm the schema declares type name, version, and status, and that the node has immutable identity fields.",
          "Confirm the node contract declares semantic meaning and the reason the node exists.",
          "Validate required fields (`id`, `type`, `data`) and the declared data shape against the contract.",
          "Validate optional fields only when present, and reject undocumented keys or free-form blobs.",
          "Validate declared ports and the implicit root portability rule, and reject undeclared ports when the schema is ported.",
          "Prefer update over recreate, and reject forbidden mutations including type changes, identity rewrites, undocumented fields, required-field deletion, and port-ID changes.",
          "Confirm the node resolves at least one view and emit explicit errors instead of guessing when any check fails."
        ],
        "_classBinding": {
          "key": "procedure",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/skill-contract/procedure.node-class.node",
