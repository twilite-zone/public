      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Twilite Node Template Set Proposal",
        "purpose": "Stable summary surface for the canonical template set proposal.",
        "titleSourceNodeId": "twilite-node-template-set-proposal-title",
        "typeSourceNodeId": "twilite-node-template-set-proposal-type",
        "viewRole": "node",
        "viewKind": "interactive",
        "audience": "Author",
        "status": "active",
        "svg": "<svg viewBox=\"0 0 220 160\" xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\"><rect x=\"18\" y=\"16\" width=\"184\" height=\"128\" rx=\"24\" fill=\"#fffaf3\" stroke=\"#241a12\" stroke-width=\"5\"/><rect x=\"34\" y=\"34\" width=\"82\" height=\"14\" rx=\"7\" fill=\"#f3e2b8\"/><rect x=\"126\" y=\"34\" width=\"54\" height=\"14\" rx=\"7\" fill=\"#dbeafe\"/><rect x=\"34\" y=\"66\" width=\"150\" height=\"16\" rx=\"8\" fill=\"#fff1e6\"/><rect x=\"34\" y=\"94\" width=\"46\" height=\"36\" rx=\"10\" fill=\"#cbd5e1\"/><rect x=\"88\" y=\"94\" width=\"46\" height=\"36\" rx=\"10\" fill=\"#fde68a\"/><rect x=\"142\" y=\"94\" width=\"42\" height=\"36\" rx=\"10\" fill=\"#c7d2fe\"/></svg>",
        "_classBinding": {
          "key": "node-view",
