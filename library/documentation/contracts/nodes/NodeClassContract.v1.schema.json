{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://twilite.zone/contracts/nodes/NodeClassContract.v1.schema.json",
  "title": "Twilite NodeClassContract v1",
  "description": "Stable contract for defining a reusable Twilite node class with schema, defaults, views, validation, override behavior, and lifecycle hooks.",
  "type": "object",
  "required": [
    "contractVersion",
    "nodeType",
    "classRef",
    "classVersion",
    "source",
    "dataSchema",
    "defaults",
    "views",
    "validation",
    "overrides"
  ],
  "additionalProperties": false,
  "properties": {
    "contractVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "nodeType": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Canonical node type key (e.g. markdown, graph-reference, complaint)."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "classRef": {
      "type": "string",
      "pattern": "^(github://|local://|tlz://|/|https?://).+",
      "description": "Canonical source of the node class graph file."
    },
    "classVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Version or semver range for the class graph."
    },
    "source": {
      "type": "string",
      "enum": [
        "local",
        "github",
        "http",
        "https",
        "tlz",
        "external"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "dataSchema": {
      "description": "JSON Schema for node.data.",
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object"
        }
      ]
    },
    "defaults": {
      "type": "object",
      "required": [
        "label",
        "size",
        "data",
        "ports"
      ],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string"
        },
        "size": {
          "type": "object",
          "required": [
            "width",
            "height"
          ],
          "additionalProperties": false,
          "properties": {
            "width": {
              "type": "number",
              "minimum": 40
            },
            "height": {
              "type": "number",
              "minimum": 40
            }
          }
        },
        "color": {
          "type": [
            "string",
            "null"
          ]
        },
        "visible": {
          "type": "boolean",
          "default": true
        },
        "showLabel": {
          "type": "boolean",
          "default": true
        },
        "data": {
          "type": "object",
          "description": "Default node.data payload for this node class."
        },
        "ports": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/portDefinition"
          }
        }
      }
    },
    "views": {
      "type": "object",
      "required": [
        "node"
      ],
      "additionalProperties": false,
      "properties": {
        "node": {
          "$ref": "#/definitions/viewBinding"
        },
        "editor": {
          "$ref": "#/definitions/viewBinding"
        },
        "additional": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/viewBinding"
          }
        }
      }
    },
    "overrides": {
      "type": "object",
      "required": [
        "allowLabel",
        "allowSize",
        "allowColor",
        "allowPorts",
        "allowData",
        "dataMode"
      ],
      "additionalProperties": false,
      "properties": {
        "allowLabel": {
          "type": "boolean"
        },
        "allowSize": {
          "type": "boolean"
        },
        "allowColor": {
          "type": "boolean"
        },
        "allowPorts": {
          "type": "boolean"
        },
        "allowData": {
          "type": "boolean"
        },
        "dataMode": {
          "type": "string",
          "enum": [
            "replace",
            "merge-shallow",
            "merge-deep"
          ],
          "description": "How instance data overrides class defaults."
        }
      }
    },
    "validation": {
      "type": "object",
      "required": [
        "requiredDataKeys",
        "rules",
        "onError"
      ],
      "additionalProperties": false,
      "properties": {
        "requiredDataKeys": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/validationRule"
          }
        },
        "onError": {
          "type": "string",
          "enum": [
            "block",
            "warn"
          ]
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hooks": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "onCreate": {
              "$ref": "#/definitions/hookRef"
            },
            "onLoad": {
              "$ref": "#/definitions/hookRef"
            },
            "onBeforeUpdate": {
              "$ref": "#/definitions/hookRef"
            },
            "onAfterUpdate": {
              "$ref": "#/definitions/hookRef"
            },
            "onDelete": {
              "$ref": "#/definitions/hookRef"
            }
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minTwiliteVersion": {
          "type": "string"
        },
        "maxTwiliteVersion": {
          "type": "string"
        },
        "legacyAdapters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deprecatedFields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "definitions": {
    "portDefinition": {
      "type": "object",
      "required": [
        "id",
        "label",
        "direction",
        "dataType",
        "position"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "direction": {
          "type": "string",
          "enum": [
            "input",
            "output",
            "bidirectional"
          ]
        },
        "dataType": {
          "type": "string"
        },
        "position": {
          "type": "object",
          "required": [
            "side",
            "offset"
          ],
          "additionalProperties": false,
          "properties": {
            "side": {
              "type": "string",
              "enum": [
                "left",
                "right",
                "top",
                "bottom"
              ]
            },
            "offset": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    },
    "viewBinding": {
      "type": "object",
      "required": [
        "intent",
        "payload",
        "ref",
        "source",
        "version"
      ],
      "additionalProperties": false,
      "properties": {
        "intent": {
          "type": "string",
          "enum": [
            "node",
            "editor",
            "preview",
            "inspector",
            "runtime"
          ]
        },
        "payload": {
          "type": "string",
          "minLength": 1,
          "description": "View payload selector, e.g. node.web or editor.web."
        },
        "ref": {
          "type": "string",
          "pattern": "^(github://|local://|tlz://|/|https?://).+"
        },
        "source": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "validationRule": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "path",
        "message",
        "severity"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "required",
            "type",
            "enum",
            "pattern",
            "range",
            "custom"
          ]
        },
        "path": {
          "type": "string",
          "description": "Dot path relative to node instance (e.g. data.videoId)."
        },
        "message": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "error",
            "warning"
          ]
        },
        "enum": {
          "type": "array",
          "items": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          }
        },
        "pattern": {
          "type": "string"
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        }
      }
    },
    "hookRef": {
      "type": "object",
      "required": [
        "kind",
        "ref"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "script",
            "skill",
            "rpc"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
