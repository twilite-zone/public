    {
      "id": "node-contract-guardrail",
      "type": "guardrail",
      "label": "Guardrail",
      "position": {
        "x": 2624.2797978692142,
        "y": 405
      },
      "width": 420,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Identity, Fragment Topology, And Root Ports Are Stable",
        "body": "A node's `id` and `type` are stable identity anchors. A mutation must not change them, recreate the node to fake a type change, expose ports on fragments, treat a file without a type node of type `fragment` as a fragment, attach a fragment anywhere except one `root.node` or another fragment already connected to that `root.node`, connect a fragment into more than one root context, delete required fields, add undocumented fields, or modify declared port IDs outside the contract.",
        "hardStop": true,
        "_classBinding": {
          "key": "guardrail",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/skill-contract/guardrail.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/skill-contract/guardrail.node-class.node",
          "identity": {
            "graphId": "guardrail-class",
            "name": "guardrail Node Class",
            "version": "0.1.0",
            "description": "Explicit safety boundary for what the skill must not do or assume.",
            "createdAt": "2026-03-26T18:30:00.000Z",
            "updatedAt": "2026-03-26T18:30:00.000Z"
          },
