    {
      "id": "node-contract-failure",
      "type": "failure-mode",
      "label": "Failure Mode",
      "position": {
        "x": 4664.279797869214,
        "y": 405
      },
      "width": 420,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Undeclared Shape Or Illegal Fragment Topology",
        "body": "If a node is missing required fields, lacks required metadata, carries undocumented keys, violates the declared data shape, exposes ports anywhere except `root.node`, treats files without a type node of type `fragment` as fragments outside the runtime-root discovery path, connects fragments illegally, connects a fragment into more than one root context, attempts a forbidden mutation, or fails to resolve at least one valid view, validation must fail and execution must stop.",
        "response": "refuse",
        "_classBinding": {
          "key": "failure-mode",
