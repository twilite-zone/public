    {
      "id": "node-contract-procedure",
      "type": "procedure",
      "label": "Procedure",
      "position": {
        "x": 5204.279797869214,
        "y": 430
      },
      "width": 420,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Validate In Order",
        "body": "Read declared schema before acting, then validate identity, meaning, `root.node` plus connected-fragment topology, explicit fragment declaration, root-only port exposure, payload shape, mutation legality, and view resolution. Prefer update over recreate, refuse unknown or undocumented structure, and emit explicit errors instead of guessing.",
        "steps": [
          "Read the declared node schema and refuse unknown types before creating or mutating anything.",
          "Confirm the schema declares type name, version, and status, and that the node has immutable identity fields.",
          "Confirm the node contract declares semantic meaning and the reason the node exists.",
          "Confirm the on-disk node is exactly one `root.node` plus all fragments connected to it.",
          "Reject any connected file that does not declare itself as a fragment by carrying a type node of type `fragment`, unless it is being projected by a runtime-generated root as a discovered sibling `.node` file.",
          "Treat a node with no connected fragments as single-file and a node with one or more connected fragments as multi-file.",
          "Reject any fragment that connects anywhere except one `root.node` or another fragment already connected to that `root.node`.",
          "Reject any fragment that connects into more than one root context.",
          "Reject any exposed port that is not declared on `root.node`.",
          "If `root.node` is absent, a runtime-generated root may expose sibling `.node` files using port-view first and icon-view fallback without turning them into declared fragments.",
          "Validate required fields (`id`, `type`, `data`) and the declared data shape against the contract.",
          "Validate optional fields only when present, and reject undocumented keys or free-form blobs.",
          "Validate declared ports and the implicit root portability rule, and reject undeclared ports when the schema is ported.",
          "Prefer update over recreate, and reject forbidden mutations including type changes, identity rewrites, undocumented fields, required-field deletion, and port-ID changes.",
          "Confirm the node resolves at least one view and emit explicit errors instead of guessing when any check fails."
        ],
        "_classBinding": {
          "key": "procedure",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/skill-contract/procedure.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/skill-contract/procedure.node-class.node",
