          "dataType": "any",
          "position": {
            "side": "right",
            "offset": 0.5
          }
        }
      ],
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Node Contract",
        "subtitle": "Normative contract for Twilite node schemas. On disk, a node is one and only one `root.node` plus all fragments connected to it. A node with no connected fragments is a single-file node. A node with one or more connected fragments is a multi-file node. A file is a fragment only if it carries a type node whose type is `fragment`. Any node whose type is not `fragment` may serve as a root node. A fragment may connect only to one `root.node` or to another fragment already connected to that `root.node`, and validation must fail if a fragment connects into more than one root context. Ports are exposed on `root.node` only. A runtime-generated root may still discover sibling `.node` files in a folder and expose them through port-view first and icon-view fallback without treating them as declared fragments. Editors and agents may not invent fields, infer structure, or guess missing data.",
        "intent": "headline",
        "status": "active",
        "_classBinding": {
          "key": "title",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/template-structure/title.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/template-structure/title.node-class.node",
          "identity": {
            "graphId": "title-node-class",
            "name": "Title Node Class",
            "version": "0.1.0",
            "description": "Template heading or major framing node for reusable graph structures.",
            "createdAt": "2026-03-26T02:30:00.000Z",
