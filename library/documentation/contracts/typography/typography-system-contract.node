    {
      "id": "typography-contract-type",
      "type": "type-definition",
      "label": "Type",
      "root": false,
      "position": {
        "x": -430,
        "y": 500
      },
      "width": 300,
      "height": 170,
      "visible": true,
      "showLabel": true,
      "data": {
        "name": "Typography Contract",
        "key": "typography-contract",
        "classRef": "github://twilite-zone/public/library/documentation/contracts/typography/typography-system-contract.node",
        "meaning": "A Twilite contract graph that defines the shared typography roles, rules, and adoption order for the product.",
        "description": "Use this type when the host should present the artifact as a typography contract rather than a generic document.",
        "category": "documentation",
        "status": "active",
        "_classBinding": {
          "key": "type-definition",
