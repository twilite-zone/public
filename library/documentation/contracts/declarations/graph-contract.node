        "svg": "<svg viewBox=\"0 0 220 160\" xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\"><rect x=\"18\" y=\"16\" width=\"184\" height=\"128\" rx=\"24\" fill=\"#f7fbff\" stroke=\"#17324d\" stroke-width=\"5\"/><rect x=\"36\" y=\"34\" width=\"92\" height=\"14\" rx=\"7\" fill=\"#dbeafe\"/><rect x=\"136\" y=\"34\" width=\"44\" height=\"14\" rx=\"7\" fill=\"#e2e8f0\"/><rect x=\"36\" y=\"62\" width=\"144\" height=\"18\" rx=\"9\" fill=\"#eef2ff\"/><rect x=\"36\" y=\"92\" width=\"58\" height=\"30\" rx=\"10\" fill=\"#bfdbfe\"/><rect x=\"102\" y=\"92\" width=\"44\" height=\"30\" rx=\"10\" fill=\"#cbd5e1\"/><rect x=\"154\" y=\"92\" width=\"26\" height=\"30\" rx=\"10\" fill=\"#dbeafe\"/></svg>",
