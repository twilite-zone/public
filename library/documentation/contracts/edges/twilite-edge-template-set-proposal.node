        "svg": "<svg viewBox=\"0 0 220 160\" xmlns=\"http://www.w3.org/2000/svg\" width=\"100%\" height=\"100%\" preserveAspectRatio=\"xMidYMid meet\"><rect x=\"18\" y=\"16\" width=\"184\" height=\"128\" rx=\"24\" fill=\"#f8fafc\" stroke=\"#0f172a\" stroke-width=\"5\"/><line x1=\"40\" y1=\"66\" x2=\"124\" y2=\"66\" stroke=\"#ff2d55\" stroke-width=\"7\" stroke-dasharray=\"18 6\" stroke-linecap=\"round\"/><polygon points=\"124,58 140,66 124,74\" fill=\"#ff2d55\"/><line x1=\"40\" y1=\"104\" x2=\"160\" y2=\"104\" stroke=\"#2e7d32\" stroke-width=\"4\" stroke-linecap=\"round\"/><polygon points=\"160,96 174,104 160,112\" fill=\"#2e7d32\"/></svg>",
        "_classBinding": {
