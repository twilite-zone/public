      "data": {
        "title": "Edge Template Set Proposal",
        "purpose": "Stable summary surface for the canonical edge template set proposal.",
        "titleSourceNodeId": "twilite-edge-template-set-proposal-title",
        "typeSourceNodeId": "twilite-edge-template-set-proposal-type",
