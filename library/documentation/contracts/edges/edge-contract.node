    {
      "id": "edge-mutations",
      "type": "markdown",
      "label": "7. Allowed Mutations",
      "position": {
        "x": 900,
        "y": 760
      },
      "width": 460,
      "height": 300,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "## Allowed Mutations\n\n- add edge: allowed\n- remove edge: allowed (unless appendOnly)\n- add, remove, or change runtime `type`: allowed if compatible\n- assign or remove edge class: allowed\n- update instance style overrides: allowed\n- rewire edge: forbidden\n\nMutations not listed are forbidden.",
        "_classBinding": {
