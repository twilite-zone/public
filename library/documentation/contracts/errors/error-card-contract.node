    {
      "id": "error-card-contract-procedure",
      "type": "procedure",
      "label": "Procedure",
      "position": {
        "x": 1180,
        "y": 700
      },
      "width": 420,
      "height": 250,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Procedure",
        "body": "On render failure: classify the failure, normalize it into shared error-card data, render the appropriate fallback card, and preserve enough target context for the graph author to repair the source.",
        "steps": [
          "Read the host port authority; default new ports to navigate.",
          "Read the target exposure: named views, bridgeability, runtime capability, and default root behavior.",
          "Validate semantic meaning, direction, semantic type, multiplicity, and wildcard policy.",
          "Compute effective authority as the minimum of host authority, target exposure, and local policy.",
          "Filter the result to the allowed boundary behavior or refuse if no safe behavior remains."
        ],
        "_classBinding": {
          "key": "procedure",
          "sourceRef": "/library/classes/nodes/skill-contract/procedure.node-class.node",
