    {
      "id": "skill-extract-identity",
      "type": "markdown",
      "label": "Identity Rules",
      "position": {
        "x": -960,
        "y": 900
      },
      "width": 720,
      "height": 340,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "## Identity Rules\n\n- fork=false → IDs preserved\n- fork=true → new IDs minted\n- newManifest=true → new graph identity\n- newManifest=false → caller supplies identity",
        "_classBinding": {
