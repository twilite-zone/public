    {
      "id": "layout-authority-intro",
      "type": "section",
      "label": "Reality First",
      "root": false,
      "position": {
        "x": -460,
        "y": 120
      },
      "width": 500,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Reality First",
        "summary": "Many graphs will never connect. Some graphs expose only narrow surfaces. The app can govern authored spaces, but not arbitrary web content. So the system must treat disconnection as normal and connection as explicit rather than assumed.",
        "level": "h2",
        "anchor": "reality-first",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "layout-authority-bridge-section",
          "sourceBridgeNodeId": "layout-authority-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "layout-authority-local-first",
      "type": "section",
      "label": "Local First",
      "root": false,
      "position": {
        "x": -462,
        "y": 452.1266199144439
      },
      "width": 500,
      "height": 340,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Local Authority First",
        "summary": "A graph starts sovereign. It owns its own structure, what it exposes, and how its content grows. If a graph is not connected, nothing is wrong. Belonging is negotiated by references, views, summaries, and explicit expansion surfaces.",
        "level": "h2",
        "anchor": "local-authority",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "layout-authority-bridge-section",
          "sourceBridgeNodeId": "layout-authority-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "layout-authority-connection",
      "type": "section",
      "label": "Connection",
      "root": false,
      "position": {
        "x": 95.30382627262327,
        "y": 465.03826272623263
      },
      "width": 500,
      "height": 320,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Connection Is Explicit",
        "summary": "Another graph can reference, summarize, expand into, or consume a surface only through what the source graph actually exposes. Connection is relational, not imperial. Someone else has to want to connect to you, and the source graph has to expose a real surface to receive that connection.",
        "level": "h2",
        "anchor": "connection-explicit",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "layout-authority-bridge-section",
          "sourceBridgeNodeId": "layout-authority-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "layout-authority-graph-level",
      "type": "section",
      "label": "Graph-Level Decisions",
      "root": false,
      "position": {
        "x": 686.8560895179747,
        "y": 459.1767265097633
      },
      "width": 560,
      "height": 360,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Growth And Layout Belong To The Graph",
        "summary": "Growth and layout decisions should be made at the graph level. The host graph determines how content is added to its own space, what growth grammar is used by default, and when global relayout is allowed. Local growth is the default authority. Manual placement is sticky. Global relayout is explicit and exceptional rather than ambient. The graph, not incidental cleanup, owns those decisions.",
        "level": "h2",
        "anchor": "graph-level-decisions",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "layout-authority-bridge-section",
          "sourceBridgeNodeId": "layout-authority-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "layout-authority-behavior-law",
      "type": "section",
      "label": "Behavior Law",
      "root": false,
      "position": {
        "x": 686.2386785063467,
        "y": 1509.0450893379461
      },
      "width": 560,
      "height": 380,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Relayout And Reroute Behavior",
        "summary": "Local growth owns normal editing. Expansion, nearby creation, and positionless imports should adapt incrementally near the active area instead of invoking whole-graph cleanup. Manual placement is sticky: once a user has shaped a region, later growth should work around that meaning instead of erasing it. Global relayout is explicit and exceptional, reserved for user-requested layout operations or graphs that have no meaningful placement yet. Reroute is lighter than relayout: edges may adapt as nodes move, but edge cleanup alone should not relocate nodes. Preserve meaning over neatness.",
        "level": "h2",
        "anchor": "relayout-reroute-behavior",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "layout-authority-bridge-section",
          "sourceBridgeNodeId": "layout-authority-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "layout-authority-placement-provenance",
      "type": "section",
      "label": "Placement Provenance",
      "root": false,
      "position": {
        "x": 1318.909723005775,
        "y": 455.0445696128032
      },
      "width": 560,
      "height": 380,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Placement Provenance",
        "summary": "The runtime should not infer layout authority forever from coordinates. It should record placement provenance. Nodes may be unplaced, auto-placed, manually-shaped, or part of a mixed graph. System-created, imported, expanded, and layout-generated positions should be marked auto-placed. User-dragged or intentionally arranged nodes should be marked manually-shaped. A graph with no meaningful placement may accept global relayout. A graph with manual placement should protect that meaning unless the user explicitly grants relayout authority.",
        "level": "h2",
        "anchor": "placement-provenance",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "layout-authority-bridge-section",
          "sourceBridgeNodeId": "layout-authority-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
    {
      "id": "layout-authority-future-shapes",
      "type": "section",
      "label": "Future Shapes",
      "root": false,
      "position": {
        "x": 890.8267277926466,
        "y": 868.9201421226633
      },
      "width": 560,
      "height": 360,
      "visible": true,
      "showLabel": true,
      "data": {
        "title": "Graph Shape First, Section Shapes Later",
        "summary": "The current path is to continue testing with layered growth as the default graph grammar. Later, graphs may allow local sections to choose a different internal shape, such as spiral or radial growth, without breaking the host graph’s larger boundary contract. The host graph keeps overall legibility. Local sections may express themselves inside that boundary.",
        "level": "h2",
        "anchor": "future-shapes",
        "status": "active",
        "_classBinding": {
          "key": "section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "ref": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "_bridge": {
          "sourceNodeId": "layout-authority-bridge-section",
          "sourceBridgeNodeId": "layout-authority-bridge-section",
          "sourceBridgeLabel": "Section",
          "sourceRef": "/library/classes/nodes/document-publishing/section.node-class.node",
          "entryPort": "root",
          "kind": "node-class",
          "targetKind": "node-class",
          "classKey": "section",
          "classRef": "/library/classes/nodes/document-publishing/section.node-class.node"
        },
        "definitionKey": "section"
      }
    },
