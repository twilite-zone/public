      "showLabel": true,
      "data": {
        "title": "Graph Layout Authority",
        "subtitle": "Disconnected is normal. Connection is explicit. Growth and layout decisions belong to the graph that owns the content.",
        "intent": "headline",
        "status": "active",
        "_classBinding": {
          "key": "title",
