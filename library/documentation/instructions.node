    {
      "id": "onboarding-root",
      "type": "markdown",
      "label": "👋 Twilite Onboarding Guide",
      "position": {
        "x": 0,
        "y": 0
      },
      "width": 920,
      "height": 340,
      "visible": true,
      "showLabel": true,
      "data": {
        "markdown": "# Twilite Onboarding Guide\n\nWelcome, orient, and align humans working inside existing Twilite graphs.\n\nTwilite is not a canvas. It is a **living artifact** with history, intent, and obligations.\n\nWhen you open a graph, you become its steward.",
        "_classBinding": {
          "key": "markdown",
          "sourceRef": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
          "ref": "github://twilite-zone/public/library/classes/nodes/markdown.node-class.node",
